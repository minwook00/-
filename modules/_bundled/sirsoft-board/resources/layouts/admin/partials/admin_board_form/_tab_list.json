{
  "meta": {
    "is_partial": true,
    "description": "Board Form - List Tab Content"
  },
  "id": "tab_content_list",
  "type": "basic",
  "name": "Div",
  "props": {
    "id": "tab_content_list"
  },
  "classMap": {
    "key": "{{_computed.isReadOnly ? 'readonly' : 'normal'}}",
    "variants": {
      "readonly": "opacity-60",
      "normal": ""
    }
  },
  "children": [
    {
      "id": "section_list_card",
      "type": "layout",
      "name": "SectionLayout",
      "props": {
        "background": "white",
        "border": true,
        "shadow": "md",
        "rounded": true,
        "padding": "xl",
        "className": "bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-6 mb-6"
      },
      "children": [
        {
          "id": "section_list",
          "type": "basic",
          "name": "H3",
          "props": {
            "className": "text-lg font-semibold text-gray-900 dark:text-white pb-3 mb-6 border-b-2 border-gray-200 dark:border-gray-700"
          },
          "text": "$t:sirsoft-board.admin.form.tabs.list"
        },
        {
          "id": "list_sort_group",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "grid mb-6 pb-8 grid-cols-2 gap-4"
          },
          "children": [
            {
              "id": "order_by_field",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": ""
              },
              "children": [
                {
                  "id": "order_by_label",
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Span",
                      "text": "$t:sirsoft-board.admin.form.fields.order_by.label"
                    }
                  ]
                },
                {
                  "id": "order_by_select",
                  "type": "composite",
                  "name": "Select",
                  "props": {
                    "name": "order_by",
                    "disabled": "{{_computed.isReadOnly}}",
                    "className": "w-full",
                    "options": [
                      {
                        "value": "created_at",
                        "label": "$t:sirsoft-board.admin.form.fields.order_by.options.created_at"
                      },
                      {
                        "value": "view_count",
                        "label": "$t:sirsoft-board.admin.form.fields.order_by.options.view_count"
                      },
                      {
                        "value": "title",
                        "label": "$t:sirsoft-board.admin.form.fields.order_by.options.title"
                      },
                      {
                        "value": "author",
                        "label": "$t:sirsoft-board.admin.form.fields.order_by.options.author"
                      }
                    ]
                  }
                }
              ]
            },
            {
              "id": "order_direction_field",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": ""
              },
              "children": [
                {
                  "id": "order_direction_label",
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Span",
                      "text": "$t:sirsoft-board.admin.form.fields.order_direction.label"
                    }
                  ]
                },
                {
                  "id": "order_direction_select",
                  "type": "composite",
                  "name": "Select",
                  "props": {
                    "name": "order_direction",
                    "disabled": "{{_computed.isReadOnly}}",
                    "className": "w-full",
                    "options": [
                      {
                        "value": "DESC",
                        "label": "$t:sirsoft-board.admin.form.fields.order_direction.options.desc"
                      },
                      {
                        "value": "ASC",
                        "label": "$t:sirsoft-board.admin.form.fields.order_direction.options.asc"
                      }
                    ]
                  }
                }
              ]
            }
          ]
        },
        {
          "id": "list_per_page_group",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "grid grid-cols-2 gap-4"
          },
          "children": [
            {
              "id": "per_page_field",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": ""
              },
              "children": [
                {
                  "id": "per_page_label",
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Span",
                      "text": "$t:sirsoft-board.admin.form.fields.per_page.label"
                    }
                  ]
                },
                {
                  "id": "per_page_input",
                  "type": "basic",
                  "name": "Input",
                  "props": {
                    "type": "number",
                    "name": "per_page",
                    "required": true,
                    "disabled": "{{_computed.isReadOnly}}",
                    "className": "w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white"
                  }
                },
                {
                  "id": "per_page_hint",
                  "type": "basic",
                  "name": "P",
                  "props": {
                    "className": "mt-1 text-xs text-gray-500 dark:text-gray-400"
                  },
                  "text": "$t:sirsoft-board.admin.form.fields.per_page.hint|min={{board_config?.data?.limits?.per_page_min ?? 5}}|max={{board_config?.data?.limits?.per_page_max ?? 100}}"
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "if": "{{_local.errors?.per_page}}",
                  "props": {
                    "className": "text-red-500 dark:text-red-400 text-xs mt-1"
                  },
                  "text": "{{_local.errors?.per_page?.[0] ?? ''}}"
                }
              ]
            },
            {
              "id": "per_page_mobile_field",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": ""
              },
              "children": [
                {
                  "id": "per_page_mobile_label",
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Span",
                      "text": "$t:sirsoft-board.admin.form.fields.per_page_mobile.label"
                    }
                  ]
                },
                {
                  "id": "per_page_mobile_input",
                  "type": "basic",
                  "name": "Input",
                  "props": {
                    "type": "number",
                    "name": "per_page_mobile",
                    "required": true,
                    "disabled": "{{_computed.isReadOnly}}",
                    "className": "w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white"
                  }
                },
                {
                  "id": "per_page_mobile_hint",
                  "type": "basic",
                  "name": "P",
                  "props": {
                    "className": "mt-1 text-xs text-gray-500 dark:text-gray-400"
                  },
                  "text": "$t:sirsoft-board.admin.form.fields.per_page_mobile.hint|min={{board_config?.data?.limits?.per_page_min ?? 5}}|max={{board_config?.data?.limits?.per_page_max ?? 100}}"
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "if": "{{_local.errors?.per_page_mobile}}",
                  "props": {
                    "className": "text-red-500 dark:text-red-400 text-xs mt-1"
                  },
                  "text": "{{_local.errors?.per_page_mobile?.[0] ?? ''}}"
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}