{
  "meta": {
    "is_partial": true,
    "description": "Board Type Management Modal - CRUD for board types"
  },
  "id": "board_type_manage_modal",
  "type": "composite",
  "name": "Modal",
  "props": {
    "title": "$t:sirsoft-board.admin.board_types.modal_title",
    "width": "640px",
    "closeOnBackdropClick": false
  },
  "children": [
    {
      "id": "bt_modal_content",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "space-y-4"
      },
      "classMap": {
        "key": "{{$parent._computed.isReadOnly ? 'readonly' : 'normal'}}",
        "variants": {
          "readonly": "opacity-60",
          "normal": ""
        }
      },
      "children": [
        {
          "id": "bt_usage_guide",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "flex items-start gap-2 text-xs text-blue-600 dark:text-blue-400 bg-blue-50 dark:bg-blue-900/30 border border-blue-200 dark:border-blue-800 rounded-lg px-3 py-2.5"
          },
          "children": [
            {
              "id": "bt_usage_guide_icon",
              "type": "basic",
              "name": "Icon",
              "props": {
                "name": "fa-solid fa-circle-info",
                "className": "mt-0.5 shrink-0"
              }
            },
            {
              "id": "bt_usage_guide_text",
              "type": "basic",
              "name": "Span",
              "props": {
                "className": "leading-relaxed"
              },
              "text": "$t:sirsoft-board.admin.board_types.usage_guide"
            }
          ]
        },
        {
          "id": "bt_list_section",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "max-h-64 overflow-y-auto border border-gray-200 dark:border-gray-700 rounded-lg"
          },
          "children": [
            {
              "id": "bt_table",
              "type": "basic",
              "name": "Table",
              "props": {
                "className": "min-w-full divide-y divide-gray-200 dark:divide-gray-700"
              },
              "children": [
                {
                  "id": "bt_thead",
                  "type": "basic",
                  "name": "Thead",
                  "children": [
                    {
                      "id": "bt_thead_row",
                      "type": "basic",
                      "name": "Tr",
                      "children": [
                        {
                          "id": "bt_th_slug",
                          "type": "basic",
                          "name": "Th",
                          "props": {
                            "className": "px-3 py-2 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider"
                          },
                          "text": "$t:sirsoft-board.admin.board_types.slug"
                        },
                        {
                          "id": "bt_th_name",
                          "type": "basic",
                          "name": "Th",
                          "props": {
                            "className": "px-3 py-2 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider"
                          },
                          "text": "$t:sirsoft-board.admin.board_types.name"
                        },
                        {
                          "id": "bt_th_actions",
                          "type": "basic",
                          "name": "Th",
                          "props": {
                            "className": "px-3 py-2 text-center text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider w-24"
                          },
                          "text": "$t:sirsoft-board.admin.board_types.actions"
                        }
                      ]
                    }
                  ]
                },
                {
                  "id": "bt_tbody",
                  "type": "basic",
                  "name": "Tbody",
                  "props": {
                    "className": "bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700"
                  },
                  "children": [
                    {
                      "id": "bt_empty_row",
                      "type": "basic",
                      "name": "Tr",
                      "if": "{{!_global.boardTypesList || _global.boardTypesList.length === 0}}",
                      "children": [
                        {
                          "id": "bt_empty_cell",
                          "type": "basic",
                          "name": "Td",
                          "props": {
                            "colSpan": 3,
                            "className": "px-3 py-8 text-center text-sm text-gray-500 dark:text-gray-400"
                          },
                          "text": "$t:sirsoft-board.admin.board_types.empty"
                        }
                      ]
                    },
                    {
                      "id": "bt_row",
                      "type": "basic",
                      "name": "Tr",
                      "if": "{{_global.boardTypesList && _global.boardTypesList.length > 0}}",
                      "iteration": {
                        "source": "{{_global.boardTypesList ?? []}}",
                        "item_var": "btItem",
                        "index_var": "btIdx"
                      },
                      "props": {
                        "className": "hover:bg-gray-50 dark:bg-gray-800 dark:hover:bg-gray-700/50 transition-colors duration-150"
                      },
                      "classMap": {
                        "key": "{{_global.btEditingItem?.id === btItem.id ? 'true' : 'false'}}",
                        "variants": {
                          "true": "bg-blue-50 dark:bg-blue-900/20",
                          "false": ""
                        }
                      },
                      "children": [
                        {
                          "id": "bt_td_slug",
                          "type": "basic",
                          "name": "Td",
                          "props": {
                            "className": "px-3 py-2 text-sm text-gray-900 dark:text-gray-100 font-mono"
                          },
                          "text": "{{btItem.slug}}"
                        },
                        {
                          "id": "bt_td_name",
                          "type": "basic",
                          "name": "Td",
                          "props": {
                            "className": "px-3 py-2 text-sm text-gray-900 dark:text-gray-100"
                          },
                          "text": "{{btItem.name[_global.locale ?? 'ko'] ?? btItem.name.ko ?? btItem.slug}}"
                        },
                        {
                          "id": "bt_td_actions",
                          "type": "basic",
                          "name": "Td",
                          "props": {
                            "className": "px-3 py-2 text-center"
                          },
                          "children": [
                            {
                              "id": "bt_action_btns",
                              "type": "basic",
                              "name": "Div",
                              "props": {
                                "className": "flex items-center justify-center gap-1"
                              },
                              "children": [
                                {
                                  "id": "bt_edit_btn",
                                  "type": "basic",
                                  "name": "Button",
                                  "props": {
                                    "type": "button",
                                    "className": "p-1 text-gray-500 dark:text-gray-400 hover:text-blue-600 dark:text-blue-400 dark:hover:text-blue-400",
                                    "title": "$t:common.edit",
                                    "disabled": "{{_computed.isReadOnly || _global.btSaving}}"
                                  },
                                  "actions": [
                                    {
                                      "type": "click",
                                      "handler": "setState",
                                      "params": {
                                        "target": "global",
                                        "btEditingItem": "{{btItem}}",
                                        "btFormMode": "edit",
                                        "btFormSlug": "{{btItem.slug}}",
                                        "btFormName": "{{typeof btItem.name === 'object' ? btItem.name : {ko: btItem.name ?? '', en: ''}}}",
                                        "btFormErrors": null
                                      }
                                    }
                                  ],
                                  "children": [
                                    {
                                      "id": "bt_edit_icon",
                                      "type": "basic",
                                      "name": "Icon",
                                      "props": {
                                        "name": "pencil",
                                        "size": "sm"
                                      }
                                    }
                                  ]
                                },
                                {
                                  "id": "bt_delete_btn",
                                  "type": "basic",
                                  "name": "Button",
                                  "props": {
                                    "type": "button",
                                    "className": "p-1 text-gray-500 dark:text-gray-400 hover:text-red-600 dark:text-red-400 dark:hover:text-red-400 disabled:opacity-50 disabled:cursor-not-allowed",
                                    "title": "$t:common.delete",
                                    "disabled": "{{_global.btDeletingId != null || _global.btSaving}}"
                                  },
                                  "actions": [
                                    {
                                      "type": "click",
                                      "handler": "sequence",
                                      "actions": [
                                        {
                                          "handler": "setState",
                                          "params": {
                                            "target": "global",
                                            "btDeletingId": "{{btItem.id}}"
                                          }
                                        },
                                        {
                                          "handler": "apiCall",
                                          "auth_required": true,
                                          "target": "/api/modules/sirsoft-board/admin/board-types/{{btItem.id}}",
                                          "params": {
                                            "method": "DELETE"
                                          },
                                          "confirm": "$t:sirsoft-board.admin.board_types.delete_confirm",
                                          "onSuccess": [
                                            {
                                              "handler": "setState",
                                              "params": {
                                                "target": "global",
                                                "btDeletingId": null
                                              }
                                            },
                                            {
                                              "handler": "apiCall",
                                              "auth_required": true,
                                              "target": "/api/modules/sirsoft-board/admin/board-types",
                                              "params": {
                                                "method": "GET"
                                              },
                                              "onSuccess": [
                                                {
                                                  "handler": "setState",
                                                  "params": {
                                                    "target": "global",
                                                    "boardTypesList": "{{response.data}}"
                                                  }
                                                }
                                              ]
                                            },
                                            {
                                              "handler": "refetchDataSource",
                                              "params": {
                                                "dataSourceId": "boards"
                                              }
                                            },
                                            {
                                              "handler": "refetchDataSource",
                                              "params": {
                                                "dataSourceId": "board_types"
                                              }
                                            },
                                            {
                                              "handler": "toast",
                                              "params": {
                                                "type": "success",
                                                "message": "$t:sirsoft-board.admin.board_types.delete_success"
                                              }
                                            }
                                          ],
                                          "onError": [
                                            {
                                              "handler": "setState",
                                              "params": {
                                                "target": "global",
                                                "btDeletingId": null
                                              }
                                            },
                                            {
                                              "handler": "toast",
                                              "params": {
                                                "type": "error",
                                                "message": "{{error.errors ? Object.values(error.errors).flat()[0] : error.message}}"
                                              }
                                            }
                                          ]
                                        }
                                      ]
                                    }
                                  ],
                                  "children": [
                                    {
                                      "id": "bt_delete_icon",
                                      "type": "basic",
                                      "name": "Icon",
                                      "if": "{{_global.btDeletingId !== btItem.id}}",
                                      "props": {
                                        "name": "trash",
                                        "size": "sm"
                                      }
                                    },
                                    {
                                      "id": "bt_delete_spinner",
                                      "type": "basic",
                                      "name": "Icon",
                                      "if": "{{_global.btDeletingId === btItem.id}}",
                                      "props": {
                                        "name": "spinner",
                                        "className": "w-4 h-4 animate-spin"
                                      }
                                    }
                                  ],
                                  "if": "{{!_computed.isReadOnly}}"
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "id": "bt_form_section",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "border-t border-gray-200 dark:border-gray-700 pt-4 rounded-lg transition-all duration-200"
          },
          "classMap": {
            "key": "{{_global.btFormMode}}",
            "variants": {
              "edit": "ring-2 ring-blue-300 dark:ring-blue-600 bg-blue-50/30 dark:bg-blue-900/10 p-4 -mx-1",
              "add": ""
            }
          },
          "children": [
            {
              "id": "bt_form_header",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex items-center justify-between mb-3"
              },
              "children": [
                {
                  "id": "bt_form_title",
                  "type": "basic",
                  "name": "H3",
                  "props": {
                    "className": "text-sm font-semibold text-gray-900 dark:text-white"
                  },
                  "text": "{{_global.btFormMode === 'edit' ? '$t:sirsoft-board.admin.board_types.edit_title' : '$t:sirsoft-board.admin.board_types.add_title'}}"
                },
                {
                  "id": "bt_form_cancel_btn",
                  "type": "basic",
                  "name": "Button",
                  "if": "{{_global.btFormMode === 'edit'}}",
                  "props": {
                    "type": "button",
                    "className": "px-2.5 py-1 text-xs font-medium text-gray-600 dark:text-gray-300 bg-gray-100 dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-md hover:bg-gray-200 dark:hover:bg-gray-600"
                  },
                  "text": "$t:common.cancel",
                  "actions": [
                    {
                      "type": "click",
                      "handler": "setState",
                      "params": {
                        "target": "global",
                        "btFormMode": "add",
                        "btEditingItem": null,
                        "btFormSlug": "",
                        "btFormName": {
                          "ko": "",
                          "en": ""
                        },
                        "btFormErrors": null
                      }
                    }
                  ]
                }
              ]
            },
            {
              "id": "bt_form_fields",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "space-y-3"
              },
              "children": [
                {
                  "id": "bt_field_slug",
                  "type": "basic",
                  "name": "Div",
                  "children": [
                    {
                      "id": "bt_label_slug",
                      "type": "basic",
                      "name": "Label",
                      "props": {
                        "className": "block text-xs font-medium text-gray-700 dark:text-gray-300 mb-1"
                      },
                      "text": "$t:sirsoft-board.admin.board_types.slug"
                    },
                    {
                      "id": "bt_input_slug",
                      "type": "basic",
                      "name": "Input",
                      "props": {
                        "type": "text",
                        "value": "{{_global.btFormSlug ?? ''}}",
                        "placeholder": "basic",
                        "className": "w-full px-2 py-1.5 text-sm border rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 focus:ring-1 focus:ring-blue-500 dark:focus:ring-blue-400 focus:border-blue-500",
                        "disabled": "{{_computed.isReadOnly || _global.btFormMode === 'edit'}}"
                      },
                      "classMap": {
                        "key": "{{_global.btFormErrors?.slug ? 'error' : 'normal'}}",
                        "variants": {
                          "error": "border-red-500 dark:border-red-400",
                          "normal": "border-gray-300 dark:border-gray-600"
                        }
                      },
                      "actions": [
                        {
                          "type": "input",
                          "handler": "setState",
                          "params": {
                            "target": "global",
                            "btFormSlug": "{{$event.target.value}}",
                            "btFormErrors": "{{(() => { const e = {...(_global.btFormErrors ?? {})}; delete e.slug; return Object.keys(e).length ? e : null; })()}}"
                          }
                        }
                      ]
                    },
                    {
                      "id": "bt_slug_hint",
                      "type": "basic",
                      "name": "P",
                      "if": "{{_global.btFormMode !== 'edit' && !_global.btFormErrors?.slug}}",
                      "props": {
                        "className": "mt-1 text-xs text-gray-400 dark:text-gray-500"
                      },
                      "text": "$t:sirsoft-board.admin.board_types.slug_hint"
                    },
                    {
                      "id": "bt_slug_error",
                      "type": "basic",
                      "name": "P",
                      "if": "{{_global.btFormErrors?.slug}}",
                      "props": {
                        "className": "mt-1 text-xs text-red-500 dark:text-red-400"
                      },
                      "text": "{{_global.btFormErrors?.slug?.[0] ?? ''}}"
                    }
                  ]
                },
                {
                  "id": "bt_field_name",
                  "type": "basic",
                  "name": "Div",
                  "children": [
                    {
                      "id": "bt_label_name",
                      "type": "basic",
                      "name": "Label",
                      "props": {
                        "className": "block text-xs font-medium text-gray-700 dark:text-gray-300 mb-1"
                      },
                      "text": "$t:sirsoft-board.admin.board_types.name"
                    },
                    {
                      "id": "bt_input_name",
                      "type": "composite",
                      "name": "MultilingualInput",
                      "props": {
                        "value": "{{_global.btFormName ?? {ko: '', en: ''}}}",
                        "layout": "tabs",
                        "name": "bt_form_name",
                        "placeholder": "$t:sirsoft-board.admin.board_types.name_placeholder",
                        "maxLength": 100,
                        "required": true,
                        "error": "{{_global.btFormErrors?.['name.ko']?.[0] ?? ''}}",
                        "disabled": "{{_computed.isReadOnly}}"
                      },
                      "actions": [
                        {
                          "event": "onChange",
                          "handler": "setState",
                          "params": {
                            "target": "global",
                            "btFormName": "{{$args[0]?.target?.value ?? _global.btFormName}}",
                            "btFormErrors": "{{(() => { const e = {...(_global.btFormErrors ?? {})}; delete e['name.ko']; delete e['name']; return Object.keys(e).length ? e : null; })()}}"
                          }
                        }
                      ]
                    },
                    {
                      "id": "bt_name_error",
                      "type": "basic",
                      "name": "P",
                      "if": "{{_global.btFormErrors?.['name.ko'] || _global.btFormErrors?.['name']}}",
                      "props": {
                        "className": "mt-1 text-xs text-red-500 dark:text-red-400"
                      },
                      "text": "{{_global.btFormErrors?.['name.ko']?.[0] ?? _global.btFormErrors?.['name']?.[0] ?? ''}}"
                    }
                  ]
                }
              ]
            },
            {
              "id": "bt_form_submit",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex justify-end mt-3"
              },
              "children": [
                {
                  "id": "bt_submit_btn",
                  "type": "basic",
                  "name": "Button",
                  "props": {
                    "type": "button",
                    "className": "flex items-center gap-2 px-4 py-2 bg-blue-600 text-white text-sm rounded-lg hover:bg-blue-700 dark:bg-blue-500 dark:hover:bg-blue-600 disabled:opacity-50 disabled:cursor-not-allowed",
                    "disabled": "{{_computed.isReadOnly || _global.btSaving || !_global.btFormSlug || !_global.btFormName?.ko}}"
                  },
                  "actions": [
                    {
                      "type": "click",
                      "handler": "sequence",
                      "actions": [
                        {
                          "handler": "setState",
                          "params": {
                            "target": "global",
                            "btSaving": true,
                            "btFormErrors": null
                          }
                        },
                        {
                          "handler": "apiCall",
                          "auth_required": true,
                          "target": "{{_global.btFormMode === 'edit' ? '/api/modules/sirsoft-board/admin/board-types/' + _global.btEditingItem.id : '/api/modules/sirsoft-board/admin/board-types'}}",
                          "params": {
                            "method": "{{_global.btFormMode === 'edit' ? 'PUT' : 'POST'}}",
                            "body": {
                              "slug": "{{_global.btFormSlug}}",
                              "name": "{{_global.btFormName ?? {ko: '', en: ''}}}"
                            }
                          },
                          "onSuccess": [
                            {
                              "handler": "setState",
                              "params": {
                                "target": "global",
                                "btSaving": false,
                                "btFormMode": "add",
                                "btEditingItem": null,
                                "btFormSlug": "",
                                "btFormName": {
                                  "ko": "",
                                  "en": ""
                                },
                                "btFormErrors": null
                              }
                            },
                            {
                              "handler": "apiCall",
                              "auth_required": true,
                              "target": "/api/modules/sirsoft-board/admin/board-types",
                              "params": {
                                "method": "GET"
                              },
                              "onSuccess": [
                                {
                                  "handler": "setState",
                                  "params": {
                                    "target": "global",
                                    "boardTypesList": "{{response.data}}"
                                  }
                                }
                              ]
                            },
                            {
                              "handler": "refetchDataSource",
                              "params": {
                                "dataSourceId": "boards"
                              }
                            },
                            {
                              "handler": "refetchDataSource",
                              "params": {
                                "dataSourceId": "board_types"
                              }
                            },
                            {
                              "handler": "toast",
                              "params": {
                                "type": "success",
                                "message": "{{_global.btFormMode === 'edit' ? '$t:sirsoft-board.admin.board_types.update_success' : '$t:sirsoft-board.admin.board_types.create_success'}}"
                              }
                            }
                          ],
                          "onError": [
                            {
                              "handler": "setState",
                              "params": {
                                "target": "global",
                                "btSaving": false,
                                "btFormErrors": "{{error.errors ?? null}}"
                              }
                            },
                            {
                              "handler": "toast",
                              "params": {
                                "type": "error",
                                "message": "{{error.errors ? Object.values(error.errors).flat()[0] : error.message}}"
                              }
                            }
                          ]
                        }
                      ]
                    }
                  ],
                  "children": [
                    {
                      "id": "bt_submit_spinner",
                      "type": "basic",
                      "name": "Icon",
                      "if": "{{_global.btSaving}}",
                      "props": {
                        "name": "spinner",
                        "className": "w-4 h-4 animate-spin"
                      }
                    },
                    {
                      "id": "bt_submit_text",
                      "type": "basic",
                      "name": "Span",
                      "text": "{{_global.btFormMode === 'edit' ? (_global.btSaving ? '$t:common.saving' : '$t:common.save') : (_global.btSaving ? '$t:sirsoft-board.admin.board_types.adding' : '$t:sirsoft-board.admin.board_types.add')}}"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "bt_modal_footer",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "flex justify-end mt-6"
      },
      "children": [
        {
          "id": "bt_modal_close_btn",
          "type": "basic",
          "name": "Button",
          "props": {
            "type": "button",
            "className": "px-4 py-2 bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700"
          },
          "actions": [
            {
              "type": "click",
              "handler": "sequence",
              "actions": [
                {
                  "handler": "setState",
                  "params": {
                    "target": "global",
                    "btFormMode": "add",
                    "btEditingItem": null,
                    "btFormSlug": "",
                    "btFormName": {
                      "ko": "",
                      "en": ""
                    },
                    "btFormErrors": null
                  }
                },
                {
                  "handler": "closeModal"
                }
              ]
            }
          ],
          "children": [
            {
              "id": "bt_close_text",
              "type": "basic",
              "name": "Span",
              "text": "$t:common.close"
            }
          ]
        }
      ]
    }
  ]
}
