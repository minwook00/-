{
  "meta": {
    "is_partial": true,
    "description": "Admin Board Reply Card Content - Simplified View Only"
  },
  "type": "basic",
  "name": "Div",
  "children": [
    {
      "id": "reply_header",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "p-6 border-b border-gray-200 dark:border-gray-700"
      },
      "children": [
        {
          "id": "title_row",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "flex flex-row items-start justify-between gap-4 mb-4"
          },
          "responsive": {
            "portable": {
              "props": {
                "className": "flex flex-col gap-3 mb-4"
              }
            }
          },
          "children": [
            {
              "id": "title_with_badges",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex-1 min-w-0"
              },
              "children": [
                {
                  "id": "title_with_prefix",
                  "type": "basic",
                  "name": "H2",
                  "props": {
                    "className": "text-xl font-semibold text-gray-900 dark:text-white flex items-center gap-2 flex-wrap"
                  },
                  "responsive": {
                    "portable": {
                      "props": {
                        "className": "text-lg font-semibold text-gray-900 dark:text-white flex items-center gap-2 flex-wrap"
                      }
                    }
                  },
                  "children": [
                    {
                      "id": "reply_arrow_icon",
                      "type": "composite",
                      "name": "Icon",
                      "props": {
                        "name": "arrow-right",
                        "className": "w-4 h-4 text-blue-600 dark:text-blue-400 flex-shrink-0"
                      }
                    },
                    {
                      "id": "category_badge_prefix",
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200"
                      },
                      "text": "{{item.category}}",
                      "if": "{{item.category}}"
                    },
                    {
                      "id": "notice_prefix",
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "text-blue-600 dark:text-blue-400"
                      },
                      "text": "$t:sirsoft-board.admin.posts.badge.notice",
                      "if": "{{item.is_notice}}"
                    },
                    {
                      "id": "title_text",
                      "type": "basic",
                      "name": "Span",
                      "text": "{{item.title}}"
                    },
                    {
                      "id": "attachment_icon",
                      "type": "composite",
                      "name": "Icon",
                      "if": "{{item.has_attachment}}",
                      "props": {
                        "name": "paperclip",
                        "className": "w-4 h-4 text-gray-500 dark:text-gray-400 flex-shrink-0"
                      }
                    },
                    {
                      "id": "new_badge",
                      "type": "basic",
                      "name": "Span",
                      "if": "{{item.is_new}}",
                      "props": {
                        "className": "inline-flex items-center px-2 py-0.5 rounded text-xs font-bold bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200"
                      },
                      "text": "$t:sirsoft-board.common.new"
                    },
                    {
                      "id": "secret_icon",
                      "type": "composite",
                      "name": "Icon",
                      "props": {
                        "name": "lock",
                        "className": "w-5 h-5 text-yellow-600 dark:text-yellow-400 flex-shrink-0"
                      },
                      "if": "{{item.is_secret}}"
                    },
                    {
                      "id": "status_badge_blinded",
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-orange-100 text-orange-800 dark:bg-orange-900 dark:text-orange-200"
                      },
                      "text": "$t:sirsoft-board.admin.posts.detail.status_blinded",
                      "if": "{{item.status === 'blinded'}}"
                    },
                    {
                      "id": "status_badge_deleted",
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-800 text-white dark:bg-gray-600 dark:text-gray-100"
                      },
                      "text": "$t:sirsoft-board.admin.posts.detail.status_deleted",
                      "if": "{{item.deleted_at}}"
                    }
                  ]
                }
              ]
            },
            {
              "id": "detail_button",
              "type": "basic",
              "name": "Button",
              "props": {
                "className": "flex items-center gap-1.5 px-3 py-1.5 text-sm bg-gray-800 dark:bg-gray-700 text-white rounded-lg hover:bg-gray-900 dark:hover:bg-gray-600 transition-colors"
              },
              "if": "{{item.id != route.id}}",
              "actions": [
                {
                  "type": "click",
                  "handler": "navigate",
                  "params": {
                    "path": "/admin/board/{{route.slug}}/post/{{item.id}}"
                  }
                }
              ],
              "children": [
                {
                  "type": "basic",
                  "name": "Span",
                  "text": "$t:sirsoft-board.admin.posts.detail.view_detail_button"
                }
              ]
            }
          ]
        },
        {
          "id": "reply_meta",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "flex flex-wrap items-center gap-2 text-sm text-gray-600 dark:text-gray-400"
          },
          "children": [
            {
              "id": "author_name_menu",
              "type": "composite",
              "name": "ActionMenu",
              "if": "{{!item.author?.is_guest}}",
              "props": {
                "triggerLabel": "{{item.author?.name}}",
                "triggerIconName": "",
                "triggerClassName": "font-medium text-gray-900 dark:text-white",
                "position": "right",
                "items": [
                  {
                    "id": "view_user_info",
                    "label": "$t:sirsoft-board.admin.posts.detail.user_info",
                    "iconName": "user"
                  }
                ]
              },
              "actions": [
                {
                  "event": "onItemClick",
                  "type": "click",
                  "handler": "switch",
                  "value": "{{$args[0]}}",
                  "cases": {
                    "view_user_info": {
                      "handler": "navigate",
                      "params": {
                        "path": "/admin/users/{{item.author?.uuid}}"
                      }
                    }
                  }
                }
              ]
            },
            {
              "type": "basic",
              "name": "Span",
              "if": "{{item.author?.is_guest}}",
              "props": {
                "className": "text-sm font-medium text-gray-900 dark:text-white"
              },
              "text": "{{item.author?.name}}"
            },
            {
              "type": "basic",
              "name": "Span",
              "props": {
                "className": "text-sm text-gray-500 dark:text-gray-400"
              },
              "text": "({{item.author?.email}})",
              "if": "{{item.author?.email}}"
            },
            {
              "type": "basic",
              "name": "Span",
              "props": {
                "className": "inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-600 dark:bg-gray-700 dark:text-gray-300"
              },
              "text": "$t:sirsoft-board.admin.posts.guest",
              "if": "{{item.author?.is_guest}}"
            },
            {
              "type": "basic",
              "name": "Span",
              "text": "·"
            },
            {
              "type": "basic",
              "name": "Span",
              "text": "{{item.created_at}}"
            },
            {
              "id": "comment_count_separator",
              "type": "basic",
              "name": "Span",
              "if": "{{(item.comment_count ?? 0) > 0}}",
              "text": "·"
            },
            {
              "id": "comment_count",
              "type": "basic",
              "name": "Div",
              "if": "{{(item.comment_count ?? 0) > 0}}",
              "props": {
                "className": "flex items-center gap-1"
              },
              "children": [
                {
                  "type": "composite",
                  "name": "Icon",
                  "props": {
                    "name": "comment",
                    "className": "w-4 h-4"
                  }
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "text": "$t:sirsoft-board.admin.posts.detail.comments_title|count={{item.comment_count}}"
                }
              ]
            },
            {
              "type": "basic",
              "name": "Span",
              "if": "{{item.ip_address}}",
              "text": "·"
            },
            {
              "type": "basic",
              "name": "Span",
              "if": "{{item.ip_address}}",
              "props": {
                "className": "text-xs text-gray-500 dark:text-gray-400"
              },
              "text": "IP: {{item.ip_address}}"
            }
          ]
        }
      ]
    },
    {
      "id": "attachments_section",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "px-6 py-4 border-b border-gray-200 dark:border-gray-700"
      },
      "if": "{{(item.attachments ?? []).length > 0}}",
      "children": [
        {
          "id": "attachments_toggle",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "flex items-center justify-between cursor-pointer"
          },
          "actions": [
            {
              "type": "click",
              "handler": "setState",
              "params": {
                "target": "local",
                "showAttachments": "{{!_local.showAttachments}}"
              }
            }
          ],
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex items-center gap-2 text-sm font-medium text-gray-700 dark:text-gray-300"
              },
              "children": [
                {
                  "type": "composite",
                  "name": "Icon",
                  "props": {
                    "name": "paperclip",
                    "className": "w-4 h-4"
                  }
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "text": "$t:sirsoft-board.admin.posts.detail.attachments|count={{(item.attachments ?? []).length}}"
                }
              ]
            },
            {
              "type": "composite",
              "name": "Icon",
              "props": {
                "name": "{{_local.showAttachments ? 'chevron-up' : 'chevron-down'}}",
                "className": "w-4 h-4 text-gray-500 dark:text-gray-400"
              }
            }
          ]
        },
        {
          "id": "attachments_list",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "mt-3 ml-4 grid grid-cols-1 gap-2"
          },
          "if": "{{_local.showAttachments}}",
          "iteration": {
            "source": "item.attachments ?? []",
            "item_var": "attachment",
            "index_var": "index"
          },
          "children": [
            {
              "id": "attachment_card",
              "type": "basic",
              "name": "A",
              "props": {
                "href": "{{attachment.download_url}}",
                "className": "flex items-center gap-2 px-3 py-2 hover:bg-gray-100 dark:bg-gray-700 dark:hover:bg-gray-700 hover:border-gray-300 dark:border-gray-600 dark:hover:border-gray-500 transition-all cursor-pointer group no-underline"
              },
              "children": [
                {
                  "type": "composite",
                  "name": "Icon",
                  "props": {
                    "name": "download",
                    "className": "w-4 h-4 text-gray-500 dark:text-gray-400 group-hover:text-blue-600 dark:text-blue-400 dark:group-hover:text-blue-400 transition-colors flex-shrink-0"
                  }
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-sm text-gray-900 dark:text-white truncate flex-1"
                  },
                  "text": "{{attachment.original_filename}} ({{attachment.size_formatted}})"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "reply_content",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "p-6"
      },
      "children": [
        {
          "id": "reply_html_content",
          "type": "extension_point",
          "name": "html_content",
          "props": {
            "content": "{{item?.content}}",
            "isHtml": "{{(item?.content_mode ?? 'text') === 'html'}}",
            "className": "{{_local.expandedReplies?.[item.id] ? 'prose dark:prose-invert max-w-none' : 'line-clamp-3'}} text-gray-900 dark:text-gray-100"
          },
          "default": [
            {
              "type": "composite",
              "name": "HtmlContent",
              "props": {
                "content": "{{item?.content}}",
                "isHtml": "{{(item?.content_mode ?? 'text') === 'html'}}",
                "className": "{{_local.expandedReplies?.[item.id] ? 'prose dark:prose-invert max-w-none' : 'line-clamp-3'}} text-gray-900 dark:text-gray-100"
              }
            }
          ]
        },
        {
          "type": "basic",
          "name": "Button",
          "if": "{{(item?.content?.length ?? 0) > 150}}",
          "props": {
            "type": "button",
            "className": "mt-2 text-xs text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 font-medium transition-colors flex items-center gap-1"
          },
          "actions": [
            {
              "type": "click",
              "handler": "setState",
              "params": {
                "target": "local",
                "expandedReplies": "{{Object.assign({}, _local.expandedReplies || {}, {[item.id]: !_local.expandedReplies?.[item.id]})}}"
              }
            }
          ],
          "children": [
            {
              "type": "basic",
              "name": "Span",
              "text": "{{_local.expandedReplies?.[item.id] ? '$t:sirsoft-board.admin.posts.form.hide_content' : '$t:sirsoft-board.admin.posts.form.show_full_content'}}"
            },
            {
              "type": "basic",
              "name": "Icon",
              "props": {
                "name": "{{_local.expandedReplies?.[item.id] ? 'chevron-up' : 'chevron-down'}}",
                "className": "w-3 h-3"
              }
            }
          ]
        }
      ]
    }
  ]
}