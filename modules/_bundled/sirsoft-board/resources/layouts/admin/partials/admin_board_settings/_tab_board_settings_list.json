{
  "meta": {
    "is_partial": true,
    "description": "게시판 설정 > 목록 탭"
  },
  "id": "list",
  "type": "basic",
  "name": "Div",
  "if": "{{(_global.activeBoardSettingsTab || query.tab || 'general') === 'basic_defaults'}}",
  "props": {
    "className": "mt-6 space-y-6"
  },
  "classMap": {
    "key": "{{_computed.isReadOnly ? 'readonly' : 'normal'}}",
    "variants": {
      "readonly": "opacity-60",
      "normal": ""
    }
  },
  "children": [
    {
      "id": "section_list",
      "type": "layout",
      "name": "SectionLayout",
      "props": {
        "className": "bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-6 mb-6"
      },
      "children": [
        {
          "type": "basic",
          "name": "H3",
          "props": {
            "className": "text-lg font-semibold text-gray-900 dark:text-white pb-3 mb-2 border-b-2 border-gray-200 dark:border-gray-700"
          },
          "text": "$t:sirsoft-board.admin.settings.sections.list"
        },
        {
          "id": "field_order_by",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "{{(_local.bulkApplyFields ?? []).includes('order_by') ? 'bg-blue-50 dark:bg-blue-900/30' : 'hover:bg-gray-50 dark:hover:bg-gray-700'}} transition-colors border-b border-gray-200 dark:border-gray-700"
          },
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex items-center gap-4 px-3 py-3"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "flex items-start gap-2 text-sm font-medium text-gray-700 dark:text-gray-300 flex-1 cursor-pointer"
                  },
                  "actions": [
                    {
                      "type": "click",
                      "handler": "setState",
                      "params": {
                        "target": "local",
                        "bulkApplyFields": "{{(_local.bulkApplyFields ?? []).includes('order_by') ? (_local.bulkApplyFields ?? []).filter(f => f !== 'order_by') : [...(_local.bulkApplyFields ?? []), 'order_by']}}"
                      }
                    }
                  ],
                  "children": [
                    {
                      "type": "basic",
                      "name": "Input",
                      "props": {
                        "type": "checkbox",
                        "className": "checkbox flex-shrink-0 mt-0.5",
                        "checked": "{{(_local.bulkApplyFields ?? []).includes('order_by')}}"
                      }
                    },
                    {
                      "type": "basic",
                      "name": "Div",
                      "children": [
                        {
                          "type": "basic",
                          "name": "Span",
                          "text": "$t:sirsoft-board.admin.settings.fields.order_by"
                        },
                        {
                          "type": "basic",
                          "name": "P",
                          "props": {
                            "className": "text-xs text-gray-500 dark:text-gray-400 mt-0.5 font-normal"
                          },
                          "text": "$t:sirsoft-board.admin.settings.fields.descriptions.order_by"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "composite",
                  "name": "Select",
                  "props": {
                    "name": "basic_defaults.order_by",
                    "options": [
                      { "value": "created_at", "label": "$t:sirsoft-board.admin.settings.options.order_by.created_at" },
                      { "value": "view_count", "label": "$t:sirsoft-board.admin.settings.options.order_by.view_count" },
                      { "value": "title", "label": "$t:sirsoft-board.admin.settings.options.order_by.title" },
                      { "value": "author", "label": "$t:sirsoft-board.admin.settings.options.order_by.author" }
                    ],
                    "className": "w-48 flex-shrink-0 text-sm",
                    "disabled": "{{_computed.isReadOnly}}"
                  }
                }
              ]
            }
          ]
        },
        {
          "id": "field_order_direction",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "{{(_local.bulkApplyFields ?? []).includes('order_direction') ? 'bg-blue-50 dark:bg-blue-900/30' : 'hover:bg-gray-50 dark:hover:bg-gray-700'}} transition-colors border-b border-gray-200 dark:border-gray-700"
          },
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex items-center gap-4 px-3 py-3"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "flex items-start gap-2 text-sm font-medium text-gray-700 dark:text-gray-300 flex-1 cursor-pointer"
                  },
                  "actions": [
                    {
                      "type": "click",
                      "handler": "setState",
                      "params": {
                        "target": "local",
                        "bulkApplyFields": "{{(_local.bulkApplyFields ?? []).includes('order_direction') ? (_local.bulkApplyFields ?? []).filter(f => f !== 'order_direction') : [...(_local.bulkApplyFields ?? []), 'order_direction']}}"
                      }
                    }
                  ],
                  "children": [
                    {
                      "type": "basic",
                      "name": "Input",
                      "props": {
                        "type": "checkbox",
                        "className": "checkbox flex-shrink-0 mt-0.5",
                        "checked": "{{(_local.bulkApplyFields ?? []).includes('order_direction')}}"
                      }
                    },
                    {
                      "type": "basic",
                      "name": "Div",
                      "children": [
                        {
                          "type": "basic",
                          "name": "Span",
                          "text": "$t:sirsoft-board.admin.settings.fields.order_direction"
                        },
                        {
                          "type": "basic",
                          "name": "P",
                          "props": {
                            "className": "text-xs text-gray-500 dark:text-gray-400 mt-0.5 font-normal"
                          },
                          "text": "$t:sirsoft-board.admin.settings.fields.descriptions.order_direction"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "composite",
                  "name": "Select",
                  "props": {
                    "name": "basic_defaults.order_direction",
                    "options": [
                      { "value": "DESC", "label": "$t:sirsoft-board.admin.settings.options.order_direction.DESC" },
                      { "value": "ASC", "label": "$t:sirsoft-board.admin.settings.options.order_direction.ASC" }
                    ],
                    "className": "w-48 flex-shrink-0 text-sm",
                    "disabled": "{{_computed.isReadOnly}}"
                  }
                }
              ]
            }
          ]
        },
        {
          "id": "field_per_page",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "{{(_local.bulkApplyFields ?? []).includes('per_page') ? 'bg-blue-50 dark:bg-blue-900/30' : 'hover:bg-gray-50 dark:hover:bg-gray-700'}} transition-colors border-b border-gray-200 dark:border-gray-700"
          },
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex items-center gap-4 px-3 py-3"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "flex items-start gap-2 text-sm font-medium text-gray-700 dark:text-gray-300 flex-1 cursor-pointer"
                  },
                  "actions": [
                    {
                      "type": "click",
                      "handler": "setState",
                      "params": {
                        "target": "local",
                        "bulkApplyFields": "{{(_local.bulkApplyFields ?? []).includes('per_page') ? (_local.bulkApplyFields ?? []).filter(f => f !== 'per_page') : [...(_local.bulkApplyFields ?? []), 'per_page']}}"
                      }
                    }
                  ],
                  "children": [
                    {
                      "type": "basic",
                      "name": "Input",
                      "props": {
                        "type": "checkbox",
                        "className": "checkbox flex-shrink-0 mt-0.5",
                        "checked": "{{(_local.bulkApplyFields ?? []).includes('per_page')}}"
                      }
                    },
                    {
                      "type": "basic",
                      "name": "Div",
                      "children": [
                        {
                          "type": "basic",
                          "name": "Span",
                          "text": "$t:sirsoft-board.admin.settings.fields.per_page"
                        },
                        {
                          "type": "basic",
                          "name": "P",
                          "props": {
                            "className": "text-xs text-gray-500 dark:text-gray-400 mt-0.5 font-normal"
                          },
                          "text": "$t:sirsoft-board.admin.settings.fields.descriptions.per_page"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "props": { "className": "flex-shrink-0" },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Input",
                      "props": {
                        "type": "number",
                        "name": "basic_defaults.per_page",
                        "min": 1,
                        "max": 100,
                        "className": "{{(_local.errors?.['basic_defaults.per_page']) ? 'w-32 px-3 py-2 text-sm border border-red-500 dark:border-red-500 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white' : 'w-32 px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white'}}",
                        "disabled": "{{_computed.isReadOnly}}"
                      }
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "if": "{{_local.errors?.['basic_defaults.per_page']}}",
                      "props": { "className": "text-xs text-red-600 dark:text-red-400 block mt-1" },
                      "text": "{{(Array.isArray(_local.errors?.['basic_defaults.per_page']) ? _local.errors['basic_defaults.per_page'][0] : _local.errors?.['basic_defaults.per_page']) ?? ''}}"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "id": "field_per_page_mobile",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "{{(_local.bulkApplyFields ?? []).includes('per_page_mobile') ? 'bg-blue-50 dark:bg-blue-900/30' : 'hover:bg-gray-50 dark:hover:bg-gray-700'}} transition-colors"
          },
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex items-center gap-4 px-3 py-3"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "flex items-start gap-2 text-sm font-medium text-gray-700 dark:text-gray-300 flex-1 cursor-pointer"
                  },
                  "actions": [
                    {
                      "type": "click",
                      "handler": "setState",
                      "params": {
                        "target": "local",
                        "bulkApplyFields": "{{(_local.bulkApplyFields ?? []).includes('per_page_mobile') ? (_local.bulkApplyFields ?? []).filter(f => f !== 'per_page_mobile') : [...(_local.bulkApplyFields ?? []), 'per_page_mobile']}}"
                      }
                    }
                  ],
                  "children": [
                    {
                      "type": "basic",
                      "name": "Input",
                      "props": {
                        "type": "checkbox",
                        "className": "checkbox flex-shrink-0 mt-0.5",
                        "checked": "{{(_local.bulkApplyFields ?? []).includes('per_page_mobile')}}"
                      }
                    },
                    {
                      "type": "basic",
                      "name": "Div",
                      "children": [
                        {
                          "type": "basic",
                          "name": "Span",
                          "text": "$t:sirsoft-board.admin.settings.fields.per_page_mobile"
                        },
                        {
                          "type": "basic",
                          "name": "P",
                          "props": {
                            "className": "text-xs text-gray-500 dark:text-gray-400 mt-0.5 font-normal"
                          },
                          "text": "$t:sirsoft-board.admin.settings.fields.descriptions.per_page_mobile"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "props": { "className": "flex-shrink-0" },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Input",
                      "props": {
                        "type": "number",
                        "name": "basic_defaults.per_page_mobile",
                        "min": 1,
                        "max": 100,
                        "className": "{{(_local.errors?.['basic_defaults.per_page_mobile']) ? 'w-32 px-3 py-2 text-sm border border-red-500 dark:border-red-500 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white' : 'w-32 px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white'}}",
                        "disabled": "{{_computed.isReadOnly}}"
                      }
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "if": "{{_local.errors?.['basic_defaults.per_page_mobile']}}",
                      "props": { "className": "text-xs text-red-600 dark:text-red-400 block mt-1" },
                      "text": "{{(Array.isArray(_local.errors?.['basic_defaults.per_page_mobile']) ? _local.errors['basic_defaults.per_page_mobile'][0] : _local.errors?.['basic_defaults.per_page_mobile']) ?? ''}}"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
