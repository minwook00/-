{
  "meta": {
    "is_partial": true,
    "description": "게시판 환경설정 신고 정책 탭 콘텐츠"
  },
  "id": "tab_content_report_policy",
  "type": "basic",
  "name": "Div",
  "if": "{{(_global.activeBoardSettingsTab || query.tab || 'general') === 'report_policy'}}",
  "props": {
    "className": "space-y-6"
  },
  "classMap": {
    "key": "{{_computed.isReadOnly ? 'readonly' : 'normal'}}",
    "variants": {
      "readonly": "opacity-60",
      "normal": ""
    }
  },
  "children": [
    {
      "comment": "========== 카드 1: 자동 블라인드 처리 ==========",
      "id": "section_auto_hide",
      "type": "layout",
      "name": "SectionLayout",
      "props": {
        "className": "bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-6 mb-6"
      },
      "children": [
        {
          "type": "basic",
          "name": "H3",
          "props": {
            "className": "text-lg font-semibold text-gray-900 dark:text-white pb-3 mb-4 border-b-2 border-gray-200 dark:border-gray-700"
          },
          "text": "$t:sirsoft-board.admin.settings.sections.auto_hide"
        },
        {
          "type": "basic",
          "name": "Span",
          "props": {
            "className": "text-sm text-gray-500 dark:text-gray-400 block mb-6"
          },
          "text": "$t:sirsoft-board.admin.settings.sections.auto_hide_description"
        },
        {
          "id": "field_auto_hide_threshold",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "space-y-2 mb-6"
          },
          "children": [
            {
              "type": "basic",
              "name": "Label",
              "props": {
                "className": "block text-sm font-medium text-gray-700 dark:text-gray-300"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Span",
                  "text": "$t:sirsoft-board.admin.settings.fields.auto_hide_threshold"
                }
              ]
            },
            {
              "type": "basic",
              "name": "Input",
              "props": {
                "type": "number",
                "name": "report_policy.auto_hide_threshold",
                "min": 1,
                "max": 100,
                "className": "{{(_local.errors?.['report_policy.auto_hide_threshold']) ? 'w-full px-3 py-2 border border-red-500 dark:border-red-500 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white' : 'w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white'}}",
                "disabled": "{{_computed.isReadOnly}}"
              }
            },
            {
              "type": "basic",
              "name": "Span",
              "if": "{{_local.errors?.['report_policy.auto_hide_threshold']}}",
              "props": {
                "className": "text-xs text-red-600 dark:text-red-400 block"
              },
              "text": "{{(Array.isArray(_local.errors?.['report_policy.auto_hide_threshold']) ? _local.errors['report_policy.auto_hide_threshold'][0] : _local.errors?.['report_policy.auto_hide_threshold']) ?? ''}}"
            },
            {
              "type": "basic",
              "name": "Span",
              "props": {
                "className": "text-xs text-gray-500 dark:text-gray-400 block"
              },
              "text": "$t:sirsoft-board.admin.settings.fields.auto_hide_threshold_hint"
            }
          ]
        },
        {
          "id": "field_auto_hide_target",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "space-y-2 mb-6"
          },
          "children": [
            {
              "type": "basic",
              "name": "Label",
              "props": {
                "className": "block text-sm font-medium text-gray-700 dark:text-gray-300"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Span",
                  "text": "$t:sirsoft-board.admin.settings.fields.auto_hide_target"
                }
              ]
            },
            {
              "type": "composite",
              "name": "Select",
              "props": {
                "name": "report_policy.auto_hide_target",
                "options": [
                  {
                    "value": "post",
                    "label": "$t:sirsoft-board.admin.settings.options.auto_hide_target.post"
                  },
                  {
                    "value": "comment",
                    "label": "$t:sirsoft-board.admin.settings.options.auto_hide_target.comment"
                  },
                  {
                    "value": "both",
                    "label": "$t:sirsoft-board.admin.settings.options.auto_hide_target.both"
                  }
                ],
                "className": "w-full text-sm",
                "disabled": "{{_computed.isReadOnly}}"
              }
            },
            {
              "type": "basic",
              "name": "Span",
              "props": {
                "className": "text-xs text-gray-500 dark:text-gray-400 block"
              },
              "text": "$t:sirsoft-board.admin.settings.fields.auto_hide_target_hint"
            }
          ]
        }
      ]
    },
    {
