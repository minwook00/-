          "id": "field_report_view_roles",
          "type": "basic",
          "name": "Div",
          "props": { "className": "space-y-2 mb-6" },
          "children": [
            {
              "type": "basic",
              "name": "Span",
              "props": { "className": "block text-sm font-semibold text-gray-800 dark:text-gray-200" },
              "text": "$t:sirsoft-board.admin.settings.fields.report_view_roles"
            },
            {
              "type": "basic",
              "name": "Span",
              "props": { "className": "block text-xs text-gray-500 dark:text-gray-400 mb-1.5" },
              "text": "$t:sirsoft-board.admin.settings.fields.report_view_roles_description"
            },
            {
              "type": "composite",
              "name": "TagInput",
              "props": {
                "name": "report_permissions.view_roles",
                "options": "{{_computed.roleOptions ?? []}}",
                "className": "w-full",
                "disabled": "{{_computed.isReadOnly}}"
              }
            }
          ]
        },
