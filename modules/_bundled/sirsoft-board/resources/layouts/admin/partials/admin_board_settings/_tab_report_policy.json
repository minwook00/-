          "text": "$t:sirsoft-board.admin.settings.sections.report_notification_description"
        },
        {
          "comment": "--- 신고 접수 관리자 알림 ---",
          "id": "field_notify_admin_on_report",
          "type": "basic",
          "name": "Div",
          "props": { "className": "border border-gray-200 dark:border-gray-700 rounded-lg mb-4" },
          "children": [
            {
              "comment": "토글 헤더 행",
              "type": "basic",
              "name": "Div",
              "props": { "className": "flex items-start gap-4 px-4 py-3 bg-gray-50 dark:bg-gray-700/50" },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "props": { "className": "flex-1 min-w-0" },
                  "children": [
                    { "type": "basic", "name": "Span", "props": { "className": "block text-sm font-medium text-gray-900 dark:text-white" }, "text": "$t:sirsoft-board.admin.settings.fields.notify_admin_on_report" },
                    { "type": "basic", "name": "Span", "props": { "className": "block text-xs text-gray-500 dark:text-gray-400 mt-0.5" }, "text": "$t:sirsoft-board.admin.settings.fields.notify_admin_on_report_description" }
                  ]
                },
                { "type": "composite", "name": "Toggle", "props": { "name": "report_policy.notify_admin_on_report", "className": "flex-shrink-0 mt-0.5" } }
              ]
            },
            {
              "comment": "하위 옵션 (토글 ON 시에만 표시)",
              "type": "basic",
              "name": "Div",
              "if": "{{_local.form?.report_policy?.notify_admin_on_report === true}}",
              "props": { "className": "px-4 py-4 space-y-4 border-t border-gray-200 dark:border-gray-700" },
              "children": [
                {
                  "id": "field_notify_admin_on_report_scope",
                  "type": "basic",
                  "name": "Div",
                  "props": { "className": "space-y-1.5" },
                  "children": [
                    { "type": "basic", "name": "Label", "props": { "className": "text-xs text-gray-500 dark:text-gray-400" }, "text": "$t:sirsoft-board.admin.settings.fields.notify_admin_on_report_scope" },
                    {
                      "type": "composite",
                      "name": "RadioGroup",
                      "props": {
                        "name": "report_policy.notify_admin_on_report_scope",
                        "options": [
                          { "value": "per_case", "label": "$t:sirsoft-board.admin.settings.fields.notify_admin_on_report_scope_per_case" },
                          { "value": "per_report", "label": "$t:sirsoft-board.admin.settings.fields.notify_admin_on_report_scope_per_report" }
                        ],
                        "inline": true,
                        "size": "md",
                        "disabled": "{{_computed.isReadOnly}}"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "comment": "--- 신고 처리 결과 작성자 알림 ---",
          "id": "field_notify_author_on_report_action",
          "type": "basic",
          "name": "Div",
          "props": { "className": "border border-gray-200 dark:border-gray-700 rounded-lg" },
          "children": [
            {
              "comment": "토글 헤더 행",
              "type": "basic",
              "name": "Div",
              "props": { "className": "flex items-start gap-4 px-4 py-3 bg-gray-50 dark:bg-gray-700/50" },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "props": { "className": "flex-1 min-w-0" },
                  "children": [
                    { "type": "basic", "name": "Span", "props": { "className": "block text-sm font-medium text-gray-900 dark:text-white" }, "text": "$t:sirsoft-board.admin.settings.fields.notify_author_on_report_action" },
                    { "type": "basic", "name": "Span", "props": { "className": "block text-xs text-gray-500 dark:text-gray-400 mt-0.5" }, "text": "$t:sirsoft-board.admin.settings.fields.notify_author_on_report_action_description" }
                  ]
                },
                { "type": "composite", "name": "Toggle", "props": { "name": "report_policy.notify_author_on_report_action", "className": "flex-shrink-0 mt-0.5" } }
              ]
            }
          ]
        }
      ]
    }
  ]
}
