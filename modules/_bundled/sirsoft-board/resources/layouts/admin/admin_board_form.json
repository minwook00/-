{
    "version": "1.0.0",
    "layout_name": "admin_board_form",
    "permissions": [
        "sirsoft-board.boards.read"
    ],
    "extends": "_admin_base",
    "meta": {
        "title": "{{route?.id ? '$t:sirsoft-board.admin.form.title_edit' : '$t:sirsoft-board.admin.form.title_create'}}",
        "description": "$t:sirsoft-board.admin.form.description"
    },
    "computed": {
        "isReadOnly": "{{!!route?.id && !!boards?.data && boards?.data?.abilities?.can_update !== true}}"
    },
    "state": {
        "activeTab": "basic",
        "showCategoryRemoveModal": false,
        "categoryToRemove": null,
        "isSaving": false,
        "hasChanges": false,
        "showCancelConfirmModal": false,
        "form": [],
        "isDataLoaded": false,
        "managerSearchResults": [],
        "stepSearchResults": []
    },
    "transition_overlay": {
        "wait_for": [
            "roles",
            "notification_channels"
        ]
    },
    "data_sources": [
        {
            "id": "boards",
            "type": "api",
            "endpoint": "/api/modules/sirsoft-board/admin/boards/form-data",
            "method": "GET",
            "auto_fetch": true,
            "auth_required": true,
            "cache": false,
            "loading_strategy": "blocking",
            "params": {
                "board_id": "{{route?.id}}",
                "copy_id": "{{query?.copy_id}}"
            },
            "initLocal": "form",
            "refetchOnMount": true,
            "errorHandling": {
                "403": {
                    "handler": "showErrorPage",
                    "params": {
                        "target": "content"
                    }
                },
                "404": {
                    "handler": "showErrorPage",
                    "params": {
                        "target": "content"
                    }
                }
            }
        },
        {
            "id": "roles",
            "type": "api",
            "endpoint": "/api/admin/roles/active",
            "method": "GET",
            "auto_fetch": true,
            "auth_required": true
        },
        {
            "id": "availableChannels",
            "type": "api",
            "endpoint": "/api/admin/notification-channels",
            "method": "GET",
            "auto_fetch": true,
            "auth_required": true,
            "fallback": {
                "data": { "channels": [] }
            }
        }
    ],
    "slots": {
        "content": [
            {
                "id": "board_form_wrapper",
                "type": "basic",
                "name": "Div",
                "blur_until_loaded": true,
                "dataKey": "form",
                "trackChanges": true,
                "children": [
                    {
                        "id": "read_only_banner",
                        "type": "basic",
                        "name": "Div",
                        "if": "{{_computed.isReadOnly}}",
                        "props": {
                            "className": "mx-6 mt-4 flex items-center gap-3 rounded-lg border border-amber-200 dark:border-amber-800 bg-amber-50 dark:bg-amber-900/20 px-4 py-3"
                        },
                        "children": [
                            {
                                "type": "basic",
                                "name": "Icon",
                                "props": {
                                    "name": "lock",
                                    "className": "w-5 h-5 text-amber-600 dark:text-amber-400 flex-shrink-0"
                                }
                            },
                            {
                                "type": "basic",
                                "name": "Span",
                                "props": {
                                    "className": "text-sm text-amber-800 dark:text-amber-200"
                                },
                                "text": "$t:sirsoft-board.admin.form.read_only_message"
                            }
                        ]
                    },
                    {
                        "id": "sticky_header_container",
                        "type": "basic",
                        "name": "Div",
                        "props": {
                            "className": "sticky top-0 z-40 bg-gray-50 dark:bg-gray-900"
                        },
                        "children": [
                            {
                                "id": "form_header",
                                "type": "basic",
                                "name": "Div",
                                "props": {
                                    "className": "border-b border-gray-200 dark:border-gray-700 py-3 px-6"
                                },
                                "children": [
                                    {
                                        "id": "header_flex_container",
                                        "type": "basic",
                                        "name": "Div",
                                        "props": {
                                            "className": "flex justify-between items-center"
                                        },
                                        "children": [
                                            {
                                                "id": "header_title",
                                                "type": "basic",
                                                "name": "H1",
                                                "props": {
                                                    "className": "text-xl font-semibold text-gray-900 dark:text-white"
                                                },
                                                "text": "{{route?.id ? '$t:sirsoft-board.admin.form.title_edit' : '$t:sirsoft-board.admin.form.title_create'}}"
                                            },
                                            {
                                                "id": "header_actions",
                                                "type": "basic",
                                                "name": "Div",
                                                "props": {
                                                    "className": "flex items-center gap-3"
                                                },
                                                "children": [
                                                    {
                                                        "id": "cancel_button",
                                                        "type": "basic",
                                                        "name": "Button",
                                                        "props": {
                                                            "type": "button",
                                                            "className": "flex items-center gap-2 px-4 py-2 border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-200 bg-white dark:bg-gray-800 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 font-medium transition-colors"
                                                        },
                                                        "actions": [
                                                            {
                                                                "type": "click",
                                                                "handler": "navigate",
                                                                "target": "/admin/boards"
                                                            }
                                                        ],
                                                        "children": [
                                                            {
                                                                "type": "basic",
                                                                "name": "Span",
                                                                "text": "$t:sirsoft-board.common.cancel"
                                                            }
                                                        ]
                                                    },
                                                    {
                                                        "id": "save_button",
                                                        "type": "basic",
                                                        "name": "Button",
                                                        "props": {
                                                            "disabled": "{{_computed.isReadOnly || _local.isSaving || (!!route?.id && !_local.hasChanges)}}",
                                                            "className": "flex items-center gap-2 px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 dark:bg-blue-500 dark:hover:bg-blue-600 font-medium transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
                                                        },
                                                        "actions": [
                                                            {
                                                                "type": "click",
                                                                "handler": "setState",
                                                                "params": {
                                                                    "target": "local",
                                                                    "isSaving": true
                                                                }
                                                            },
                                                            {
                                                                "type": "click",
                                                                "handler": "apiCall",
                                                                "auth_required": true,
                                                                "target": "{{route?.id ? '/api/modules/sirsoft-board/admin/boards/' + route.id : '/api/modules/sirsoft-board/admin/boards'}}",
                                                                "params": {
                                                                    "method": "{{route?.id ? 'PUT' : 'POST'}}",
                                                                    "body": "{{_local.form}}"
                                                                },
                                                                "onSuccess": [
                                                                    {
                                                                        "handler": "setState",
                                                                        "params": {
                                                                            "target": "local",
                                                                            "isSaving": false,
                                                                            "hasChanges": false,
                                                                            "errors": null
                                                                        }
                                                                    },
                                                                    {
                                                                        "handler": "toast",
                                                                        "params": {
                                                                            "type": "success",
                                                                            "message": "{{route?.id ? '$t:sirsoft-board.admin.board.messages.update_success' : '$t:sirsoft-board.admin.board.messages.create_success'}}"
                                                                        }
                                                                    },
                                                                    {
                                                                        "handler": "navigate",
                                                                        "condition": "{{!route?.id}}",
                                                                        "params": {
                                                                            "path": "{{'/admin/boards/' + result.data.id + '/edit'}}"
                                                                        }
                                                                    }
                                                                ],
                                                                "onError": [
                                                                    {
                                                                        "handler": "setState",
                                                                        "params": {
                                                                            "target": "local",
                                                                            "isSaving": false,
                                                                            "errors": "{{error.errors}}"
                                                                        }
                                                                    },
                                                                    {
                                                                        "handler": "toast",
                                                                        "params": {
                                                                            "type": "error",
                                                                            "message": "{{error.message}}",
                                                                            "icon": "triangle-exclamation"
                                                                        }
                                                                    }
                                                                ]
                                                            }
                                                        ],
                                                        "children": [
                                                            {
                                                                "type": "basic",
                                                                "name": "Icon",
                                                                "if": "{{!_local.isSaving}}",
                                                                "props": {
                                                                    "name": "floppy-disk",
                                                                    "className": "w-4 h-4"
                                                                }
                                                            },
                                                            {
                                                                "type": "basic",
                                                                "name": "Icon",
                                                                "if": "{{_local.isSaving}}",
                                                                "props": {
                                                                    "name": "spinner",
                                                                    "className": "w-4 h-4 animate-spin"
                                                                }
                                                            },
                                                            {
                                                                "type": "basic",
                                                                "name": "Span",
                                                                "text": "{{_local.isSaving ? '$t:sirsoft-board.common.saving' : '$t:sirsoft-board.common.save'}}"
                                                            }
                                                        ]
                                                    }
                                                ]
                                            }
                                        ]
                                    }
                                ]
                            },
                            {
                                "id": "tab_navigation",
                                "type": "composite",
                                "name": "TabNavigationScroll",
                                "props": {
                                    "activeTabId": "{{_local.activeTab ?? 'basic'}}",
                                    "enableScrollSpy": true,
                                    "scrollSpyOffset": 120,
                                    "tabs": [
                                        {
                                            "id": "basic",
                                            "label": "$t:sirsoft-board.admin.form.tabs.basic"
                                        },
                                        {
                                            "id": "permissions",
                                            "label": "$t:sirsoft-board.admin.form.tabs.permissions"
                                        },
                                        {
                                            "id": "list",
                                            "label": "$t:sirsoft-board.admin.form.tabs.list"
                                        },
                                        {
                                            "id": "post",
                                            "label": "$t:sirsoft-board.admin.form.tabs.post"
                                        },
                                        {
                                            "id": "notification",
                                            "label": "$t:sirsoft-board.admin.form.tabs.notification"
                                        }
                                    ]
                                }
                            }
                        ]
                    },
                    {
                        "id": "validation_error",
                        "type": "basic",
                        "name": "Div",
                        "if": "{{_local.errors}}",
                        "props": {
                            "className": "px-6 pt-4"
                        },
                        "children": [
                            {
                                "type": "basic",
                                "name": "Div",
                                "props": {
                                    "className": "bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg p-4 flex gap-3"
                                },
                                "children": [
                                    {
                                        "type": "basic",
                                        "name": "Icon",
                                        "props": {
                                            "name": "triangle-exclamation",
                                            "className": "w-5 h-5 text-red-600 dark:text-red-400 flex-shrink-0 mt-0.5"
                                        }
                                    },
                                    {
                                        "type": "basic",
                                        "name": "Div",
                                        "children": [
                                            {
                                                "type": "basic",
                                                "name": "H3",
                                                "props": {
                                                    "className": "text-sm font-medium text-red-800 dark:text-red-200"
                                                },
                                                "text": "$t:sirsoft-board.admin.form.validation_error"
                                            },
                                            {
                                                "type": "basic",
                                                "name": "P",
                                                "if": "{{typeof _local.errors === 'string'}}",
                                                "props": {
                                                    "className": "mt-2 text-sm text-red-700 dark:text-red-300"
                                                },
                                                "text": "{{_local.errors}}"
                                            },
                                            {
                                                "type": "basic",
                                                "name": "Ul",
                                                "if": "{{typeof _local.errors === 'object' && Object.keys(_local.errors).length > 0}}",
                                                "props": {
                                                    "className": "mt-2 list-disc list-inside space-y-1"
                                                },
                                                "iteration": {
                                                    "source": "Object.entries(_local.errors ?? {}).flatMap(([field, messages]) => Array.isArray(messages) ? messages : [messages])",
                                                    "item_var": "message"
                                                },
                                                "children": [
                                                    {
                                                        "type": "basic",
                                                        "name": "Li",
                                                        "props": {
                                                            "className": "text-sm text-red-700 dark:text-red-300"
                                                        },
                                                        "text": "{{message}}"
                                                    }
                                                ]
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    },
                    {
                        "id": "board_form",
                        "type": "basic",
                        "name": "Form",
                        "props": {
                            "id": "board_form",
                            "className": "p-6"
                        },
                        "children": [
                            {
                                "partial": "partials/admin_board_form/_tab_basic.json"
                            },
                            {
                                "partial": "partials/admin_board_form/_tab_permissions.json"
                            },
                            {
                                "partial": "partials/admin_board_form/_tab_list.json"
                            },
                            {
                                "partial": "partials/admin_board_form/_tab_post.json"
                            },
                            {
                                "partial": "partials/admin_board_form/_tab_notification.json"
                            }
                        ]
                    }
                ]
            }
        ]
    },
    "modals": [
        {
            "id": "category_remove_modal",
            "type": "composite",
            "name": "Modal",
            "condition": "{{_local.showCategoryRemoveModal === true}}",
            "props": {
                "isOpen": "{{_local.showCategoryRemoveModal}}",
                "title": "$t:sirsoft-board.admin.form.modals.category_remove.title",
                "size": "sm"
            },
            "actions": [
                {
                    "type": "close",
                    "handler": "setState",
                    "target": "_local.showCategoryRemoveModal",
                    "value": false
                }
            ],
            "children": [
                {
                    "id": "category_remove_modal_content",
                    "type": "basic",
                    "name": "Div",
                    "props": {
                        "className": "space-y-4"
                    },
                    "children": [
                        {
                            "id": "category_remove_modal_message",
                            "type": "basic",
                            "name": "P",
                            "props": {
                                "className": "text-sm text-gray-600 dark:text-gray-300"
                            },
                            "text": "$t:sirsoft-board.admin.form.modals.category_remove.message"
                        },
                        {
                            "id": "category_remove_modal_warning",
                            "type": "basic",
                            "name": "P",
                            "props": {
                                "className": "text-sm text-gray-500 dark:text-gray-400"
                            },
                            "text": "$t:sirsoft-board.admin.form.modals.category_remove.warning"
                        },
                        {
                            "id": "category_remove_modal_actions",
                            "type": "basic",
                            "name": "Div",
                            "props": {
                                "className": "flex mt-6 justify-end"
                            },
                            "children": [
                                {
                                    "id": "category_remove_modal_confirm",
                                    "type": "basic",
                                    "name": "Button",
                                    "props": {
                                        "className": "flex items-center gap-2 px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 dark:bg-blue-500 dark:hover:bg-blue-600 font-medium transition-colors"
                                    },
                                    "text": "$t:common.confirm",
                                    "actions": [
                                        {
                                            "type": "click",
                                            "handler": "setState",
                                            "target": "_local.showCategoryRemoveModal",
                                            "value": false
                                        }
                                    ]
                                }
                            ]
                        }
                    ]
                }
            ]
        }
    ]
}
