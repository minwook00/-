{
  "data_sources": [
    {
      "id": "board_list_for_inquiry",
      "type": "api",
      "endpoint": "/api/modules/sirsoft-board/admin/boards",
      "method": "GET",
      "auto_fetch": true,
      "auth_required": true,
      "params": {
        "per_page": "200"
      },
      "fallback": null
    }
  ],
  "extension_point": "inquiry_board_setting",
  "mode": "replace",
  "components": [
    {
      "id": "inquiry_board_setting_active",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "space-y-4"
      },
      "children": [
        {
          "id": "inquiry_board_setting_description",
          "type": "basic",
          "name": "P",
          "props": {
            "className": "text-sm text-gray-700 dark:text-gray-300"
          },
          "text": "$t:sirsoft-board.admin.ecommerce_settings.inquiry.description"
        },
        {
          "id": "inquiry_board_field",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "flex flex-col gap-1.5"
          },
          "children": [
            {
              "id": "inquiry_board_label",
              "type": "basic",
              "name": "Label",
              "props": {
                "className": "form-label"
              },
              "text": "$t:sirsoft-board.admin.ecommerce_settings.inquiry.board_label"
            },
            {
              "id": "inquiry_board_select",
              "type": "basic",
              "name": "Select",
              "props": {
                "name": "inquiry.board_slug",
                "value": "{{_local.form?.inquiry?.board_slug ?? ''}}",
                "options": "{{[{value: '', label: $t('sirsoft-board.admin.ecommerce_settings.inquiry.board_placeholder')}].concat((board_list_for_inquiry?.data?.data ?? []).map(b => ({value: b.slug, label: b.name})))}}",
                "className": "{{_local.errors?.['inquiry.board_slug'] ? 'input input-error' : 'input'}}",
                "disabled": "{{_computed.isReadOnly}}"
              }
            },
            {
              "id": "inquiry_board_select_error",
              "type": "basic",
              "name": "Span",
              "if": "{{_local.errors?.['inquiry.board_slug']}}",
              "props": {
                "className": "text-red-500 text-xs mt-1 block"
              },
              "text": "{{_local.errors?.['inquiry.board_slug']?.[0] ?? ''}}"
            }
          ]
        },
        {
          "id": "inquiry_board_hints",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "space-y-3"
          },
          "children": [
            {
              "id": "inquiry_board_hint_secret",
              "type": "basic",
              "name": "P",
              "props": {
                "className": "text-xs text-gray-500 dark:text-gray-400"
              },
              "text": "$t:sirsoft-board.admin.ecommerce_settings.inquiry.hint_secret"
            },
            {
              "id": "inquiry_board_hint_category",
              "type": "basic",
              "name": "P",
              "props": {
                "className": "text-xs text-gray-500 dark:text-gray-400"
              },
              "text": "$t:sirsoft-board.admin.ecommerce_settings.inquiry.hint_category"
            },
            {
              "id": "inquiry_board_actions",
              "type": "basic",
              "name": "Div",
              "if": "{{!!(board_list_for_inquiry?.data?.data ?? []).find(b => b.slug === (settings?.data?.inquiry?.board_slug ?? ''))?.id}}",
              "props": {
                "className": "flex flex-col md:flex-row gap-3"
              },
              "children": [
                {
                  "id": "inquiry_board_go_edit_card",
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex flex-col justify-between gap-3 flex-1 p-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "P",
                      "props": {
                        "className": "flex items-start gap-1.5 text-xs text-gray-500 dark:text-gray-400"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Icon",
                          "props": { "name": "gear", "className": "w-3 h-3 shrink-0 mt-0.5" }
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "text": "$t:sirsoft-board.admin.ecommerce_settings.inquiry.go_to_board_edit_desc"
                        }
                      ]
                    },
                    {
                      "id": "inquiry_board_go_edit",
                      "type": "basic",
                      "name": "Button",
                      "props": {
                        "type": "button",
                        "className": "self-start inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-900 border border-gray-300 dark:border-gray-600 rounded hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Icon",
                          "props": { "name": "pen-to-square", "className": "w-3 h-3" }
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "text": "$t:sirsoft-board.admin.ecommerce_settings.inquiry.go_to_board_edit"
                        }
                      ],
                      "actions": [
                        {
                          "type": "click",
                          "handler": "navigate",
                          "params": {
                            "path": "/admin/boards/{{(board_list_for_inquiry?.data?.data ?? []).find(b => b.slug === (settings?.data?.inquiry?.board_slug ?? ''))?.id}}/edit"
                          }
                        }
                      ]
                    }
                  ]
                },
                {
                  "id": "inquiry_board_go_posts_card",
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex flex-col justify-between gap-3 flex-1 p-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "P",
                      "props": {
                        "className": "flex items-start gap-1.5 text-xs text-gray-500 dark:text-gray-400"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Icon",
                          "props": { "name": "clipboard-list", "className": "w-3 h-3 shrink-0 mt-0.5" }
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "text": "$t:sirsoft-board.admin.ecommerce_settings.inquiry.go_to_posts_desc"
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "flex gap-2"
                      },
                      "children": [
                        {
                          "id": "inquiry_board_go_posts",
                          "type": "basic",
                          "name": "Button",
                          "props": {
                            "type": "button",
                            "className": "inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-900 border border-gray-300 dark:border-gray-600 rounded hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors"
                          },
                          "children": [
                            {
                              "type": "basic",
                              "name": "Icon",
                              "props": { "name": "list", "className": "w-3 h-3" }
                            },
                            {
                              "type": "basic",
                              "name": "Span",
                              "text": "$t:sirsoft-board.admin.ecommerce_settings.inquiry.go_to_posts"
                            }
                          ],
                          "actions": [
                            {
                              "type": "click",
                              "handler": "navigate",
                              "params": {
                                "path": "/admin/board/{{settings?.data?.inquiry?.board_slug}}"
                              }
                            }
                          ]
                        },
                        {
                          "id": "inquiry_board_add_menu",
                          "type": "basic",
                          "name": "Button",
                          "props": {
                            "type": "button",
                            "className": "inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium text-blue-600 dark:text-blue-400 bg-white dark:bg-gray-900 border border-blue-500 dark:border-blue-400 rounded hover:bg-blue-50 dark:hover:bg-blue-900/20 transition-colors"
                          },
                          "children": [
                            {
                              "type": "basic",
                              "name": "Icon",
                              "props": { "name": "plus", "className": "w-3 h-3" }
                            },
                            {
                              "type": "basic",
                              "name": "Span",
                              "text": "$t:sirsoft-board.admin.ecommerce_settings.inquiry.add_to_admin_menu"
                            }
                          ],
                          "actions": [
                            {
                              "type": "click",
                              "handler": "apiCall",
                              "target": "/api/modules/sirsoft-board/admin/boards/{{(board_list_for_inquiry?.data?.data ?? []).find(b => b.slug === (settings?.data?.inquiry?.board_slug ?? ''))?.id}}/add-to-menu",
                              "params": { "method": "POST" },
                              "auth_required": true,
                              "onSuccess": [
                                {
                                  "handler": "toast",
                                  "params": { "type": "success", "message": "{{result.message}}" }
                                },
                                {
                                  "handler": "refetchDataSource",
                                  "params": { "dataSourceId": "admin_menu", "sync": true }
                                }
                              ],
                              "onError": [
                                {
                                  "handler": "toast",
                                  "params": { "type": "error", "message": "{{error.message}}" }
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "priority": 100
}
