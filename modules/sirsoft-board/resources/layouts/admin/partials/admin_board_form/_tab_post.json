                  "id": "post_comment_order_section",
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": ""
                  },
                  "children": [
                    {
                      "id": "comment_order_field",
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": ""
                      },
                      "children": [
                        {
                          "id": "comment_order_label",
                          "type": "basic",
                          "name": "Label",
                          "props": {
                            "className": "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2"
                          },
                          "children": [
                            {
                              "type": "basic",
                              "name": "Span",
                              "text": "$t:sirsoft-board.admin.form.fields.comment_order.label"
                            }
                          ]
                        },
                        {
                          "id": "comment_order_select",
                          "type": "composite",
                          "name": "Select",
                          "props": {
                            "name": "comment_order",
                            "disabled": "{{_computed.isReadOnly}}",
                            "className": "w-full",
                            "options": [
                              {
                                "value": "ASC",
                                "label": "$t:sirsoft-board.admin.form.fields.comment_order.options.asc"
                              },
                              {
                                "value": "DESC",
                                "label": "$t:sirsoft-board.admin.form.fields.comment_order.options.desc"
                              }
                            ]
                          }
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "id": "post_file_upload_section",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "space-y-4 py-4 mt-4 border-t border-gray-200 dark:border-gray-700"
          },
          "children": [
            {
              "id": "use_file_upload_toggle",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex justify-between items-start"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex-1"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Label",
                      "props": {
                        "className": "text-sm font-medium text-gray-900 dark:text-white"
                      },
                      "text": "$t:sirsoft-board.admin.form.fields.use_file_upload.label"
                    },
                    {
                      "type": "basic",
                      "name": "P",
                      "props": {
                        "className": "text-xs text-gray-500 dark:text-gray-400 mt-1"
                      },
                      "text": "$t:sirsoft-board.admin.form.fields.use_file_upload.description"
                    }
                  ]
                },
                {
                  "type": "composite",
                  "name": "Toggle",
                  "props": {
                    "name": "use_file_upload",
                    "disabled": "{{_computed.isReadOnly}}",
                    "className": "flex-shrink-0 ml-4"
                  }
                }
              ]
            },
            {
              "id": "file_sub_fields",
              "type": "basic",
              "name": "Div",
              "if": "{{_local.form.use_file_upload}}",
              "props": {
                "className": "space-y-4"
              },
              "children": [
                {
                  "id": "file_settings_group",
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "grid mt-4 grid-cols-2 gap-4"
                  },
                  "children": [
                    {
                      "id": "max_file_count_field",
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": ""
                      },
                      "children": [
                        {
                          "id": "max_file_count_label",
                          "type": "basic",
                          "name": "Label",
                          "props": {
                            "className": "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2"
                          },
                          "children": [
                            {
                              "type": "basic",
                              "name": "Span",
                              "text": "$t:sirsoft-board.admin.form.fields.max_file_count.label"
                            }
                          ]
                        },
                        {
                          "id": "max_file_count_input",
                          "type": "basic",
                          "name": "Input",
                          "props": {
                            "type": "number",
                            "name": "max_file_count",
                            "disabled": "{{_computed.isReadOnly}}",
                            "className": "w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white"
                          }
                        },
                        {
                          "id": "max_file_count_hint",
                          "type": "basic",
                          "name": "P",
                          "props": {
                            "className": "mt-1 text-xs text-gray-500 dark:text-gray-400"
                          },
                          "text": "$t:sirsoft-board.admin.form.fields.max_file_count.hint|min={{board_config?.data?.limits?.max_file_count_min ?? 1}}|max={{board_config?.data?.limits?.max_file_count_max ?? 20}}"
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "if": "{{_local.errors?.max_file_count}}",
                          "props": {
                            "className": "text-red-500 dark:text-red-400 text-xs mt-1"
                          },
                          "text": "{{_local.errors?.max_file_count?.[0] ?? ''}}"
                        }
                      ]
                    },
                    {
                      "id": "max_file_size_field",
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": ""
                      },
                      "children": [
                        {
                          "id": "max_file_size_label",
                          "type": "basic",
                          "name": "Label",
                          "props": {
                            "className": "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2"
                          },
                          "children": [
                            {
                              "type": "basic",
                              "name": "Span",
                              "text": "$t:sirsoft-board.admin.form.fields.max_file_size.label"
                            }
                          ]
                        },
                        {
                          "id": "max_file_size_input",
                          "type": "basic",
                          "name": "Input",
                          "props": {
                            "type": "number",
                            "name": "max_file_size",
                            "placeholder": "$t:sirsoft-board.admin.form.fields.max_file_size.placeholder",
                            "disabled": "{{_computed.isReadOnly}}",
                            "className": "w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white"
                          }
                        },
                        {
                          "id": "max_file_size_hint",
                          "type": "basic",
                          "name": "P",
                          "props": {
                            "className": "mt-1 text-xs text-gray-500 dark:text-gray-400"
                          },
                          "text": "$t:sirsoft-board.admin.form.fields.max_file_size.hint|maxMB={{board_config?.data?.limits?.max_file_size_max ?? 200}}"
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "if": "{{_local.errors?.max_file_size}}",
                          "props": {
                            "className": "text-red-500 dark:text-red-400 text-xs mt-1"
                          },
                          "text": "{{_local.errors?.max_file_size?.[0] ?? ''}}"
                        }
                      ]
                    }
                  ]
                },
                {
                  "id": "allowed_extensions_field",
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": ""
                  },
                  "children": [
                    {
                      "id": "allowed_extensions_label",
                      "type": "basic",
                      "name": "Label",
                      "props": {
                        "className": "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Span",
                          "text": "$t:sirsoft-board.admin.form.fields.allowed_extensions.label"
                        }
                      ]
                    },
                    {
                      "id": "allowed_extensions_input",
                      "type": "basic",
                      "name": "Input",
                      "props": {
                        "type": "text",
                        "name": "allowed_extensions",
                        "placeholder": "$t:sirsoft-board.admin.form.fields.allowed_extensions.placeholder",
                        "disabled": "{{_computed.isReadOnly}}",
                        "className": "w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white"
                      }
                    },
                    {
                      "id": "allowed_extensions_description",
                      "type": "basic",
                      "name": "P",
                      "props": {
                        "className": "mt-2 text-sm text-gray-500 dark:text-gray-400",
                        "children": "$t:sirsoft-board.admin.form.fields.allowed_extensions.description"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
