{
  "meta": {
    "is_partial": true,
    "description": "Post Form - Parent Post Information (답글 작성 시에만 표시)"
  },
  "id": "parent_post_card",
  "type": "basic",
  "name": "Div",
  "if": "{{(form_data?.data?.parent_id || query?.parent_id) && form_meta?.data?.parent_post?.id}}",
  "props": {
    "className": "bg-white dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg p-4 mb-6"
  },
  "children": [
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "flex items-center gap-2 mb-3"
      },
      "children": [
        {
          "type": "basic",
          "name": "Icon",
          "props": {
            "name": "reply",
            "className": "w-4 h-4 text-blue-600 dark:text-blue-400"
          }
        },
        {
          "type": "basic",
          "name": "Span",
          "props": {
            "className": "text-sm font-semibold text-gray-900 dark:text-white"
          },
          "text": "$t:sirsoft-board.admin.posts.form.reply_to"
        },
        {
          "type": "basic",
          "name": "Span",
          "if": "{{form_meta?.data?.parent_post?.is_notice}}",
          "props": {
            "className": "inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-red-100 text-red-700 dark:bg-red-900 dark:text-red-300"
          },
          "text": "$t:sirsoft-board.admin.posts.notice"
        },
        {
          "type": "basic",
          "name": "Span",
          "if": "{{form_meta?.data?.parent_post?.is_secret}}",
          "props": {
            "className": "inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-yellow-100 text-yellow-700 dark:bg-yellow-900 dark:text-yellow-300"
          },
          "text": "$t:sirsoft-board.admin.posts.secret"
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "flex items-center gap-2 mb-2"
      },
      "children": [
        {
          "type": "basic",
          "name": "H4",
          "props": {
            "className": "text-base font-semibold text-gray-900 dark:text-white"
          },
          "text": "{{form_meta?.data?.parent_post?.title}}"
        },
        {
          "type": "basic",
          "name": "A",
          "props": {
            "href": "/admin/board/{{route.slug}}/{{form_meta?.data?.parent_post?.id}}",
            "title": "$t:sirsoft-board.admin.posts.form.view_original",
            "className": "text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 transition-colors"
          },
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "props": {
                "name": "arrow-up-right-from-square",
                "className": "w-3.5 h-3.5"
              }
            }
          ]
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "flex items-center gap-2 text-xs text-gray-500 dark:text-gray-400 mb-3"
      },
      "children": [
        {
          "type": "basic",
          "name": "Span",
          "text": "{{form_meta?.data?.parent_post?.user?.name ?? '$t:sirsoft-board.admin.posts.unknown_author'}}"
        },
        {
          "type": "basic",
          "name": "Span",
          "text": "·"
        },
        {
          "type": "basic",
          "name": "Span",
          "text": "{{form_meta?.data?.parent_post?.created_at}}"
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "if": "{{form_meta?.data?.parent_post?.content}}",
      "props": {
        "className": "bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded p-3"
      },
      "children": [
        {
          "type": "extension_point",
          "name": "html_content",
          "props": {
            "content": "{{form_meta?.data?.parent_post?.content}}",
            "isHtml": "{{(form_meta?.data?.parent_post?.content_mode ?? 'text') === 'html'}}",
            "className": "{{_local.parentPostExpanded ? '' : 'line-clamp-3'}} text-sm text-gray-600 dark:text-gray-300 mb-2"
          },
          "default": [
            {
              "type": "composite",
              "name": "HtmlContent",
              "props": {
                "content": "{{form_meta?.data?.parent_post?.content}}",
                "isHtml": "{{(form_meta?.data?.parent_post?.content_mode ?? 'text') === 'html'}}",
                "className": "{{_local.parentPostExpanded ? '' : 'line-clamp-3'}} text-sm text-gray-600 dark:text-gray-300 mb-2"
              }
            }
          ]
        },
        {
          "type": "basic",
          "name": "Button",
          "if": "{{(form_meta?.data?.parent_post?.content?.length ?? 0) > 150}}",
          "props": {
            "type": "button",
            "className": "text-xs text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 font-medium transition-colors flex items-center gap-1"
          },
          "actions": [
            {
              "type": "click",
              "handler": "setState",
              "params": {
                "target": "local",
                "parentPostExpanded": "{{!_local.parentPostExpanded}}"
              }
            }
          ],
          "children": [
            {
              "type": "basic",
              "name": "Span",
              "text": "{{_local.parentPostExpanded ? '$t:sirsoft-board.admin.posts.form.hide_content' : '$t:sirsoft-board.admin.posts.form.show_full_content'}}"
            },
            {
              "type": "basic",
              "name": "Icon",
              "props": {
                "name": "{{_local.parentPostExpanded ? 'chevron-up' : 'chevron-down'}}",
                "className": "w-3 h-3"
              }
            }
          ]
        }
      ]
    }
  ]
}
