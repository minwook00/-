                    }
                  ],
                  "actions": [
                    {
                      "type": "click",
                      "handler": "sequence",
                      "actions": [
                        {
                          "handler": "setState",
                          "params": {
                            "target": "local",
                            "clearingCache": true
                          }
                        },
                        {
                          "handler": "apiCall",
                          "auth_required": true,
                          "target": "/api/admin/seo/clear-cache",
                          "params": {
                            "method": "POST",
                            "body": { "layout": "board/boards" }
                          },
                          "onSuccess": {
                            "handler": "apiCall",
                            "auth_required": true,
                            "target": "/api/admin/seo/clear-cache",
                            "params": {
                              "method": "POST",
                              "body": { "layout": "board/index" }
                            },
                            "onSuccess": {
                              "handler": "apiCall",
                              "auth_required": true,
                              "target": "/api/admin/seo/clear-cache",
                              "params": {
                                "method": "POST",
                                "body": { "layout": "board/show" }
                              },
                              "onSuccess": [
                                { "handler": "setState", "params": { "target": "local", "clearingCache": false } },
                                { "handler": "toast", "params": { "type": "success", "message": "$t:sirsoft-board.admin.settings.seo.seo_friendly.clear_cache_success" } }
                              ],
                              "onError": [
                                { "handler": "setState", "params": { "target": "local", "clearingCache": false } },
                                { "handler": "toast", "params": { "type": "error", "message": "$t:sirsoft-board.admin.settings.seo.seo_friendly.clear_cache_error" } }
                              ]
                            },
                            "onError": [
                              { "handler": "setState", "params": { "target": "local", "clearingCache": false } },
                              { "handler": "toast", "params": { "type": "error", "message": "$t:sirsoft-board.admin.settings.seo.seo_friendly.clear_cache_error" } }
                            ]
                          },
