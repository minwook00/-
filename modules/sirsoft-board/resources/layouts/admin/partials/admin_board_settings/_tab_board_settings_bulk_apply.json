{
  "meta": {
    "is_partial": true,
    "description": "게시판 설정 > 일괄 적용 섹션"
  },
  "id": "bulk_apply",
  "type": "basic",
  "name": "Div",
  "if": "{{(_global.activeBoardSettingsTab || query.tab || 'general') === 'basic_defaults'}}",
  "props": {
    "className": "mt-6 space-y-6"
  },
  "classMap": {
    "key": "{{_computed.isReadOnly ? 'readonly' : 'normal'}}",
    "variants": {
      "readonly": "opacity-60",
      "normal": ""
    }
  },
  "children": [
    {
      "comment": "========== 섹션 9: 기존 게시판에 일괄 적용 ==========",
      "id": "section_bulk_apply",
      "type": "layout",
      "name": "SectionLayout",
      "props": {
        "className": "bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-6 mb-6"
      },
      "children": [
        {
          "type": "basic",
          "name": "H3",
          "props": {
            "className": "text-lg font-semibold text-gray-900 dark:text-white pb-3 mb-4 border-b-2 border-gray-200 dark:border-gray-700"
          },
          "text": "$t:sirsoft-board.admin.settings.bulk_apply.title"
        },
        {
          "type": "basic",
          "name": "Div",
          "if": "{{(boards_list?.data?.data ?? []).length > 0}}",
          "props": {
            "className": "space-y-2 mb-6"
          },
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "p-4 bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-lg flex items-center gap-3"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Icon",
                  "props": {
                    "name": "triangle-exclamation",
                    "className": "text-amber-600 dark:text-amber-400 flex-shrink-0",
                    "size": "sm"
                  }
                },
                {
                  "type": "basic",
                  "name": "P",
                  "props": {
                    "className": "text-sm text-amber-800 dark:text-amber-200"
                  },
                  "text": "$t:sirsoft-board.admin.settings.bulk_apply.checked_fields_notice"
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "if": "{{!(_local.bulkApplyFields ?? []).length}}",
              "props": {
                "className": "flex items-center gap-2 px-1"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Icon",
                  "props": {
                    "name": "circle-exclamation",
                    "className": "text-amber-600 dark:text-amber-400 flex-shrink-0",
                    "size": "sm"
                  }
                },
                {
                  "type": "basic",
                  "name": "P",
                  "props": {
                    "className": "text-sm text-amber-700 dark:text-amber-300"
                  },
                  "text": "$t:sirsoft-board.admin.settings.bulk_apply.no_fields_selected"
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "if": "{{(_local.bulkApplyFields ?? []).length > 0 && _local.bulkApplyAll === false && !(_local._bulkApplyBoardIds ?? []).length}}",
              "props": {
                "className": "flex items-center gap-2 px-1"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Icon",
                  "props": {
                    "name": "circle-exclamation",
                    "className": "text-red-500 dark:text-red-400 flex-shrink-0",
                    "size": "sm"
                  }
                },
                {
                  "type": "basic",
                  "name": "P",
                  "props": {
                    "className": "text-sm text-red-600 dark:text-red-400"
                  },
                  "text": "$t:sirsoft-board.admin.settings.bulk_apply.no_boards_selected"
                }
              ]
            }
          ]
        },
        {
          "id": "no_boards_notice",
          "type": "basic",
          "name": "Div",
          "if": "{{!(boards_list?.data?.data ?? []).length}}",
          "props": {
            "className": "p-4 bg-gray-50 dark:bg-gray-700/50 border border-gray-200 dark:border-gray-600 rounded-lg flex items-center gap-3"
          },
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "props": {
                "name": "circle-info",
                "className": "text-gray-500 dark:text-gray-400 flex-shrink-0",
                "size": "sm"
              }
            },
            {
              "type": "basic",
              "name": "P",
              "props": {
                "className": "text-sm text-gray-600 dark:text-gray-300"
              },
              "text": "$t:sirsoft-board.admin.settings.bulk_apply.no_boards_notice"
            }
          ]
        },
        {
          "id": "bulk_apply_target",
          "type": "basic",
          "name": "Div",
          "if": "{{(boards_list?.data?.data ?? []).length > 0}}",
          "props": {
            "className": "space-y-2 mb-6"
          },
          "children": [
            {
              "type": "basic",
              "name": "Label",
              "props": {
                "className": "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Span",
                  "text": "$t:sirsoft-board.admin.settings.bulk_apply.target_boards"
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex items-center gap-4"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "flex items-center gap-2 text-sm text-gray-700 dark:text-gray-300 cursor-pointer"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Input",
                      "props": {
                        "type": "radio",
                        "name": "_bulkApplyAll",
                        "className": "radio",
                        "checked": "{{_local.bulkApplyAll !== false}}"
                      },
                      "actions": [
                        {
                          "type": "change",
                          "handler": "setState",
                          "params": {
                            "target": "local",
                            "bulkApplyAll": true
                          }
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "text": "$t:sirsoft-board.admin.settings.bulk_apply.apply_all"
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "flex items-center gap-2 text-sm text-gray-700 dark:text-gray-300 cursor-pointer"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Input",
                      "props": {
                        "type": "radio",
                        "name": "_bulkApplyAll",
                        "className": "radio",
                        "checked": "{{_local.bulkApplyAll === false}}"
                      },
                      "actions": [
                        {
                          "type": "change",
                          "handler": "setState",
                          "params": {
                            "target": "local",
                            "bulkApplyAll": false
                          }
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "text": "$t:sirsoft-board.admin.settings.bulk_apply.apply_selected"
                    }
                  ]
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "if": "{{_local.bulkApplyAll === false}}",
              "props": {
                "className": "mt-3"
              },
              "children": [
                {
                  "type": "composite",
                  "name": "TagInput",
                  "props": {
                    "value": "{{_local._bulkApplyBoardIds ?? []}}",
                    "options": "{{$computed.boardOptions ?? []}}",
                    "placeholder": "$t:sirsoft-board.admin.settings.bulk_apply.select_boards_placeholder",
                    "className": "w-full",
                    "disabled": "{{_computed.isReadOnly}}"
                  },
                  "actions": [
                    {
                      "type": "change",
                      "handler": "setState",
                      "params": {
                        "target": "local",
                        "_bulkApplyBoardIds": "{{$event.target.value}}"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "basic",
          "name": "Div",
          "if": "{{(boards_list?.data?.data ?? []).length > 0}}",
          "props": {
            "className": "flex justify-end"
          },
          "children": [
            {
              "type": "basic",
              "name": "Button",
              "props": {
                "type": "button",
                "disabled": "{{_computed.isReadOnly || !(_local.bulkApplyFields ?? []).length || (_local.bulkApplyAll === false && !(_local._bulkApplyBoardIds ?? []).length)}}",
                "className": "flex items-center gap-2 px-4 py-2 bg-amber-600 text-white rounded-lg hover:bg-amber-700 dark:bg-amber-500 dark:hover:bg-amber-600 font-medium transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
              },
              "actions": [
                {
                  "type": "click",
                  "handler": "sequence",
                  "actions": [
                    {
                      "comment": "모달 열기 전 현재 _local 상태를 _global 스냅샷에 저장 + 오류 상태 초기화",
                      "handler": "setState",
                      "params": {
                        "target": "global",
                        "bulkApplySnapshot": "{{(function() { const fields = _local.bulkApplyFields ?? []; const applyAll = _local.bulkApplyAll !== false; const boardIds = _local._bulkApplyBoardIds ?? []; const tab = _global.activeBoardSettingsTab || 'basic_defaults'; const form = _local.form || {}; return { fields: fields, applyAll: applyAll, boardIds: boardIds, tab: tab, form: form }; })()}}"
                      }
                    },
                    {
                      "comment": "이전 오류 메시지 초기화",
                      "handler": "setState",
                      "params": {
                        "target": "local",
                        "bulkApplySaveError": false
                      }
                    },
                    {
                      "handler": "openModal",
                      "target": "bulk_apply_confirm_modal"
                    }
                  ]
                }
              ],
              "children": [
                {
                  "type": "basic",
                  "name": "Span",
                  "text": "$t:sirsoft-board.admin.settings.bulk_apply.apply_button"
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
