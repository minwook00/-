{
  "meta": {
    "is_partial": true
  },
  "id": "board_guest_password_modal",
  "type": "composite",
  "name": "Modal",
  "props": {
    "title": "{{_global.guestPasswordModal?.action === 'edit' ? (_global.guestPasswordModal?.targetType === 'comment' ? '$t:board.modals.edit_comment_title' : '$t:board.modals.edit_post_title') : (_global.guestPasswordModal?.targetType === 'comment' ? '$t:board.modals.delete_comment_title' : '$t:board.modals.delete_post_title')}}",
    "icon": "{{_global.guestPasswordModal?.action === 'edit' ? 'pen' : 'trash'}}",
    "iconClassName": "{{_global.guestPasswordModal?.action === 'edit' ? 'text-teal-500' : 'text-red-500'}}",
    "size": "sm"
  },
  "children": [
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "space-y-4"
      },
      "children": [
        {
          "type": "basic",
          "name": "P",
          "props": {
            "className": "text-sm text-slate-600 dark:text-slate-400"
          },
          "text": "$t:board.password_verify.description"
        },
        {
          "type": "basic",
          "name": "Div",
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex items-center gap-1.5 mb-1"
              },
              "children": [
                {
                  "type": "composite",
                  "name": "Icon",
                  "props": {
                    "name": "lock",
                    "size": "xs",
                    "className": "text-slate-500 dark:text-slate-400"
                  }
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-sm font-medium text-slate-700 dark:text-slate-300"
                  },
                  "text": "$t:board.guest_password"
                }
              ]
            },
            {
              "type": "basic",
              "name": "Input",
              "props": {
                "type": "password",
                "placeholder": "$t:board.guest_password_placeholder",
                "className": "w-full px-4 py-2 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-800 text-slate-900 dark:text-white focus:ring-2 focus:ring-teal-500",
                "value": "{{_local.guestPasswordForm?.password ?? ''}}"
              },
              "actions": [
                {
                  "type": "change",
                  "handler": "setState",
                  "params": {
                    "target": "local",
                    "guestPasswordForm": {
                      "password": "{{$event.target.value}}"
                    }
                  }
                }
              ]
            }
          ]
        },
        {
          "type": "basic",
          "name": "Div",
          "if": "{{_local.guestPasswordError}}",
          "props": {
            "className": "text-sm text-red-500"
          },
          "text": "{{_local.guestPasswordError}}"
        },
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "flex justify-end gap-3"
          },
          "children": [
            {
              "type": "basic",
              "name": "Button",
              "props": {
                "className": "px-4 py-2 border border-slate-300 dark:border-slate-600 text-slate-700 dark:text-slate-300 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-700 cursor-pointer"
              },
              "text": "$t:common.cancel",
              "actions": [
                {
                  "type": "click",
                  "handler": "sequence",
                  "actions": [
                    {
                      "handler": "setState",
                      "params": {
                        "target": "local",
                        "guestPasswordForm": null,
                        "guestPasswordError": ""
                      }
                    },
                    {
                      "handler": "setState",
                      "params": {
                        "target": "global",
                        "guestPasswordModal": null
                      }
                    },
                    {
                      "handler": "closeModal"
                    }
                  ]
                }
              ]
            },
            {
              "type": "basic",
              "name": "Button",
              "props": {
                "disabled": "{{_global.guestPasswordModal?.isVerifying || !_local.guestPasswordForm?.password}}",
                "className": "px-4 py-2 bg-teal-600 dark:bg-teal-500 text-white rounded-lg font-medium hover:bg-teal-700 dark:hover:bg-teal-600 disabled:opacity-50 disabled:cursor-not-allowed"
              },
              "children": [
                {
                  "type": "composite",
                  "name": "Icon",
                  "if": "{{_global.guestPasswordModal?.isVerifying}}",
                  "props": {
                    "name": "spinner",
                    "size": "sm",
                    "className": "animate-spin mr-2"
                  }
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "text": "$t:board.password_verify.confirm"
                }
              ],
              "actions": [
                {
                  "type": "click",
                  "handler": "sequence",
                  "actions": [
                    {
                      "handler": "setState",
                      "params": {
                        "target": "global",
                        "guestPasswordModal": {
                          "targetType": "{{_global.guestPasswordModal?.targetType}}",
                          "action": "{{_global.guestPasswordModal?.action}}",
                          "apiEndpoint": "{{_global.guestPasswordModal?.apiEndpoint}}",
                          "storageKey": "{{_global.guestPasswordModal?.storageKey}}",
                          "redirectPath": "{{_global.guestPasswordModal?.redirectPath}}",
                          "commentEdit": "{{_global.guestPasswordModal?.commentEdit}}",
                          "isVerifying": true
                        }
                      }
                    },
                    {
                      "handler": "setState",
                      "params": {
                        "target": "local",
                        "guestPasswordError": ""
                      }
                    },
                    {
                      "handler": "apiCall",
                      "target": "{{_global.guestPasswordModal?.apiEndpoint}}",
                      "params": {
                        "method": "POST",
                        "body": {
                          "password": "{{_local.guestPasswordForm?.password}}"
                        }
                      },
                      "onSuccess": [
                        {
                          "if": "{{!_global.guestPasswordModal.redirectPath && _global.guestPasswordModal.commentEdit}}",
                          "handler": "setState",
                          "params": {
                            "target": "global",
                            "commentEdit": "{{_global.guestPasswordModal?.commentEdit}}",
                            "verifiedGuestPassword": "{{_local.guestPasswordForm?.password}}"
                          }
                        },
                        {
                          "if": "{{_global.guestPasswordModal.redirectPath}}",
                          "handler": "navigate",
                          "params": {
                            "path": "{{_global.guestPasswordModal.redirectPath}}"
                          }
                        },
                        {
                          "handler": "setState",
                          "params": {
                            "target": "local",
                            "guestPasswordForm": null,
                            "guestPasswordError": ""
                          }
                        },
                        {
                          "handler": "setState",
                          "params": {
                            "target": "global",
                            "guestPasswordModal": null
                          }
                        },
                        {
                          "handler": "closeModal"
                        }
                      ],
                      "onError": [
                        {
                          "handler": "setState",
                          "params": {
                            "target": "global",
                            "guestPasswordModal": {
                              "targetType": "{{_global.guestPasswordModal?.targetType}}",
                              "action": "{{_global.guestPasswordModal?.action}}",
                              "apiEndpoint": "{{_global.guestPasswordModal?.apiEndpoint}}",
                              "storageKey": "{{_global.guestPasswordModal?.storageKey}}",
                              "redirectPath": "{{_global.guestPasswordModal?.redirectPath}}",
                              "commentEdit": "{{_global.guestPasswordModal?.commentEdit}}",
                              "isVerifying": false
                            }
                          }
                        },
                        {
                          "handler": "setState",
                          "params": {
                            "target": "local",
                            "guestPasswordError": "$t:board.password_verify.incorrect"
                          }
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
