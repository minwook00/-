{
  "meta": {
    "is_partial": true
  },
  "type": "basic",
  "name": "Form",
  "props": {
    "className": "space-y-6"
  },
  "children": [
    {
      "type": "basic",
      "name": "Div",
      "if": "{{_global.loginError}}",
      "props": {
        "className": "p-4 rounded-lg bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800"
      },
      "children": [
        {
          "type": "basic",
          "name": "P",
          "props": {
            "className": "text-sm text-red-600 dark:text-red-400"
          },
          "text": "{{_global.loginError}}"
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "children": [
        {
          "type": "basic",
          "name": "Label",
          "props": {
            "className": "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-3"
          },
          "text": "$t:auth.email"
        },
        {
          "type": "basic",
          "name": "Input",
          "props": {
            "type": "email",
            "name": "email",
            "placeholder": "$t:auth.email_placeholder",
            "className": "{{_global.loginErrors?.email ? 'w-full px-4 py-2 border border-red-500 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:ring-2 focus:ring-red-500 focus:border-red-500 disabled:opacity-50 disabled:cursor-not-allowed transition-colors duration-200' : 'w-full px-4 py-2 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:ring-2 focus:ring-teal-500 focus:border-teal-500 disabled:opacity-50 disabled:cursor-not-allowed transition-colors duration-200'}}",
            "required": true,
            "disabled": "{{_global.isLoggingIn}}"
          }
        },
        {
          "type": "basic",
          "name": "P",
          "if": "{{_global.loginErrors?.email}}",
          "props": {
            "className": "mt-1 text-sm text-red-600 dark:text-red-400"
          },
          "text": "{{Array.isArray(_global.loginErrors?.email) ? _global.loginErrors.email[0] : _global.loginErrors?.email}}"
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "children": [
        {
          "type": "basic",
          "name": "Label",
          "props": {
            "className": "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-3"
          },
          "text": "$t:auth.password"
        },
        {
          "type": "basic",
          "name": "PasswordInput",
          "props": {
            "name": "password",
            "placeholder": "$t:auth.password_placeholder",
            "className": "w-full px-4 py-2 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:ring-2 focus:ring-teal-500 focus:border-teal-500 disabled:opacity-50 disabled:cursor-not-allowed transition-colors duration-200",
            "required": true,
            "disabled": "{{_global.isLoggingIn}}",
            "showToggle": true,
            "error": "{{_global.loginErrors?.password?.[0] ?? (_global.loginErrors?.password ?? '')}}"
          }
        }
      ]
    },
    {
      "type": "basic",
      "name": "Button",
      "props": {
        "type": "submit",
        "className": "w-full py-3 mt-12 bg-teal-600 dark:bg-teal-500 text-white rounded-lg font-medium hover:bg-teal-700 dark:hover:bg-teal-600 transition-colors disabled:opacity-50 disabled:cursor-not-allowed flex items-center justify-center gap-2",
        "disabled": "{{_global.isLoggingIn}}"
      },
      "children": [
        {
          "type": "basic",
          "name": "Div",
          "if": "{{_global.isLoggingIn}}",
          "props": {
            "className": "w-5 h-5 border-2 border-white/30 border-t-white rounded-full animate-spin"
          }
        },
        {
          "type": "basic",
          "name": "Span",
          "if": "{{!_global.isLoggingIn}}",
          "text": "$t:auth.login"
        },
        {
          "type": "basic",
          "name": "Span",
          "if": "{{_global.isLoggingIn}}",
          "text": "$t:auth.login_processing"
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "submit",
      "handler": "sequence",
      "actions": [
        {
          "handler": "setState",
          "params": {
            "target": "local",
            "isLoginAction": true
          }
        },
        {
          "handler": "setState",
          "params": {
            "target": "global",
            "isLoggingIn": true,
            "loginError": null,
            "loginErrors": null
          }
        },
        {
          "handler": "login",
          "target": "user",
          "params": {
            "body": {
              "email": "{{form.email}}",
              "password": "{{form.password}}"
            }
          },
          "onSuccess": [
            {
              "handler": "setState",
              "params": {
                "target": "global",
                "currentUser": "{{response.user}}"
              }
            },
            {
              "handler": "setState",
              "params": {
                "target": "global",
                "isLoggingIn": false
              }
            },
            {
              "handler": "toast",
              "params": {
                "type": "success",
                "message": "$t:auth.login_success"
              }
            },
            {
              "handler": "navigate",
              "params": {
                "path": "{{query.redirect ?? '/'}}"
              }
            }
          ],
          "onError": [
            {
              "handler": "setState",
              "params": {
                "target": "global",
                "isLoggingIn": false,
                "loginError": "{{error.message}}",
                "loginErrors": "{{error.errors}}"
              }
            }
          ]
        }
      ]
    }
  ]
}
