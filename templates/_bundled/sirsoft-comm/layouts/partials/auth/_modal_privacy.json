{
  "meta": {
    "is_partial": true
  },
  "id": "privacyModal",
  "type": "composite",
  "name": "Modal",
  "props": {
    "title": "$t:policy.privacy.title",
    "size": "lg",
    "className": "overflow-hidden"
  },
  "children": [
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "flex flex-col"
      },
      "children": [
        {
          "type": "basic",
          "name": "Div",
          "if": "{{privacyContent?.loading}}",
          "props": {
            "className": "flex justify-center items-center py-12"
          },
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "w-8 h-8 border-4 border-slate-300 dark:border-slate-600 border-t-teal-500 rounded-full animate-spin"
              }
            }
          ]
        },
        {
          "type": "basic",
          "name": "Div",
          "if": "{{!privacyContent?.loading && privacyContent?.data?.published_at}}",
          "props": {
            "className": "flex-shrink-0 flex items-center gap-2 mb-3"
          },
          "children": [
            {
              "type": "basic",
              "name": "Span",
              "props": {
                "className": "text-sm text-slate-500 dark:text-slate-400"
              },
              "text": "$t:policy.published_at: {{privacyContent?.data?.published_at | date}}"
            }
          ]
        },
        {
          "type": "basic",
          "name": "Div",
          "if": "{{!privacyContent?.loading && privacyContent?.data}}",
          "props": {
            "className": "flex-1 overflow-y-auto min-h-0 max-h-96"
          },
          "children": [
            {
              "id": "privacy_html_content",
              "type": "extension_point",
              "name": "html_content",
              "props": {
                "content": "{{privacyContent?.data?.content ?? ''}}",
                "isHtml": "{{(privacyContent?.data?.content_mode ?? 'html') === 'html'}}",
                "className": "prose dark:prose-invert prose-sm max-w-none text-slate-700 dark:text-slate-300"
              },
              "default": [
                {
                  "type": "composite",
                  "name": "HtmlContent",
                  "props": {
                    "content": "{{privacyContent?.data?.content ?? ''}}",
                    "isHtml": "{{(privacyContent?.data?.content_mode ?? 'html') === 'html'}}",
                    "className": "prose dark:prose-invert prose-sm max-w-none text-slate-700 dark:text-slate-300"
                  }
                }
              ]
            }
          ]
        },
        {
          "type": "basic",
          "name": "Div",
          "if": "{{!privacyContent?.loading && !privacyContent?.data}}",
          "props": {
            "className": "py-8 text-center text-slate-500 dark:text-slate-400"
          },
          "text": "$t:policy.no_content"
        },
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "flex-shrink-0 flex justify-end gap-3 mt-4 pt-4 border-t border-slate-200 dark:border-slate-700"
          },
          "children": [
            {
              "type": "basic",
              "name": "Button",
              "props": {
                "className": "px-4 py-2 bg-teal-600 dark:bg-teal-500 text-white rounded-lg hover:bg-teal-700 dark:hover:bg-teal-600"
              },
              "text": "$t:common.close",
              "actions": [
                {
                  "type": "click",
                  "handler": "closeModal"
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
