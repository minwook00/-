{
  "meta": {
    "is_partial": true
  },
  "type": "basic",
  "name": "Div",
  "if": "{{_global?.searchActiveTab === 'posts' && query?.q}}",
  "props": {
    "className": "flex flex-wrap gap-2 mb-4"
  },
  "children": [
    {
      "type": "basic",
      "name": "Select",
      "if": "{{_global?.searchActiveTab === 'posts'}}",
      "props": {
        "name": "boardFilter",
        "className": "w-40 px-4 py-2.5 bg-slate-100 dark:bg-slate-700 border-0 rounded-xl text-slate-700 dark:text-slate-200 font-medium focus:ring-2 focus:ring-teal-500 focus:outline-none cursor-pointer",
        "value": "{{_global?.searchBoardFilter ?? ''}}"
      },
      "children": [
        {
          "type": "basic",
          "name": "Option",
          "props": {
            "value": ""
          },
          "text": "$t:search.filter.all_boards"
        },
        {
          "type": "basic",
          "name": "Option",
          "iteration": {
            "source": "{{searchResults?.data?.posts?.available_boards ?? []}}",
            "item_var": "board"
          },
          "props": {
            "value": "{{board?.slug}}"
          },
          "text": "{{board?.name}}"
        }
      ],
      "actions": [
        {
          "type": "change",
          "handler": "sequence",
          "actions": [
            {
              "handler": "setState",
              "params": {
                "target": "global",
                "searchBoardFilter": "{{$event.target.value}}",
                "searchPage": 1
              }
            },
            {
              "handler": "refetchDataSource",
              "params": {
                "dataSourceId": "searchResults"
              }
            }
          ]
        }
      ]
    },
    {
      "type": "composite",
      "name": "Select",
      "if": "{{_global?.searchActiveTab === 'posts'}}",
      "props": {
        "name": "sortBy",
        "className": "w-32",
        "value": "{{_global?.searchSortBy ?? 'relevance'}}",
        "options": [
          {
            "value": "relevance",
            "label": "$t:search.sort.relevance"
          },
          {
            "value": "latest",
            "label": "$t:search.sort.latest"
          },
          {
            "value": "popular",
            "label": "$t:search.sort.popular"
          }
        ]
      },
      "actions": [
        {
          "type": "change",
          "handler": "sequence",
          "actions": [
            {
              "handler": "setState",
              "params": {
                "target": "global",
                "searchSortBy": "{{$event.target.value}}",
                "searchPage": 1
              }
            },
            {
              "handler": "refetchDataSource",
              "params": {
                "dataSourceId": "searchResults"
              }
            }
          ]
        }
      ]
    }
  ]
}
