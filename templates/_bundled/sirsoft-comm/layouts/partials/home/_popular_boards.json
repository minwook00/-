{
  "meta": {
    "is_partial": true
  },
  "type": "basic",
  "name": "Div",
  "props": {
    "className": "bg-slate-50 dark:bg-slate-800 rounded-xl p-4 shadow-md border border-slate-200/70 dark:border-slate-700 h-full flex flex-col transition-all hover:shadow-lg"
  },
  "children": [
    {
      "type": "basic",
      "name": "H3",
      "props": {
        "className": "text-lg font-semibold text-slate-900 dark:text-white flex items-center gap-2 mb-3"
      },
      "children": [
        {
          "type": "basic",
          "name": "Icon",
          "props": {
            "name": "flame",
            "className": "w-5 h-5 text-orange-500"
          }
        },
        {
          "type": "basic",
          "name": "Span",
          "text": "$t:home.popular_boards"
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "if": "{{popular_boards.data && popular_boards.data.length > 0}}",
      "props": {
        "className": "space-y-2 mb-1"
      },
      "iteration": {
        "source": "{{popular_boards.data ?? []}}",
        "item_var": "board",
        "index_var": "index"
      },
      "children": [
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "className": "w-full text-left flex items-center justify-between py-2 hover:bg-slate-50 dark:hover:bg-slate-700/50 rounded-lg transition-colors cursor-pointer"
          },
          "actions": [
            {
              "type": "click",
              "handler": "navigate",
              "params": {
                "path": "/board/{{board.slug}}"
              }
            }
          ],
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex items-center gap-3 flex-1 min-w-0"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "w-6 h-6 rounded-full bg-slate-100 dark:bg-slate-700 flex items-center justify-center text-xs font-medium text-slate-600 dark:text-slate-300"
                  },
                  "text": "{{index + 1}}"
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-sm font-medium text-slate-900 dark:text-white"
                  },
                  "text": "{{board.name}}"
                }
              ]
            },
            {
              "type": "basic",
              "name": "Span",
              "props": {
                "className": "text-xs font-medium text-teal-600 dark:text-teal-400 bg-teal-50 dark:bg-teal-900/30 px-2 py-1 rounded"
              },
              "text": "{{board.posts_count | number}}"
            }
          ]
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "if": "{{!popular_boards.data || popular_boards.data.length === 0}}",
      "props": {
        "className": "text-center py-6 text-slate-500 dark:text-slate-400 flex-grow flex flex-col items-center justify-center min-h-[140px]"
      },
      "children": [
        {
          "type": "basic",
          "name": "Icon",
          "props": {
            "name": "inbox",
            "className": "w-7 h-7 mx-auto mb-2 opacity-50"
          }
        },
        {
          "type": "basic",
          "name": "P",
          "props": {
            "className": "text-sm"
          },
          "text": "$t:home.no_boards"
        }
      ]
    }
  ]
}
