{
  "meta": {
    "is_partial": true
  },
  "type": "basic",
  "name": "Div",
  "props": {
    "className": "block w-full text-left bg-white dark:bg-slate-800 rounded-xl pt-3 shadow-sm border border-slate-100 dark:border-slate-700 hover:shadow-md hover:border-teal-200 dark:hover:border-teal-800 transition-all"
  },
  "children": [
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "flex items-center justify-between mb-2 px-3"
      },
      "children": [
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "className": "font-semibold text-slate-900 dark:text-white hover:text-teal-600 dark:hover:text-teal-400 cursor-pointer"
          },
          "text": "{{item.name}}",
          "actions": [
            {
              "type": "click",
              "handler": "navigate",
              "params": {
                "path": "/board/{{item.slug}}"
              }
            }
          ]
        },
        {
          "type": "basic",
          "name": "Span",
          "props": {
            "className": "text-xs font-medium text-teal-600 dark:text-teal-400 bg-teal-50 dark:bg-teal-900/30 px-2 py-1 rounded"
          },
          "text": "{{item.posts_count | number}}"
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "px-3 pb-2"
      },
      "children": [
        {
          "type": "basic",
          "name": "Div",
          "if": "{{item.recent_posts && item.recent_posts.length > 0}}",
          "props": {
            "className": "space-y-1"
          },
          "iteration": {
            "source": "{{item.recent_posts ?? []}}",
            "item_var": "post"
          },
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex items-center justify-between w-full hover:bg-slate-50 dark:hover:bg-slate-700/50 rounded-lg py-1.5 transition-colors gap-2"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex items-center gap-2 flex-1 min-w-0"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Span",
                      "if": "{{post.is_notice}}",
                      "props": {
                        "className": "text-xs font-medium text-red-600 dark:text-red-400 bg-red-50 dark:bg-red-900/30 px-1.5 py-0.5 rounded shrink-0"
                      },
                      "text": "$t:board.notice"
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "if": "{{post.category && !post.is_notice}}",
                      "props": {
                        "className": "text-xs font-medium text-teal-600 dark:text-teal-400 bg-teal-50 dark:bg-teal-900/30 px-1.5 py-0.5 rounded shrink-0"
                      },
                      "text": "{{post.category}}"
                    },
                    {
                      "type": "basic",
                      "name": "Icon",
                      "if": "{{post.is_secret}}",
                      "props": {
                        "name": "lock",
                        "className": "w-3.5 h-3.5 text-slate-400 dark:text-slate-500 shrink-0"
                      }
                    },
                    {
                      "type": "basic",
                      "name": "Button",
                      "props": {
                        "className": "text-sm text-slate-900 dark:text-white text-left line-clamp-1 hover:text-teal-600 dark:hover:text-teal-400 cursor-pointer"
                      },
                      "actions": [
                        {
                          "type": "click",
                          "handler": "navigate",
                          "params": {
                            "path": "/board/{{item.slug}}/{{post.id}}"
                          }
                        }
                      ],
                      "text": "{{post.title}}"
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "if": "{{post.is_new}}",
                      "props": {
                        "className": "px-1.5 py-0.5 text-xs bg-red-500 text-white rounded shrink-0"
                      },
                      "text": "$t:board.new_badge"
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "if": "{{post.comment_count > 0}}",
                      "props": {
                        "className": "text-xs font-medium text-teal-500 dark:text-teal-400 shrink-0"
                      },
                      "text": "$t:home.comment_count_badge|count={{post.comment_count}}"
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-xs text-slate-500 dark:text-slate-400 shrink-0",
                    "title": "{{post.created_at ?? ''}}"
                  },
                  "text": "{{post.created_at_formatted ?? ''}}"
                }
              ]
            }
          ]
        },
        {
          "type": "basic",
          "name": "Div",
          "if": "{{!item.recent_posts || item.recent_posts.length === 0}}",
          "props": {
            "className": "py-6 my-1 text-center text-sm text-slate-400 dark:text-slate-500"
          },
          "children": [
            {
              "type": "basic",
              "name": "Span",
              "text": "$t:home.no_posts"
            }
          ]
        }
      ]
    },
    {
      "type": "basic",
      "name": "Button",
      "props": {
        "className": "w-full px-3 py-2.5 text-center text-sm font-medium text-teal-600 dark:text-teal-400 hover:bg-teal-50 dark:hover:bg-teal-900/20 transition-colors cursor-pointer border-t border-slate-100 dark:border-slate-700"
      },
      "actions": [
        {
          "type": "click",
          "handler": "navigate",
          "params": {
            "path": "/board/{{item.slug}}"
          }
        }
      ],
      "children": [
        {
          "type": "basic",
          "name": "Span",
          "text": "$t:common.more"
        },
        {
          "type": "basic",
          "name": "Icon",
          "props": {
            "name": "arrow-right",
            "className": "w-4 h-4 inline-block ml-1"
          }
        }
      ]
    }
  ]
}
