{
  "meta": {
    "is_partial": true
  },
  "id": "notification_delete_all_confirm_modal",
  "type": "composite",
  "name": "Modal",
  "props": {
    "title": "$t:mypage.notifications.delete_all_title",
    "size": "small"
  },
  "children": [
    {
      "type": "basic",
      "name": "P",
      "props": {
        "className": "text-slate-700 dark:text-slate-300"
      },
      "text": "$t:mypage.notifications.delete_all_confirm"
    },
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "flex justify-end gap-3 mt-6"
      },
      "children": [
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "className": "px-4 py-2 bg-white dark:bg-slate-800 text-slate-700 dark:text-slate-300 border border-slate-300 dark:border-slate-600 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-700 disabled:opacity-50 disabled:cursor-not-allowed",
            "disabled": "{{_global.isDeletingAllNotifications}}",
            "type": "button"
          },
          "actions": [
            {
              "type": "click",
              "handler": "closeModal",
              "target": "notification_delete_all_confirm_modal"
            }
          ],
          "text": "$t:common.cancel"
        },
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "className": "flex items-center gap-2 px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 disabled:opacity-50 disabled:cursor-not-allowed",
            "disabled": "{{_global.isDeletingAllNotifications}}",
            "type": "button"
          },
          "actions": [
            {
              "type": "click",
              "handler": "sequence",
              "actions": [
                {
                  "handler": "setState",
                  "params": {
                    "target": "global",
                    "isDeletingAllNotifications": true
                  }
                },
                {
                  "handler": "apiCall",
                  "auth_required": true,
                  "target": "/api/user/notifications/all",
                  "params": {
                    "method": "DELETE"
                  },
                  "onSuccess": [
                    {
                      "handler": "setState",
                      "params": {
                        "target": "global",
                        "isDeletingAllNotifications": false,
                        "notificationsCurrentPage": 1,
                        "notificationsHasMore": null,
                        "notificationsLoadingMore": false
                      }
                    },
                    {
                      "handler": "toast",
                      "params": {
                        "type": "success",
                        "message": "$t:mypage.notifications.delete_all_success"
                      }
                    },
                    {
                      "handler": "refetchDataSource",
                      "params": {
                        "dataSourceId": "notifications"
                      }
                    },
                    {
                      "handler": "refetchDataSource",
                      "params": {
                        "dataSourceId": "notification_unread_count"
                      }
                    },
                    {
                      "handler": "refetchDataSource",
                      "params": {
                        "dataSourceId": "userNotifications"
                      }
                    },
                    {
                      "handler": "closeModal",
                      "target": "notification_delete_all_confirm_modal"
                    }
                  ],
                  "onError": [
                    {
                      "handler": "setState",
                      "params": {
                        "target": "global",
                        "isDeletingAllNotifications": false
                      }
                    },
                    {
                      "handler": "toast",
                      "params": {
                        "type": "error",
                        "message": "{{error.message ?? $t:mypage.notifications.delete_all_failed}}"
                      }
                    }
                  ]
                }
              ]
            }
          ],
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "if": "{{_global.isDeletingAllNotifications}}",
              "props": {
                "name": "spinner",
                "className": "w-4 h-4 animate-spin"
              }
            },
            {
              "type": "basic",
              "name": "Span",
              "text": "{{_global.isDeletingAllNotifications ? $t:common.deleting : $t:common.delete}}"
            }
          ]
        }
      ]
    }
  ]
}
