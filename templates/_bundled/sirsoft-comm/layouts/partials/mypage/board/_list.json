{
  "meta": {
    "is_partial": true
  },
  "type": "basic",
  "name": "Div",
  "props": {
    "className": "mt-6"
  },
  "responsive": {
    "portable": {
      "props": {
        "className": "mt-4"
      }
    }
  },
  "children": [
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "mb-6"
      },
      "children": [
        {
          "type": "basic",
          "name": "H2",
          "props": {
            "className": "text-xl font-bold text-slate-900 dark:text-white"
          },
          "text": "$t:mypage.board_activities.title"
        },
        {
          "type": "basic",
          "name": "P",
          "props": {
            "className": "mt-1 text-sm text-slate-500 dark:text-slate-400"
          },
          "text": "$t:mypage.board_activities.description"
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "blur_until_loaded": {
        "enabled": true,
        "data_sources": [
          "myActivityStats"
        ]
      },
      "props": {
        "className": "grid grid-cols-3 gap-4 mb-6"
      },
      "responsive": {
        "portable": {
          "props": {
            "className": "grid grid-cols-1 gap-3 mb-4"
          }
        }
      },
      "children": [
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "bg-white dark:bg-slate-800 rounded-lg border border-slate-200 dark:border-slate-700 p-4 text-center"
          },
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "props": {
                "name": "file-text",
                "size": "lg",
                "className": "mx-auto text-slate-400 dark:text-slate-500 mb-2"
              }
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "text-2xl font-bold text-slate-900 dark:text-white"
              },
              "text": "{{(myActivityStats?.data?.total_posts ?? 0) | number}}"
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "text-sm text-slate-500 dark:text-slate-400"
              },
              "text": "$t:mypage.board_activities.stats.total_posts"
            }
          ]
        },
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "bg-white dark:bg-slate-800 rounded-lg border border-slate-200 dark:border-slate-700 p-4 text-center"
          },
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "props": {
                "name": "comment",
                "size": "lg",
                "className": "mx-auto text-slate-400 dark:text-slate-500 mb-2"
              }
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "text-2xl font-bold text-slate-900 dark:text-white"
              },
              "text": "{{(myActivityStats?.data?.total_comments ?? 0) | number}}"
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "text-sm text-slate-500 dark:text-slate-400"
              },
              "text": "$t:mypage.board_activities.stats.total_comments"
            }
          ]
        },
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "bg-white dark:bg-slate-800 rounded-lg border border-slate-200 dark:border-slate-700 p-4 text-center"
          },
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "props": {
                "name": "eye",
                "size": "lg",
                "className": "mx-auto text-slate-400 dark:text-slate-500 mb-2"
              }
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "text-2xl font-bold text-slate-900 dark:text-white"
              },
              "text": "{{(myActivityStats?.data?.total_views ?? 0) | number}}"
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "text-sm text-slate-500 dark:text-slate-400"
              },
              "text": "$t:mypage.board_activities.stats.total_views"
            }
          ]
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "flex gap-2 mb-4 border-b border-slate-200 dark:border-slate-700"
      },
      "children": [
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "className": "px-4 py-2 text-sm font-medium border-b-2 transition-colors flex items-center gap-2 {{(_global.boardActivitySubTab ?? 'my-posts') === 'my-posts' ? 'border-slate-900 dark:border-white text-slate-900 dark:text-white' : 'border-transparent text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-300'}}"
          },
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "props": {
                "name": "file-text",
                "size": "sm"
              }
            },
            {
              "type": "basic",
              "name": "Span",
              "text": "$t:mypage.board_activities.tabs.my_posts"
            },
            {
              "type": "basic",
              "name": "Span",
              "props": {
                "className": "ml-1 text-xs bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300 px-1.5 py-0.5 rounded-full"
              },
              "text": "{{(myActivityStats?.data?.total_posts ?? 0) | number}}"
            }
          ],
          "actions": [
            {
              "type": "click",
              "handler": "sequence",
              "actions": [
                {
                  "handler": "setState",
                  "params": {
                    "target": "global",
                    "boardActivitySubTab": "my-posts",
                    "myPostsPage": 1
                  }
                },
                {
                  "handler": "refetchDataSource",
                  "params": {
                    "dataSourceId": "myPosts"
                  }
                }
              ]
            }
          ]
        },
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "className": "px-4 py-2 text-sm font-medium border-b-2 transition-colors flex items-center gap-2 {{(_global.boardActivitySubTab ?? 'my-posts') === 'my-comments' ? 'border-slate-900 dark:border-white text-slate-900 dark:text-white' : 'border-transparent text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-300'}}"
          },
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "props": {
                "name": "comment",
                "size": "sm"
              }
            },
            {
              "type": "basic",
              "name": "Span",
              "text": "$t:mypage.board_activities.tabs.my_comments"
            },
            {
              "type": "basic",
              "name": "Span",
              "props": {
                "className": "ml-1 text-xs bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300 px-1.5 py-0.5 rounded-full"
              },
              "text": "{{(myActivityStats?.data?.total_comments ?? 0) | number}}"
            }
          ],
          "actions": [
            {
              "type": "click",
              "handler": "sequence",
              "actions": [
                {
                  "handler": "setState",
                  "params": {
                    "target": "global",
                    "boardActivitySubTab": "my-comments",
                    "myCommentsPage": 1
                  }
                },
                {
                  "handler": "refetchDataSource",
                  "params": {
                    "dataSourceId": "myComments"
                  }
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "if": "{{(_global.boardActivitySubTab ?? 'my-posts') === 'my-posts'}}",
      "blur_until_loaded": {
        "enabled": true,
        "data_sources": [
          "myPosts"
        ]
      },
      "children": [
        {
          "partial": "partials/mypage/board/_my_posts.json"
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "if": "{{(_global.boardActivitySubTab ?? 'my-posts') === 'my-comments'}}",
      "blur_until_loaded": {
        "enabled": true,
        "data_sources": [
          "myComments"
        ]
      },
      "children": [
        {
          "partial": "partials/mypage/board/_my_comments.json"
        }
      ]
    }
  ]
}
