{
  "version": "1.0.0",
  "layout_name": "users/posts",
  "extends": "_user_base",
  "permissions": [],
  "data_sources": [
    {
      "id": "userProfile",
      "type": "api",
      "endpoint": "/api/users/{{route.userId}}/profile",
      "method": "GET",
      "auto_fetch": true,
      "auth_required": true,
      "refetchOnMount": true,
      "loading_strategy": "progressive",
      "errorHandling": {
        "404": {
          "handler": "showErrorPage",
          "params": {
            "target": "content"
          }
        }
      }
    },
    {
      "id": "userPosts",
      "type": "api",
      "endpoint": "/api/modules/sirsoft-board/users/{{route.userId}}/posts",
      "method": "GET",
      "auto_fetch": true,
      "auth_required": false,
      "loading_strategy": "progressive",
      "params": {
        "page": "{{query.page || 1}}",
        "per_page": 20
      }
    }
  ],
  "slots": {
    "content": [
      {
        "type": "basic",
        "name": "Div",
        "props": {
          "className": "min-h-screen bg-slate-50 dark:bg-slate-900"
        },
        "children": [
          {
            "type": "layout",
            "name": "Container",
            "props": {
              "className": "py-8"
            },
            "responsive": {
              "portable": {
                "props": {
                  "className": "py-4"
                }
              }
            },
            "children": [
              {
                "type": "basic",
                "name": "Div",
                "if": "{{userPosts.loading && !userPosts.data}}",
                "props": {
                  "className": "flex justify-center items-center py-20"
                },
                "children": [
                  {
                    "type": "basic",
                    "name": "Div",
                    "props": {
                      "className": "animate-spin rounded-full h-8 w-8 border-b-2 border-slate-900 dark:border-white"
                    }
                  }
                ]
              },
              {
                "type": "basic",
                "name": "Div",
                "if": "{{userPosts.data && !userPosts.error}}",
                "props": {
                  "className": "space-y-6"
                },
                "children": [
                  {
                    "type": "basic",
                    "name": "Div",
                    "props": {
                      "className": "flex items-center gap-2 text-sm text-slate-500 dark:text-slate-400 mb-2"
                    },
                    "children": [
                      {
                        "type": "basic",
                        "name": "Button",
                        "props": {
                          "className": "hover:text-teal-600 dark:hover:text-teal-400 cursor-pointer transition-colors"
                        },
                        "actions": [
                          {
                            "type": "click",
                            "handler": "navigate",
                            "params": {
                              "path": "/users/{{route.userId}}"
                            }
                          }
                        ],
                        "text": "$t:user.profile.back_to_profile_for_user|name={{userProfile.data?.name ?? ''}}"
                      },
                      {
                        "type": "basic",
                        "name": "Span",
                        "text": ">"
                      },
                      {
                        "type": "basic",
                        "name": "Span",
                        "props": {
                          "className": "text-slate-900 dark:text-white font-medium"
                        },
                        "text": "$t:user.profile.posts_page_title"
                      }
                    ]
                  },
                  {
                    "type": "basic",
                    "name": "Div",
                    "props": {
                      "className": "mb-4"
                    },
                    "children": [
                      {
                        "type": "basic",
                        "name": "Div",
                        "props": {
                          "className": "flex items-center gap-2"
                        },
                        "children": [
                          {
                            "type": "basic",
                            "name": "Icon",
                            "props": {
                              "name": "file-lines",
                              "size": "xl",
                              "className": "text-slate-900 dark:text-white"
                            }
                          },
                          {
                            "type": "basic",
                            "name": "H1",
                            "props": {
                              "className": "text-2xl font-bold text-slate-900 dark:text-white"
                            },
                            "text": "$t:user.profile.posts_title_for_user|name={{userProfile.data?.name ?? ''}}"
                          }
                        ]
                      },
                      {
                        "type": "basic",
                        "name": "Span",
                        "props": {
                          "className": "text-sm text-slate-500 dark:text-slate-400 mt-1 block text-right"
                        },
                        "text": "$t:user.profile.total_posts|count={{userPosts.data?.total ?? 0}}"
                      }
                    ]
                  },
                  {
                    "type": "basic",
                    "name": "Div",
                    "props": {
                      "className": "bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 overflow-hidden"
                    },
                    "children": [
                      {
                        "type": "basic",
                        "name": "Div",
                        "if": "{{!userPosts.data?.data?.length}}",
                        "props": {
                          "className": "text-center py-12"
                        },
                        "children": [
                          {
                            "type": "basic",
                            "name": "Icon",
                            "props": {
                              "name": "file-circle-xmark",
                              "size": "3x",
                              "className": "text-slate-300 dark:text-slate-600 mb-4"
                            }
                          },
                          {
                            "type": "basic",
                            "name": "P",
                            "props": {
                              "className": "text-slate-500 dark:text-slate-400"
                            },
                            "text": "$t:user.profile.no_posts"
                          }
                        ]
                      },
                      {
                        "type": "basic",
                        "name": "Div",
                        "if": "{{userPosts.data?.data?.length > 0}}",
                        "props": {
                          "className": "hidden md:grid grid-cols-12 gap-2 px-4 py-3 bg-slate-50 dark:bg-slate-700/50 border-b border-slate-200 dark:border-slate-700 text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider"
                        },
                        "children": [
                          {
                            "type": "basic",
                            "name": "Div",
                            "props": {
                              "className": "col-span-2"
                            },
                            "text": "$t:user.profile.post_board"
                          },
                          {
                            "type": "basic",
                            "name": "Div",
                            "props": {
                              "className": "col-span-6"
                            },
                            "text": "$t:user.profile.post_title"
                          },
                          {
                            "type": "basic",
                            "name": "Div",
                            "props": {
                              "className": "col-span-1 text-center"
                            },
                            "text": "$t:user.profile.post_views"
                          },
                          {
                            "type": "basic",
                            "name": "Div",
                            "props": {
                              "className": "col-span-3 text-right"
                            },
                            "text": "$t:user.profile.post_date"
                          }
                        ]
                      },
                      {
                        "type": "basic",
                        "name": "Div",
                        "if": "{{userPosts.data?.data?.length > 0}}",
                        "props": {
                          "className": "divide-y divide-slate-200 dark:divide-slate-700"
                        },
                        "children": [
                          {
                            "type": "basic",
                            "name": "Button",
                            "iteration": {
                              "source": "{{userPosts.data?.data ?? []}}",
                              "item_var": "post"
                            },
                            "props": {
                              "className": "w-full text-left grid grid-cols-1 md:grid-cols-12 gap-2 px-4 py-3 hover:bg-slate-50 dark:hover:bg-slate-700/50 transition-colors cursor-pointer items-center"
                            },
                            "actions": [
                              {
                                "type": "click",
                                "handler": "navigate",
                                "params": {
                                  "path": "/board/{{post.board_slug}}/{{post.id}}"
                                }
                              }
                            ],
                            "children": [
                              {
                                "type": "basic",
                                "name": "Div",
                                "props": {
                                  "className": "hidden md:block col-span-2 text-sm text-slate-600 dark:text-slate-400 truncate"
                                },
                                "text": "{{post.board_name}}"
                              },
                              {
                                "type": "basic",
                                "name": "Div",
                                "props": {
                                  "className": "col-span-1 md:col-span-6 flex items-center gap-2 min-w-0 overflow-hidden"
                                },
                                "children": [
                                  {
                                    "type": "basic",
                                    "name": "Span",
                                    "props": {
                                      "className": "md:hidden flex-shrink-0 text-xs px-1.5 py-0.5 bg-teal-100 dark:bg-teal-900/50 text-teal-700 dark:text-teal-300 rounded whitespace-nowrap"
                                    },
                                    "text": "{{post.board_name}}"
                                  },
                                  {
                                    "type": "basic",
                                    "name": "Span",
                                    "if": "{{post.category}}",
                                    "props": {
                                      "className": "flex-shrink-0 text-xs px-1.5 py-0.5 bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-400 rounded whitespace-nowrap"
                                    },
                                    "text": "{{post.category}}"
                                  },
                                  {
                                    "type": "basic",
                                    "name": "Icon",
                                    "if": "{{post.is_secret}}",
                                    "props": {
                                      "name": "lock",
                                      "size": "xs",
                                      "className": "flex-shrink-0 text-orange-500 dark:text-orange-400"
                                    }
                                  },
                                  {
                                    "type": "basic",
                                    "name": "Icon",
                                    "if": "{{post.status === 'blinded'}}",
                                    "props": {
                                      "name": "eye-slash",
                                      "size": "xs",
                                      "className": "flex-shrink-0 text-orange-500 dark:text-orange-400"
                                    }
                                  },
                                  {
                                    "type": "basic",
                                    "name": "Div",
                                    "props": {
                                      "className": "flex-1 min-w-0 flex items-center gap-1"
                                    },
                                    "children": [
                                      {
                                        "type": "basic",
                                        "name": "Span",
                                        "props": {
                                          "className": "truncate font-medium text-slate-900 dark:text-white"
                                        },
                                        "text": "{{post.title}}"
                                      },
                                      {
                                        "type": "basic",
                                        "name": "Span",
                                        "if": "{{post.comments_count > 0}}",
                                        "props": {
                                          "className": "flex-shrink-0 text-xs text-teal-600 dark:text-teal-400 font-medium"
                                        },
                                        "text": "[{{post.comments_count}}]"
                                      }
                                    ]
                                  }
                                ]
                              },
                              {
                                "type": "basic",
                                "name": "Div",
                                "props": {
                                  "className": "hidden md:flex col-span-1 justify-center items-center gap-1 text-sm text-slate-500 dark:text-slate-400"
                                },
                                "children": [
                                  {
                                    "type": "basic",
                                    "name": "Icon",
                                    "props": {
                                      "name": "eye",
                                      "size": "xs"
                                    }
                                  },
                                  {
                                    "type": "basic",
                                    "name": "Span",
                                    "text": "{{post.view_count ?? 0}}"
                                  }
                                ]
                              },
                              {
                                "type": "basic",
                                "name": "Span",
                                "props": {
                                  "className": "hidden md:block col-span-3 text-right text-sm text-slate-500 dark:text-slate-400",
                                  "title": "{{post.created_at ?? ''}}"
                                },
                                "text": "{{post.created_at_formatted ?? ''}}"
                              },
                              {
                                "type": "basic",
                                "name": "Div",
                                "props": {
                                  "className": "md:hidden flex items-center gap-3 text-xs text-slate-500 dark:text-slate-400 mt-1"
                                },
                                "children": [
                                  {
                                    "type": "basic",
                                    "name": "Span",
                                    "props": {
                                      "className": "flex items-center gap-1"
                                    },
                                    "children": [
                                      {
                                        "type": "basic",
                                        "name": "Icon",
                                        "props": {
                                          "name": "eye",
                                          "size": "xs"
                                        }
                                      },
                                      {
                                        "type": "basic",
                                        "name": "Span",
                                        "text": "{{post.view_count ?? 0}}"
                                      }
                                    ]
                                  },
                                  {
                                    "type": "basic",
                                    "name": "Span",
                                    "props": {
                                      "title": "{{post.created_at ?? ''}}"
                                    },
                                    "text": "{{post.created_at_formatted ?? ''}}"
                                  }
                                ]
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "basic",
                    "name": "Div",
                    "props": {
                      "className": "flex justify-center mt-6"
                    },
                    "children": [
                      {
                        "type": "composite",
                        "name": "Pagination",
                        "props": {
                          "currentPage": "{{userPosts.data?.current_page ?? 1}}",
                          "totalPages": "{{userPosts.data?.last_page ?? 1}}"
                        },
                        "actions": [
                          {
                            "event": "onPageChange",
                            "handler": "navigate",
                            "params": {
                              "path": "/users/{{route.userId}}/posts",
                              "mergeQuery": true,
                              "query": {
                                "page": "{{$args[0]}}"
                              }
                            }
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
