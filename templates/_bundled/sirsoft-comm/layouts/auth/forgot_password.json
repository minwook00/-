{
  "version": "1.0.0",
  "layout_name": "auth/forgot_password",
  "extends": "_user_base",
  "meta": {
    "title": "$t:auth.forgot_password.title",
    "guest_only": true
  },
  "slots": {
    "content": [
      {
        "type": "basic",
        "name": "Div",
        "blur_until_loaded": "{{_global?.currentUser?.uuid}}",
        "props": {
          "className": "min-h-[60vh] flex items-center justify-center py-12 px-4"
        },
        "children": [
          {
            "partial": "partials/auth/_redirect_if_logged_in.json"
          },
          {
            "type": "basic",
            "name": "Div",
            "props": {
              "className": "w-full max-w-md"
            },
            "children": [
              {
                "type": "basic",
                "name": "Div",
                "props": {
                  "className": "bg-white dark:bg-slate-800 rounded-lg shadow-md p-8"
                },
                "responsive": {
                  "portable": {
                    "props": {
                      "className": "bg-white dark:bg-slate-800 rounded-lg shadow-md p-6"
                    }
                  }
                },
                "children": [
                  {
                    "type": "basic",
                    "name": "Div",
                    "props": {
                      "className": "text-center mb-8"
                    },
                    "children": [
                      {
                        "type": "basic",
                        "name": "H1",
                        "props": {
                          "className": "text-2xl font-bold text-slate-900 dark:text-white mb-2"
                        },
                        "text": "$t:auth.forgot_password.title"
                      },
                      {
                        "type": "basic",
                        "name": "P",
                        "props": {
                          "className": "text-slate-600 dark:text-slate-400"
                        },
                        "text": "$t:auth.forgot_password.subtitle"
                      }
                    ]
                  },
                  {
                    "type": "basic",
                    "name": "Div",
                    "props": {
                      "className": "mb-6 p-4 bg-green-50 dark:bg-green-900/30 border border-green-200 dark:border-green-800 rounded-lg"
                    },
                    "if": "{{_local.success}}",
                    "children": [
                      {
                        "type": "basic",
                        "name": "P",
                        "props": {
                          "className": "text-green-700 dark:text-green-300 text-sm"
                        },
                        "text": "$t:auth.forgot_password.success"
                      }
                    ]
                  },
                  {
                    "type": "basic",
                    "name": "Form",
                    "props": {
                      "className": "space-y-6"
                    },
                    "if": "{{!_local.success}}",
                    "actions": [
                      {
                        "type": "submit",
                        "handler": "sequence",
                        "actions": [
                          {
                            "handler": "setState",
                            "params": {
                              "target": "local",
                              "isSubmitting": true
                            }
                          },
                          {
                            "handler": "apiCall",
                            "target": "/api/auth/forgot-password",
                            "params": {
                              "method": "POST",
                              "body": {
                                "email": "{{form.email}}"
                              }
                            },
                            "onSuccess": {
                              "handler": "setState",
                              "params": {
                                "target": "local",
                                "isSubmitting": false,
                                "success": true
                              }
                            },
                            "onError": [
                              {
                                "handler": "setState",
                                "params": {
                                  "target": "local",
                                  "isSubmitting": false
                                }
                              },
                              {
                                "handler": "toast",
                                "params": {
                                  "type": "error",
                                  "message": "{{error.message}}"
                                }
                              }
                            ]
                          }
                        ]
                      }
                    ],
                    "children": [
                      {
                        "type": "basic",
                        "name": "Div",
                        "children": [
                          {
                            "type": "basic",
                            "name": "Label",
                            "props": {
                              "className": "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2"
                            },
                            "text": "$t:auth.forgot_password.email"
                          },
                          {
                            "type": "basic",
                            "name": "Input",
                            "props": {
                              "type": "email",
                              "name": "email",
                              "placeholder": "$t:auth.forgot_password.email_placeholder",
                              "className": "w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:ring-2 focus:ring-primary-500 focus:border-transparent disabled:opacity-50 disabled:cursor-not-allowed",
                              "required": true,
                              "disabled": "{{_local.isSubmitting ?? false}}"
                            }
                          }
                        ]
                      },
                      {
                        "type": "basic",
                        "name": "Button",
                        "props": {
                          "type": "submit",
                          "className": "w-full py-3 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors font-medium disabled:opacity-50 disabled:cursor-not-allowed flex items-center justify-center gap-2",
                          "disabled": "{{_local.isSubmitting ?? false}}"
                        },
                        "children": [
                          {
                            "type": "basic",
                            "name": "Div",
                            "if": "{{_local.isSubmitting}}",
                            "props": {
                              "className": "w-5 h-5 border-2 border-white/30 border-t-white rounded-full animate-spin"
                            }
                          },
                          {
                            "type": "basic",
                            "name": "Span",
                            "if": "{{!_local.isSubmitting}}",
                            "text": "$t:auth.forgot_password.submit"
                          },
                          {
                            "type": "basic",
                            "name": "Span",
                            "if": "{{_local.isSubmitting}}",
                            "text": "$t:auth.forgot_password.processing"
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "basic",
                    "name": "Div",
                    "props": {
                      "className": "mt-6 text-center"
                    },
                    "children": [
                      {
                        "type": "basic",
                        "name": "Button",
                        "props": {
                          "className": "text-sm text-primary-600 dark:text-primary-400 hover:underline cursor-pointer"
                        },
                        "actions": [
                          {
                            "type": "click",
                            "handler": "navigate",
                            "params": {
                              "path": "/login"
                            }
                          }
                        ],
                        "text": "$t:auth.forgot_password.back_to_login"
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
