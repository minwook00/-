{
  "version": "1.0.0",
  "layout_name": "board/boards",
  "permissions": [],
  "extends": "_user_base",
  "meta": {
    "seo": {
      "enabled": true,
      "extensions": [
        {
          "type": "module",
          "id": "sirsoft-board"
        }
      ],
      "data_sources": [
        "boardList"
      ],
      "page_type": "boards",
      "toggle_setting": "$module_settings:sirsoft-board:seo.seo_boards",
      "vars": {
        "site_name": "$core_settings:general.site_name"
      },
      "priority": 0.5,
      "changefreq": "weekly",
      "og": {
        "type": "website"
      },
      "structured_data": {
        "@type": "ItemList"
      }
    }
  },
  "data_sources": [
    {
      "id": "boardList",
      "type": "api",
      "endpoint": "/api/modules/sirsoft-board/boards",
      "method": "GET",
      "auto_fetch": true,
      "auth_mode": "optional",
      "refetchOnMount": true,
      "errorHandling": {
        "403": {
          "handler": "showErrorPage",
          "params": {
            "target": "content"
          }
        }
      }
    }
  ],
  "slots": {
    "content": [
      {
        "type": "layout",
        "name": "Container",
        "props": {
          "className": "py-8"
        },
        "responsive": {
          "portable": {
            "props": {
              "className": "py-4"
            }
          }
        },
        "children": [
          {
            "type": "basic",
            "name": "Div",
            "props": {
              "className": "mb-6"
            },
            "responsive": {
              "portable": {
                "props": {
                  "className": "mb-4"
                }
              }
            },
            "children": [
              {
                "type": "basic",
                "name": "Div",
                "props": {
                  "className": "flex items-center gap-2 mb-2"
                },
                "children": [
                  {
                    "type": "basic",
                    "name": "Icon",
                    "props": {
                      "name": "table-cells-large",
                      "size": "xl",
                      "className": "text-slate-900 dark:text-white"
                    },
                    "responsive": {
                      "portable": {
                        "props": {
                          "name": "table-cells-large",
                          "size": "lg",
                          "className": "text-slate-900 dark:text-white"
                        }
                      }
                    }
                  },
                  {
                    "type": "basic",
                    "name": "H1",
                    "props": {
                      "className": "text-2xl font-bold text-slate-900 dark:text-white"
                    },
                    "text": "$t:board.all_boards.title",
                    "responsive": {
                      "portable": {
                        "props": {
                          "className": "text-xl font-bold text-slate-900 dark:text-white"
                        }
                      }
                    }
                  }
                ]
              },
              {
                "type": "basic",
                "name": "P",
                "props": {
                  "className": "text-slate-600 dark:text-slate-400"
                },
                "text": "$t:board.all_boards.description"
              }
            ]
          },
          {
            "type": "basic",
            "name": "Div",
            "props": {
              "className": "grid grid-cols-2 gap-4"
            },
            "responsive": {
              "portable": {
                "props": {
                  "className": "grid grid-cols-1 gap-3"
                }
              }
            },
            "children": [
              {
                "type": "basic",
                "name": "Div",
                "iteration": {
                  "source": "{{boardList.data ?? []}}",
                  "item_var": "board",
                  "index_var": "index"
                },
                "children": [
                  {
                    "partial": "partials/board/boards/_board_card.json"
                  }
                ]
              }
            ]
          },
          {
            "type": "basic",
            "name": "Div",
            "if": "{{!boardList.data || boardList.data.length === 0}}",
            "props": {
              "className": "text-center py-12"
            },
            "children": [
              {
                "type": "basic",
                "name": "Icon",
                "props": {
                  "name": "inbox",
                  "size": "3x",
                  "className": "text-slate-400 dark:text-slate-500 mx-auto mb-4"
                }
              },
              {
                "type": "basic",
                "name": "P",
                "props": {
                  "className": "text-slate-500 dark:text-slate-400"
                },
                "text": "$t:board.all_boards.empty"
              }
            ]
          }
        ]
      }
    ]
  }
}
