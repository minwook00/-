{
  "version": "1.0.0",
  "layout_name": "maintenance",
  "extends": "_user_base",
  "meta": {
    "title": "$t:error.maintenance.title",
    "is_error_layout": true
  },
  "slots": {
    "content": [
      {
        "type": "basic",
        "name": "Div",
        "props": {
          "className": "min-h-[60vh] flex items-center justify-center"
        },
        "children": [
          {
            "type": "basic",
            "name": "Div",
            "props": {
              "className": "text-center px-4 max-w-lg"
            },
            "children": [
              {
                "type": "basic",
                "name": "Icon",
                "props": {
                  "name": "gear",
                  "className": "w-24 h-24 mx-auto text-primary-400 dark:text-primary-500 mb-6 animate-spin"
                }
              },
              {
                "type": "basic",
                "name": "H1",
                "props": {
                  "className": "text-2xl font-bold text-slate-900 dark:text-white mb-4"
                },
                "text": "$t:error.maintenance.title"
              },
              {
                "type": "basic",
                "name": "P",
                "props": {
                  "className": "text-slate-600 dark:text-slate-400 mb-8"
                },
                "text": "$t:error.maintenance.description"
              },
              {
                "type": "basic",
                "name": "Button",
                "props": {
                  "className": "inline-flex items-center gap-2 px-6 py-3 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors cursor-pointer"
                },
                "actions": [
                  {
                    "type": "click",
                    "handler": "navigate",
                    "params": {
                      "path": "/"
                    }
                  }
                ],
                "children": [
                  {
                    "type": "basic",
                    "name": "Icon",
                    "props": {
                      "name": "home",
                      "className": "w-5 h-5"
                    }
                  },
                  {
                    "type": "basic",
                    "name": "Span",
                    "text": "$t:error.maintenance.back_to_home"
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
