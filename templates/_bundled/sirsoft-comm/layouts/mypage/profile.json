{
  "version": "1.0.0",
  "layout_name": "mypage/profile",
  "extends": "_user_base",
  "permissions": [],
  "transition_overlay": {
    "enabled": true,
    "style": "spinner",
    "target": "mypage_tab_content",
    "fallback_target": "main_content_area",
    "spinner": {
      "component": "PageLoading"
    }
  },
  "computed": {
    "currentTab": "profile"
  },
  "data_sources": [
    {
      "id": "user",
      "type": "api",
      "endpoint": "/api/me",
      "method": "GET",
      "auto_fetch": true,
      "auth_required": true,
      "loading_strategy": "progressive",
      "initLocal": "profileEditForm"
    }
  ],
  "slots": {
    "content": [
      {
        "type": "basic",
        "name": "Div",
        "props": {
          "className": "min-h-screen bg-slate-50 dark:bg-slate-900"
        },
        "children": [
          {
            "type": "layout",
            "name": "Container",
            "props": {
              "className": "py-8"
            },
            "responsive": {
              "portable": {
                "props": {
                  "className": "py-4"
                }
              }
            },
            "children": [
              {
                "type": "basic",
                "name": "Div",
                "props": {
                  "className": "flex items-center gap-2 mb-6"
                },
                "children": [
                  {
                    "type": "basic",
                    "name": "Icon",
                    "props": {
                      "name": "user",
                      "size": "xl",
                      "className": "text-slate-900 dark:text-white"
                    }
                  },
                  {
                    "type": "basic",
                    "name": "H1",
                    "props": {
                      "className": "text-2xl font-bold text-slate-900 dark:text-white"
                    },
                    "text": "$t:mypage.title"
                  }
                ]
              },
              {
                "partial": "partials/mypage/_tab_navigation.json"
              },
              {
                "type": "basic",
                "name": "Div",
                "id": "mypage_tab_content",
                "children": [
                  {
                    "partial": "partials/mypage/profile/_view.json"
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  "modals": [
    {
      "partial": "partials/mypage/profile/_modal_withdraw.json"
    }
  ]
}
