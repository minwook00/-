{
    "version": "1.0.0",
    "layout_name": "admin_activity_log_list",
    "permissions": [
        "core.activities.read"
    ],
    "extends": "_admin_base",
    "meta": {
        "title": "$t:admin.activity_log.page_title"
    },
    "transition_overlay": {
        "wait_for": [
            "activityLogs"
        ]
    },
    "state": {
        "filter": {
            "searchType": "all",
            "search": "",
            "logTypes": [],
            "createdBy": "",
            "dateQuick": "",
            "dateFrom": "",
            "dateTo": ""
        },
        "actorSearchResults": []
    },
    "data_sources": [
        {
            "id": "activityLogs",
            "type": "api",
            "endpoint": "/api/admin/activity-logs",
            "method": "GET",
            "auto_fetch": true,
            "auth_required": true,
            "loading_strategy": "progressive",
            "params": {
                "page": "{{query.page || 1}}",
                "per_page": "{{query.per_page || 20}}",
                "search": "{{query.search}}",
                "search_type": "{{query.search_type}}",
                "log_type[]": "{{query['log_type[]']}}",
                "created_by": "{{query.created_by}}",
                "date_from": "{{query.date_from}}",
                "date_to": "{{query.date_to}}",
                "sort_by": "{{query.sort_by || 'created_at'}}",
                "sort_order": "{{query.sort_order || 'desc'}}"
            },
            "errorHandling": {
                "403": {
                    "handler": "showErrorPage",
                    "params": {
                        "target": "content"
                    }
                }
            }
        }
    ],
    "init_actions": [
        {
            "handler": "setState",
            "params": {
                "target": "global",
                "_local": {
                    "filter": {
                        "searchType": "{{query.search_type || 'all'}}",
                        "search": "{{query.search || ''}}",
                        "logTypes": "{{query['log_type[]'] || []}}",
                        "createdBy": "{{query.created_by || ''}}",
                        "dateQuick": "",
                        "dateFrom": "{{query.date_from || ''}}",
                        "dateTo": "{{query.date_to || ''}}"
                    }
                }
            }
        }
    ],
    "named_actions": {
        "searchActivityLogs": {
            "handler": "navigate",
            "params": {
                "path": "/admin/activity-logs",
                "replace": true,
                "query": {
                    "page": 1,
                    "search": "{{_local.filter.search || undefined}}",
                    "search_type": "{{_local.filter.searchType !== 'all' ? _local.filter.searchType : undefined}}",
                    "log_type[]": "{{_local.filter.logTypes?.length > 0 ? _local.filter.logTypes : undefined}}",
                    "created_by": "{{_local.filter.createdBy || undefined}}",
                    "date_from": "{{_local.filter.dateFrom || undefined}}",
                    "date_to": "{{_local.filter.dateTo || undefined}}"
                },
                "transition_overlay_target": "activity_log_datagrid__body"
            }
        }
    },
    "slots": {
        "content": [
            {
                "id": "activity_log_list_content",
                "type": "basic",
                "name": "Div",
                "props": {
                    "className": "p-6 bg-gray-50 dark:bg-gray-900 min-h-screen"
                },
                "children": [
                    {
                        "id": "page_header",
                        "type": "basic",
                        "name": "Div",
                        "props": {
                            "className": "flex items-center justify-between mb-6"
                        },
                        "children": [
                            {
                                "type": "basic",
                                "name": "Div",
                                "children": [
                                    {
                                        "type": "basic",
                                        "name": "H1",
                                        "props": {
                                            "className": "page-title"
                                        },
                                        "text": "$t:admin.activity_log.page_title"
                                    },
                                    {
                                        "type": "basic",
                                        "name": "P",
                                        "props": {
                                            "className": "text-sm text-gray-500 dark:text-gray-400 mt-1"
                                        },
                                        "text": "$t:admin.activity_log.page_description"
                                    }
                                ]
                            },
                            {
                                "id": "refresh_button",
                                "type": "basic",
                                "name": "Button",
                                "props": {
                                    "className": "p-2 text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg transition-colors"
                                },
                                "actions": [
                                    {
                                        "type": "click",
                                        "handler": "navigate",
                                        "params": {
                                            "path": "/admin/activity-logs",
                                            "mergeQuery": false
                                        }
                                    }
                                ],
                                "children": [
                                    {
                                        "type": "basic",
                                        "name": "Icon",
                                        "props": {
                                            "name": "refresh",
                                            "className": "w-5 h-5"
                                        }
                                    }
                                ]
                            }
                        ]
                    },
                    {
                        "partial": "partials/admin_activity_log_list/_partial_filter.json"
                    },
                    {
                        "id": "data_table_section",
                        "type": "basic",
                        "name": "Div",
                        "props": {
                            "className": "mt-6"
                        },
                        "children": [
                            {
                                "id": "table_header_bar",
                                "type": "basic",
                                "name": "Div",
                                "props": {
                                    "className": "flex flex-wrap items-center justify-between gap-3 mb-4"
                                },
                                "children": [
                                    {
                                        "type": "basic",
                                        "name": "Div",
                                        "props": {
                                            "className": "flex items-center gap-3"
                                        },
                                        "children": [
                                            {
                                                "type": "basic",
                                                "name": "Span",
                                                "props": {
                                                    "className": "text-sm text-gray-600 dark:text-gray-400"
                                                },
                                                "text": "$t:admin.activity_log.pagination.total|count={{activityLogs?.data?.pagination?.total || 0}}"
                                            }
                                        ]
                                    },
                                    {
                                        "type": "basic",
                                        "name": "Div",
                                        "props": {
                                            "className": "flex items-center gap-3"
                                        },
                                        "children": [
                                            {
                                                "type": "composite",
                                                "name": "Select",
                                                "props": {
                                                    "name": "sortBy",
                                                    "className": "w-32 px-3 py-2 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg text-sm",
                                                    "value": "{{query.sort_order === 'asc' ? 'created_at_asc' : 'created_at_desc'}}",
                                                    "options": [
                                                        {
                                                            "value": "created_at_desc",
                                                            "label": "$t:admin.activity_log.sort.created_at_desc"
                                                        },
                                                        {
                                                            "value": "created_at_asc",
                                                            "label": "$t:admin.activity_log.sort.created_at_asc"
                                                        }
                                                    ]
                                                },
                                                "actions": [
                                                    {
                                                        "type": "change",
                                                        "handler": "navigate",
                                                        "params": {
                                                            "path": "/admin/activity-logs",
                                                            "replace": true,
                                                            "mergeQuery": true,
                                                            "query": {
                                                                "sort_by": "created_at",
                                                                "sort_order": "{{$event.target.value.split('_').pop()}}",
                                                                "page": 1
                                                            },
                                                            "transition_overlay_target": "activity_log_datagrid__body"
                                                        }
                                                    }
                                                ]
                                            },
                                            {
                                                "type": "composite",
                                                "name": "Select",
                                                "props": {
                                                    "name": "perPage",
                                                    "className": "w-20 px-3 py-2 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg text-sm",
                                                    "value": "{{query.per_page || '20'}}",
                                                    "options": [
                                                        {
                                                            "value": "10",
                                                            "label": "10"
                                                        },
                                                        {
                                                            "value": "20",
                                                            "label": "20"
                                                        },
                                                        {
                                                            "value": "50",
                                                            "label": "50"
                                                        },
                                                        {
                                                            "value": "100",
                                                            "label": "100"
                                                        }
                                                    ]
                                                },
                                                "actions": [
                                                    {
                                                        "type": "change",
                                                        "handler": "navigate",
                                                        "params": {
                                                            "path": "/admin/activity-logs",
                                                            "replace": true,
                                                            "mergeQuery": true,
                                                            "query": {
                                                                "per_page": "{{$event.target.value}}",
                                                                "page": 1
                                                            },
                                                            "transition_overlay_target": "activity_log_datagrid__body"
                                                        }
                                                    }
                                                ]
                                            }
                                        ]
                                    }
                                ]
                            },
                            {
                                "id": "bulk_action_bar",
                                "type": "basic",
                                "name": "Div",
                                "props": {
                                    "className": "bg-gray-100 dark:bg-gray-700/50 border border-gray-200 dark:border-gray-600 rounded-lg p-3 mb-4 flex flex-wrap items-center gap-3"
                                },
                                "children": [
                                    {
                                        "type": "basic",
                                        "name": "Span",
                                        "props": {
                                            "className": "text-sm font-medium text-gray-700 dark:text-gray-300 whitespace-nowrap"
                                        },
                                        "text": "$t:admin.activity_log.delete.selected_count|count={{(_global.selectedIds_admin_activity_logs ?? []).length}}"
                                    },
                                    {
                                        "type": "basic",
                                        "name": "Div",
                                        "props": {
                                            "className": "flex-1"
                                        }
                                    },
                                    {
                                        "id": "bulk_delete_button",
                                        "type": "basic",
                                        "name": "Button",
                                        "props": {
                                            "type": "button",
                                            "className": "px-3 py-1.5 text-sm font-medium text-red-600 dark:text-red-400 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg hover:bg-red-100 dark:hover:bg-red-900/30 disabled:opacity-50 disabled:cursor-not-allowed transition-colors",
                                            "disabled": "{{(_global.selectedIds_admin_activity_logs ?? []).length === 0 || activityLogs?.data?.abilities?.can_delete !== true}}"
                                        },
                                        "text": "$t:admin.activity_log.delete.bulk_button",
                                        "actions": [
                                            {
                                                "type": "click",
                                                "handler": "openModal",
                                                "target": "bulk_delete_confirm_modal"
                                            }
                                        ]
                                    }
                                ]
                            },
                            {
                                "partial": "partials/admin_activity_log_list/_partial_datagrid.json"
                            }
                        ]
                    }
                ]
            }
        ]
    },
    "modals": [
        {
            "id": "delete_confirm_modal",
            "type": "composite",
            "name": "Modal",
            "props": {
                "title": "$t:admin.activity_log.delete.confirm_title",
                "size": "sm"
            },
            "children": [
                {
                    "type": "basic",
                    "name": "Div",
                    "props": {
                        "className": "py-2"
                    },
                    "children": [
                        {
                            "type": "basic",
                            "name": "P",
                            "props": {
                                "className": "text-gray-700 dark:text-gray-300"
                            },
                            "text": "$t:admin.activity_log.delete.confirm_message"
                        }
                    ]
                },
                {
                    "type": "basic",
                    "name": "Div",
                    "props": {
                        "className": "flex justify-end gap-3 mt-6"
                    },
                    "children": [
                        {
                            "type": "basic",
                            "name": "Button",
                            "props": {
                                "type": "button",
                                "className": "px-4 py-2 bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 disabled:opacity-50 disabled:cursor-not-allowed",
                                "disabled": "{{_global.isDeleting}}"
                            },
                            "actions": [
                                {
                                    "type": "click",
                                    "handler": "closeModal"
                                }
                            ],
                            "children": [
                                {
                                    "type": "basic",
                                    "name": "Span",
                                    "text": "$t:common.cancel"
                                }
                            ]
                        },
                        {
                            "type": "basic",
                            "name": "Button",
                            "props": {
                                "type": "button",
                                "className": "flex items-center gap-2 px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 disabled:opacity-50 disabled:cursor-not-allowed",
                                "disabled": "{{_global.isDeleting}}"
                            },
                            "actions": [
                                {
                                    "type": "click",
                                    "handler": "sequence",
                                    "actions": [
                                        {
                                            "handler": "setState",
                                            "params": {
                                                "target": "global",
                                                "isDeleting": true
                                            }
                                        },
                                        {
                                            "handler": "apiCall",
                                            "auth_required": true,
                                            "target": "/api/admin/activity-logs/{{_global.modal_data.id}}",
                                            "params": {
                                                "method": "DELETE"
                                            },
                                            "onSuccess": [
                                                {
                                                    "handler": "setState",
                                                    "params": {
                                                        "target": "global",
                                                        "isDeleting": false
                                                    }
                                                },
                                                {
                                                    "handler": "refetchDataSource",
                                                    "params": {
                                                        "dataSourceId": "activityLogs"
                                                    }
                                                },
                                                {
                                                    "handler": "toast",
                                                    "params": {
                                                        "type": "success",
                                                        "message": "$t:admin.activity_log.delete.success"
                                                    }
                                                },
                                                {
                                                    "handler": "closeModal"
                                                }
                                            ],
                                            "onError": [
                                                {
                                                    "handler": "setState",
                                                    "params": {
                                                        "target": "global",
                                                        "isDeleting": false
                                                    }
                                                },
                                                {
                                                    "handler": "toast",
                                                    "params": {
                                                        "type": "error",
                                                        "message": "{{error.message}}"
                                                    }
                                                }
                                            ],
                                            "errorHandling": {
                                                "403": {
                                                    "handler": "sequence",
                                                    "params": {
                                                        "actions": [
                                                            {
                                                                "handler": "setState",
                                                                "params": {
                                                                    "target": "global",
                                                                    "isDeleting": false
                                                                }
                                                            },
                                                            {
                                                                "handler": "toast",
                                                                "params": {
                                                                    "type": "error",
                                                                    "message": "$t:auth.permission_denied"
                                                                }
                                                            }
                                                        ]
                                                    }
                                                }
                                            }
                                        }
                                    ]
                                }
                            ],
                            "children": [
                                {
                                    "type": "basic",
                                    "name": "Icon",
                                    "if": "{{_global.isDeleting}}",
                                    "props": {
                                        "name": "spinner",
                                        "spin": true,
                                        "className": "text-sm"
                                    }
                                },
                                {
                                    "type": "basic",
                                    "name": "Span",
                                    "text": "$t:common.delete"
                                }
                            ]
                        }
                    ]
                }
            ]
        },
        {
            "id": "bulk_delete_confirm_modal",
            "type": "composite",
            "name": "Modal",
            "props": {
                "title": "$t:admin.activity_log.delete.bulk_confirm_title",
                "size": "sm"
            },
            "children": [
                {
                    "type": "basic",
                    "name": "Div",
                    "props": {
                        "className": "py-2"
                    },
                    "children": [
                        {
                            "type": "basic",
                            "name": "P",
                            "props": {
                                "className": "text-gray-700 dark:text-gray-300"
                            },
                            "text": "$t:admin.activity_log.delete.bulk_confirm_message"
                        }
                    ]
                },
                {
                    "type": "basic",
                    "name": "Div",
                    "props": {
                        "className": "flex justify-end gap-3 mt-6"
                    },
                    "children": [
                        {
                            "type": "basic",
                            "name": "Button",
                            "props": {
                                "type": "button",
                                "className": "px-4 py-2 bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 disabled:opacity-50 disabled:cursor-not-allowed",
                                "disabled": "{{_global.isDeleting}}"
                            },
                            "actions": [
                                {
                                    "type": "click",
                                    "handler": "closeModal"
                                }
                            ],
                            "children": [
                                {
                                    "type": "basic",
                                    "name": "Span",
                                    "text": "$t:common.cancel"
                                }
                            ]
                        },
                        {
                            "type": "basic",
                            "name": "Button",
                            "props": {
                                "type": "button",
                                "className": "flex items-center gap-2 px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 disabled:opacity-50 disabled:cursor-not-allowed",
                                "disabled": "{{_global.isDeleting}}"
                            },
                            "actions": [
                                {
                                    "type": "click",
                                    "handler": "sequence",
                                    "actions": [
                                        {
                                            "handler": "setState",
                                            "params": {
                                                "target": "global",
                                                "isDeleting": true
                                            }
                                        },
                                        {
                                            "handler": "apiCall",
                                            "auth_required": true,
                                            "target": "/api/admin/activity-logs/bulk-delete",
                                            "params": {
                                                "method": "POST",
                                                "body": {
                                                    "ids": "{{_global.selectedIds_admin_activity_logs ?? []}}"
                                                }
                                            },
                                            "onSuccess": [
                                                {
                                                    "handler": "setState",
                                                    "params": {
                                                        "target": "global",
                                                        "isDeleting": false,
                                                        "selectedIds_admin_activity_logs": []
                                                    }
                                                },
                                                {
                                                    "handler": "refetchDataSource",
                                                    "params": {
                                                        "dataSourceId": "activityLogs"
                                                    }
                                                },
                                                {
                                                    "handler": "toast",
                                                    "params": {
                                                        "type": "success",
                                                        "message": "$t:admin.activity_log.delete.bulk_success"
                                                    }
                                                },
                                                {
                                                    "handler": "closeModal"
                                                }
                                            ],
                                            "onError": [
                                                {
                                                    "handler": "setState",
                                                    "params": {
                                                        "target": "global",
                                                        "isDeleting": false
                                                    }
                                                },
                                                {
                                                    "handler": "toast",
                                                    "params": {
                                                        "type": "error",
                                                        "message": "{{error.message}}"
                                                    }
                                                }
                                            ],
                                            "errorHandling": {
                                                "403": {
                                                    "handler": "sequence",
                                                    "params": {
                                                        "actions": [
                                                            {
                                                                "handler": "setState",
                                                                "params": {
                                                                    "target": "global",
                                                                    "isDeleting": false
                                                                }
                                                            },
                                                            {
                                                                "handler": "toast",
                                                                "params": {
                                                                    "type": "error",
                                                                    "message": "$t:auth.permission_denied"
                                                                }
                                                            }
                                                        ]
                                                    }
                                                }
                                            }
                                        }
                                    ]
                                }
                            ],
                            "children": [
                                {
                                    "type": "basic",
                                    "name": "Icon",
                                    "if": "{{_global.isDeleting}}",
                                    "props": {
                                        "name": "spinner",
                                        "spin": true,
                                        "className": "text-sm"
                                    }
                                },
                                {
                                    "type": "basic",
                                    "name": "Span",
                                    "text": "$t:common.delete"
                                }
                            ]
                        }
                    ]
                }
            ]
        }
    ]
}
