{
  "layout_name": "panel_detail",
  "id": "detail_panel",
  "type": "basic",
  "name": "Div",
  "props": {
    "className": "bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700"
  },
  "children": [
    {
      "id": "empty_state_panel",
      "type": "composite",
      "name": "EmptyState",
      "if": "{{!_global.selectedMenuId && _global.panelMode !== 'create'}}",
      "props": {
        "icon": "bars",
        "title": "$t:admin.menus.select_menu_hint",
        "className": "py-16"
      }
    },
    { "partial": "_panel_view.json" },
    { "partial": "_panel_form.json" }
  ]
}
