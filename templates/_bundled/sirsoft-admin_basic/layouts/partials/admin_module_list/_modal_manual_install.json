{
  "meta": {
    "is_partial": true,
    "description": "모듈 수동 설치 모달"
  },
  "id": "module_manual_install_modal",
  "type": "composite",
  "name": "Modal",
  "props": {
    "title": "$t:admin.modules.modals.manual_install_title",
    "size": "medium"
  },
  "children": [
    {
      "type": "basic",
      "name": "P",
      "props": {
        "className": "text-gray-600 dark:text-gray-400 mb-4"
      },
      "text": "$t:admin.modules.modals.manual_install_description"
    },
    {
      "type": "basic",
      "name": "Div",
      "if": "{{_global.moduleInstallError}}",
      "props": {
        "className": "bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg p-4 mb-4"
      },
      "children": [
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "flex items-start gap-3"
          },
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "props": {
                "name": "triangle-exclamation",
                "className": "text-red-500 mt-0.5",
                "size": "sm"
              }
            },
            {
              "type": "basic",
              "name": "Div",
              "children": [
                {
                  "type": "basic",
                  "name": "P",
                  "props": {
                    "className": "text-sm font-medium text-red-800 dark:text-red-200"
                  },
                  "text": "{{_global.moduleInstallError}}"
                },
                {
                  "type": "basic",
                  "name": "P",
                  "if": "{{_global.moduleInstallErrors?.error}}",
                  "props": {
                    "className": "text-sm text-red-700 dark:text-red-300 mt-1 whitespace-pre-line"
                  },
                  "text": "{{_global.moduleInstallErrors.error}}"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "module_install_tabs",
      "type": "composite",
      "name": "TabNavigation",
      "props": {
        "tabs": [
          {
            "id": "file_upload",
            "label": "$t:admin.modules.tabs.file_upload",
            "iconName": "upload"
          },
          {
            "id": "github",
            "label": "$t:admin.modules.tabs.github",
            "iconName": "code-branch"
          }
        ],
        "activeTabId": "{{_global.moduleInstallTab || 'file_upload'}}",
        "variant": "underline"
      },
      "actions": [
        {
          "event": "onTabChange",
          "type": "change",
          "handler": "setState",
          "params": {
            "target": "global",
            "moduleInstallTab": "{{$args[0]}}",
            "moduleInstallError": null,
            "moduleInstallErrors": null
          }
        }
      ]
    },
    {
      "id": "module_file_upload_tab",
      "type": "basic",
      "name": "Div",
      "if": "{{!_global.moduleInstallTab || _global.moduleInstallTab === 'file_upload'}}",
      "props": {
        "className": "mt-4 space-y-4"
      },
      "children": [
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "space-y-2"
          },
          "children": [
            {
              "type": "basic",
              "name": "Label",
              "props": {
                "className": "block text-sm font-medium text-gray-700 dark:text-gray-300"
              },
              "text": "$t:admin.modules.tabs.file_label"
            },
            {
              "type": "basic",
              "name": "FileInput",
              "props": {
                "accept": ".zip",
                "className": "{{_global.moduleInstallErrors?.file ? 'w-full border-red-500 dark:border-red-500' : 'w-full'}}",
                "buttonText": "$t:common.browse",
                "placeholder": "$t:admin.modules.tabs.no_file_selected"
              },
              "actions": [
                {
                  "type": "change",
                  "handler": "setState",
                  "params": {
                    "target": "global",
                    "moduleUploadFile": "{{$event.target.value}}",
                    "moduleUploadFileName": "{{$event.target.value?.name}}",
                    "moduleInstallError": null,
                    "moduleInstallErrors": null
                  }
                }
              ]
            },
            {
              "type": "basic",
              "name": "Span",
              "if": "{{_global.moduleInstallErrors?.file}}",
              "props": {
                "className": "text-red-500 dark:text-red-400 text-xs mt-1"
              },
              "text": "{{Array.isArray(_global.moduleInstallErrors?.file) ? _global.moduleInstallErrors.file[0] : _global.moduleInstallErrors?.file}}"
            }
          ]
        },
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "p-3 bg-blue-50 dark:bg-blue-900/20 rounded-lg"
          },
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex items-start gap-2"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Icon",
                  "props": {
                    "name": "info-circle",
                    "className": "text-blue-500 mt-0.5",
                    "size": "sm"
                  }
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "children": [
                    {
                      "type": "basic",
                      "name": "P",
                      "props": {
                        "className": "text-sm text-blue-700 dark:text-blue-300"
                      },
                      "text": "$t:admin.modules.tabs.file_requirements"
                    },
                    {
                      "type": "basic",
                      "name": "P",
                      "props": {
                        "className": "mt-1 text-sm font-mono text-blue-600 dark:text-blue-400 bg-blue-100 dark:bg-blue-900/40 px-2 py-1 rounded inline-block"
                      },
                      "text": "module.json"
                    },
                    {
                      "type": "basic",
                      "name": "P",
                      "props": {
                        "className": "mt-1 text-sm text-blue-700 dark:text-blue-300"
                      },
                      "text": "$t:admin.modules.tabs.file_structure_hint"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "module_github_tab",
      "type": "basic",
      "name": "Div",
      "if": "{{_global.moduleInstallTab === 'github'}}",
      "props": {
        "className": "mt-4 space-y-4"
      },
      "children": [
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "space-y-2"
          },
          "children": [
            {
              "type": "basic",
              "name": "Label",
              "props": {
                "className": "block text-sm font-medium text-gray-700 dark:text-gray-300"
              },
              "text": "$t:admin.modules.tabs.github_url_label"
            },
            {
              "type": "basic",
              "name": "Input",
              "props": {
                "type": "url",
                "placeholder": "https://github.com/username/module-name",
                "value": "{{_global.moduleGithubUrl ?? ''}}",
                "className": "{{_global.moduleInstallErrors?.github_url ? 'w-full px-3 py-2 border border-red-500 dark:border-red-500 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white' : 'w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white'}}"
              },
              "actions": [
                {
                  "type": "change",
                  "handler": "setState",
                  "params": {
                    "target": "global",
                    "moduleGithubUrl": "{{$event.target.value}}",
                    "moduleInstallError": null,
                    "moduleInstallErrors": null
                  }
                }
              ]
            },
            {
              "type": "basic",
              "name": "Span",
              "if": "{{_global.moduleInstallErrors?.github_url}}",
              "props": {
                "className": "text-red-500 dark:text-red-400 text-xs mt-1"
              },
              "text": "{{Array.isArray(_global.moduleInstallErrors?.github_url) ? _global.moduleInstallErrors.github_url[0] : _global.moduleInstallErrors?.github_url}}"
            },
            {
              "type": "basic",
              "name": "P",
              "props": {
                "className": "text-xs text-gray-500 dark:text-gray-400"
              },
              "text": "$t:admin.modules.tabs.github_url_hint"
            }
          ]
        },
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "p-3 bg-blue-50 dark:bg-blue-900/20 rounded-lg"
          },
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex items-start gap-2"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Icon",
                  "props": {
                    "name": "info-circle",
                    "className": "text-blue-500 mt-0.5",
                    "size": "sm"
                  }
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "children": [
                    {
                      "type": "basic",
                      "name": "P",
                      "props": {
                        "className": "text-sm text-blue-700 dark:text-blue-300"
                      },
                      "text": "$t:admin.modules.tabs.github_requirements"
                    },
                    {
                      "type": "basic",
                      "name": "P",
                      "props": {
                        "className": "mt-1 text-sm font-mono text-blue-600 dark:text-blue-400 bg-blue-100 dark:bg-blue-900/40 px-2 py-1 rounded inline-block"
                      },
                      "text": "module.json"
                    },
                    {
                      "type": "basic",
                      "name": "P",
                      "props": {
                        "className": "mt-1 text-sm text-blue-700 dark:text-blue-300"
                      },
                      "text": "$t:admin.modules.tabs.github_public_only"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "flex justify-end gap-3 mt-6"
      },
      "children": [
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "type": "button",
            "className": "px-4 py-2 bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 disabled:opacity-50 disabled:cursor-not-allowed",
            "disabled": "{{_global.isModuleManualInstalling}}"
          },
          "actions": [
            {
              "type": "click",
              "handler": "sequence",
              "actions": [
                {
                  "handler": "setState",
                  "params": {
                    "target": "global",
                    "moduleUploadFile": null,
                    "moduleUploadFileName": null,
                    "moduleGithubUrl": null,
                    "moduleInstallError": null,
                    "moduleInstallErrors": null,
                    "moduleInstallTab": "file_upload"
                  }
                },
                {
                  "handler": "closeModal"
                }
              ]
            }
          ],
          "children": [
            {
              "type": "basic",
              "name": "Span",
              "text": "$t:common.cancel"
            }
          ]
        },
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "type": "button",
            "className": "flex items-center gap-2 px-4 py-2 bg-gray-900 dark:bg-white text-white dark:text-gray-900 rounded-lg hover:bg-gray-800 dark:hover:bg-gray-100 disabled:opacity-50 disabled:cursor-not-allowed",
            "disabled": "{{_global.isModuleManualInstalling || ((!_global.moduleInstallTab || _global.moduleInstallTab === 'file_upload') ? !_global.moduleUploadFile : !_global.moduleGithubUrl)}}"
          },
          "actions": [
            {
              "type": "click",
              "handler": "sequence",
              "actions": [
                {
                  "handler": "setState",
                  "params": {
                    "target": "global",
                    "isModuleManualInstalling": true,
                    "moduleInstallError": null,
                    "moduleInstallErrors": null
                  }
                },
                {
                  "handler": "apiCall",
                  "auth_required": true,
                  "target": "{{(!_global.moduleInstallTab || _global.moduleInstallTab === 'file_upload') ? '/api/admin/modules/install-from-file' : '/api/admin/modules/install-from-github'}}",
                  "params": {
                    "method": "POST",
                    "contentType": "{{(!_global.moduleInstallTab || _global.moduleInstallTab === 'file_upload') ? 'multipart/form-data' : 'application/json'}}",
                    "body": "{{(!_global.moduleInstallTab || _global.moduleInstallTab === 'file_upload') ? { file: _global.moduleUploadFile } : { github_url: _global.moduleGithubUrl }}}"
                  },
                  "onSuccess": [
                    {
                      "handler": "setState",
                      "params": {
                        "target": "global",
                        "isModuleManualInstalling": false,
                        "moduleUploadFile": null,
                        "moduleUploadFileName": null,
                        "moduleGithubUrl": null,
                        "moduleInstallError": null,
                        "moduleInstallErrors": null,
                        "moduleInstallTab": "file_upload"
                      }
                    },
                    {
                      "handler": "toast",
                      "params": {
                        "type": "success",
                        "message": "$t:admin.modules.install_success"
                      }
                    },
                    {
                      "handler": "refetchDataSource",
                      "params": {
                        "dataSourceId": "modules"
                      }
                    },
                    {
                      "handler": "refetchDataSource",
                      "params": {
                        "dataSourceId": "admin_menu"
                      }
                    },
                    {
                      "handler": "reloadExtensions"
                    },
                    {
                      "handler": "closeModal"
                    }
                  ],
                  "onError": [
                    {
                      "handler": "setState",
                      "params": {
                        "target": "global",
                        "isModuleManualInstalling": false,
                        "moduleInstallError": "{{error.message}}",
                        "moduleInstallErrors": "{{error.errors}}"
                      }
                    }
                  ]
                }
              ]
            }
          ],
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "if": "{{!_global.isModuleManualInstalling}}",
              "props": {
                "name": "download",
                "size": "sm"
              }
            },
            {
              "type": "basic",
              "name": "Icon",
              "if": "{{_global.isModuleManualInstalling}}",
              "props": {
                "name": "spinner",
                "className": "animate-spin",
                "size": "sm"
              }
            },
            {
              "type": "basic",
              "name": "Span",
              "text": "{{_global.isModuleManualInstalling ? '$t:admin.modules.installing' : '$t:admin.modules.actions.install'}}"
            }
          ]
        }
      ]
    }
  ]
}
