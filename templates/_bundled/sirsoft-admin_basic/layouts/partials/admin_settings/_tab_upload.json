{
  "meta": {
    "is_partial": true,
    "description": "환경설정 업로드 탭 콘텐츠"
  },
  "id": "tab_content_upload",
  "type": "basic",
  "name": "Div",
  "if": "{{(_global.activeSettingsTab || query.tab || 'general') === 'upload'}}",
  "props": {
    "className": "mt-6 space-y-6"
  },
  "children": [
    {
      "id": "card_upload_settings",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-6"
      },
      "children": [
        {
          "type": "basic",
          "name": "H3",
          "props": {
            "className": "text-lg font-semibold text-gray-900 dark:text-white mb-1"
          },
          "text": "$t:admin.settings.upload.file_settings"
        },
        {
          "type": "basic",
          "name": "P",
          "props": {
            "className": "text-sm text-gray-500 dark:text-gray-400 mb-6"
          },
          "text": "$t:admin.settings.upload.file_settings_desc"
        },
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "grid grid-cols-1 md:grid-cols-2 gap-4"
          },
          "children": [
            {
              "id": "field_max_file_size",
              "type": "basic",
              "name": "Div",
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Span",
                      "text": "$t:admin.settings.upload.max_file_size"
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "text-red-500 ml-1"
                      },
                      "text": "*"
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex items-center gap-2"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Input",
                      "props": {
                        "type": "number",
                        "name": "upload.max_file_size",
                        "min": "1",
                        "max": "1024",
                        "disabled": "{{_computed.isReadOnly}}",
                        "className": "{{_local.errors?.['upload.max_file_size'] ? 'flex-1 px-3 py-2 border border-red-500 dark:border-red-500 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white text-sm focus:ring-2 focus:ring-red-500 focus:border-red-500 disabled:bg-gray-100 dark:disabled:bg-gray-800 disabled:text-gray-400 dark:disabled:text-gray-500 disabled:cursor-not-allowed' : 'flex-1 px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 disabled:bg-gray-100 dark:disabled:bg-gray-800 disabled:text-gray-400 dark:disabled:text-gray-500 disabled:cursor-not-allowed'}}"
                      }
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "text-sm text-gray-500 dark:text-gray-400"
                      },
                      "text": "MB"
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "if": "{{_local.errors?.['upload.max_file_size']}}",
                  "props": {
                    "className": "text-red-500 text-xs mt-1 block"
                  },
                  "text": "{{_local.errors?.['upload.max_file_size']?.[0] ?? ''}}"
                }
              ]
            },
            {
              "id": "field_allowed_extensions",
              "type": "basic",
              "name": "Div",
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Span",
                      "text": "$t:admin.settings.upload.allowed_extensions"
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "text-red-500 ml-1"
                      },
                      "text": "*"
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Input",
                  "props": {
                    "type": "text",
                    "name": "upload.allowed_extensions",
                    "placeholder": "jpg,jpeg,png,gif,pdf,doc,docx,xls,xlsx,zip",
                    "disabled": "{{_computed.isReadOnly}}",
                    "className": "{{_local.errors?.['upload.allowed_extensions'] ? 'w-full px-3 py-2 border border-red-500 dark:border-red-500 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white text-sm focus:ring-2 focus:ring-red-500 focus:border-red-500 disabled:bg-gray-100 dark:disabled:bg-gray-800 disabled:text-gray-400 dark:disabled:text-gray-500 disabled:cursor-not-allowed' : 'w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 disabled:bg-gray-100 dark:disabled:bg-gray-800 disabled:text-gray-400 dark:disabled:text-gray-500 disabled:cursor-not-allowed'}}"
                  }
                },
                {
                  "type": "basic",
                  "name": "P",
                  "props": {
                    "className": "text-xs text-gray-500 dark:text-gray-400 mt-1"
                  },
                  "text": "$t:admin.settings.upload.allowed_extensions_hint"
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "if": "{{_local.errors?.['upload.allowed_extensions']}}",
                  "props": {
                    "className": "text-red-500 text-xs mt-1 block"
                  },
                  "text": "{{_local.errors?.['upload.allowed_extensions']?.[0] ?? ''}}"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "card_image_settings",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-6"
      },
      "children": [
        {
          "type": "basic",
          "name": "H3",
          "props": {
            "className": "text-lg font-semibold text-gray-900 dark:text-white mb-1"
          },
          "text": "$t:admin.settings.upload.image_settings"
        },
        {
          "type": "basic",
          "name": "P",
          "props": {
            "className": "text-sm text-gray-500 dark:text-gray-400 mb-6"
          },
          "text": "$t:admin.settings.upload.image_settings_desc"
        },
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "grid grid-cols-1 md:grid-cols-3 gap-4"
          },
          "children": [
            {
              "id": "field_image_max_width",
              "type": "basic",
              "name": "Div",
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1"
                  },
                  "text": "$t:admin.settings.upload.image_max_width"
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex items-center gap-2"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Input",
                      "props": {
                        "type": "number",
                        "name": "upload.image_max_width",
                        "min": "100",
                        "max": "10000",
                        "disabled": "{{_computed.isReadOnly}}",
                        "className": "flex-1 px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 disabled:bg-gray-100 dark:disabled:bg-gray-800 disabled:text-gray-400 dark:disabled:text-gray-500 disabled:cursor-not-allowed"
                      }
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "text-sm text-gray-500 dark:text-gray-400"
                      },
                      "text": "px"
                    }
                  ]
                }
              ]
            },
            {
              "id": "field_image_max_height",
              "type": "basic",
              "name": "Div",
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1"
                  },
                  "text": "$t:admin.settings.upload.image_max_height"
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex items-center gap-2"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Input",
                      "props": {
                        "type": "number",
                        "name": "upload.image_max_height",
                        "min": "100",
                        "max": "10000",
                        "disabled": "{{_computed.isReadOnly}}",
                        "className": "flex-1 px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 disabled:bg-gray-100 dark:disabled:bg-gray-800 disabled:text-gray-400 dark:disabled:text-gray-500 disabled:cursor-not-allowed"
                      }
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "text-sm text-gray-500 dark:text-gray-400"
                      },
                      "text": "px"
                    }
                  ]
                }
              ]
            },
            {
              "id": "field_image_quality",
              "type": "basic",
              "name": "Div",
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1"
                  },
                  "text": "$t:admin.settings.upload.image_quality"
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex items-center gap-2"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Input",
                      "props": {
                        "type": "number",
                        "name": "upload.image_quality",
                        "min": "1",
                        "max": "100",
                        "disabled": "{{_computed.isReadOnly}}",
                        "className": "flex-1 px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 disabled:bg-gray-100 dark:disabled:bg-gray-800 disabled:text-gray-400 dark:disabled:text-gray-500 disabled:cursor-not-allowed"
                      }
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "text-sm text-gray-500 dark:text-gray-400"
                      },
                      "text": "%"
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "P",
                  "props": {
                    "className": "text-xs text-gray-500 dark:text-gray-400 mt-1"
                  },
                  "text": "$t:admin.settings.upload.image_quality_hint"
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
