{
    "meta": { "is_partial": true, "description": "코어 업데이트 확인 결과 모달" },
    "id": "core_update_result_modal",
    "type": "composite",
    "name": "Modal",
    "props": {
        "title": "$t:admin.settings.info.update_result_title",
        "size": "md"
    },
    "children": [
        {
            "type": "basic",
            "name": "Div",
            "props": { "className": "space-y-4" },
            "children": [
                {
                    "type": "basic",
                    "name": "Div",
                    "props": { "className": "flex justify-between items-center py-2 border-b border-gray-100 dark:border-gray-700" },
                    "children": [
                        { "type": "basic", "name": "Span", "props": { "className": "text-sm text-gray-600 dark:text-gray-400" }, "text": "$t:admin.settings.info.current_version" },
                        { "type": "basic", "name": "Span", "props": { "className": "text-sm font-medium text-gray-900 dark:text-white" }, "text": "{{$parent._local.coreUpdateInfo?.current_version ?? '-'}}" }
                    ]
                },
                {
                    "type": "basic",
                    "name": "Div",
                    "props": { "className": "flex justify-between items-center py-2 border-b border-gray-100 dark:border-gray-700" },
                    "children": [
                        { "type": "basic", "name": "Span", "props": { "className": "text-sm text-gray-600 dark:text-gray-400" }, "text": "$t:admin.settings.info.latest_version" },
                        { "type": "basic", "name": "Span", "props": { "className": "text-sm font-medium text-gray-900 dark:text-white" }, "text": "{{$parent._local.coreUpdateInfo?.latest_version ?? '-'}}" }
                    ]
                },
                {
                    "id": "update_available_section",
                    "type": "basic",
                    "name": "Div",
                    "if": "{{$parent._local.coreUpdateInfo?.update_available}}",
                    "props": { "className": "mt-4 space-y-3" },
                    "children": [
                        {
                            "type": "basic",
                            "name": "Div",
                            "props": { "className": "bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-lg p-3" },
                            "children": [
                                {
                                    "type": "basic",
                                    "name": "P",
                                    "props": { "className": "text-sm text-green-700 dark:text-green-300" },
                                    "text": "$t:admin.settings.info.update_available_message"
                                }
                            ]
                        },
                        {
                            "type": "basic",
                            "name": "Div",
                            "props": { "className": "flex gap-2 justify-end" },
                            "children": [
                                {
                                    "type": "basic",
                                    "name": "Button",
                                    "props": {
                                        "type": "button",
                                        "className": "px-3 py-1.5 text-sm font-medium text-white bg-gray-900 dark:bg-white dark:text-gray-900 rounded-md hover:bg-gray-800 dark:hover:bg-gray-100 transition-colors"
                                    },
                                    "actions": [
                                        {
                                            "type": "click",
                                            "handler": "apiCall",
                                            "auth_required": true,
                                            "target": "/api/admin/core-update/changelog",
                                            "params": {
                                                "method": "GET",
                                                "query": {
                                                    "from_version": "{{$parent._local.coreUpdateInfo?.current_version ?? ''}}",
                                                    "to_version": "{{$parent._local.coreUpdateInfo?.latest_version ?? ''}}"
                                                }
                                            },
                                            "onSuccess": [
                                                {
                                                    "handler": "setState",
                                                    "params": {
                                                        "target": "local",
                                                        "coreChangelog": "{{result.data.changelog ?? []}}"
                                                    }
                                                },
                                                {
                                                    "handler": "openModal",
                                                    "target": "core_changelog_modal"
                                                }
                                            ],
                                            "onError": [
                                                {
                                                    "handler": "setState",
                                                    "params": {
                                                        "target": "local",
                                                        "coreChangelog": []
                                                    }
                                                },
                                                {
                                                    "handler": "openModal",
                                                    "target": "core_changelog_modal"
                                                }
                                            ]
                                        }
                                    ],
                                    "text": "$t:admin.settings.info.view_changelog"
                                },
                                {
                                    "type": "basic",
                                    "name": "Button",
                                    "props": {
                                        "type": "button",
                                        "className": "px-3 py-1.5 text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-md hover:bg-gray-50 dark:hover:bg-gray-600 transition-colors"
                                    },
                                    "actions": [
                                        {
                                            "type": "click",
                                            "handler": "openModal",
                                            "target": "core_update_guide_modal"
                                        }
                                    ],
                                    "text": "$t:admin.settings.info.how_to_update"
                                }
                            ]
                        }
                    ]
                },
                {
                    "id": "no_update_section",
                    "type": "basic",
                    "name": "Div",
                    "if": "{{!$parent._local.coreUpdateInfo?.update_available}}",
                    "props": { "className": "mt-4" },
                    "children": [
                        {
                            "type": "basic",
                            "name": "Div",
                            "props": { "className": "bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg p-3" },
                            "children": [
                                { "type": "basic", "name": "P", "props": { "className": "text-sm text-blue-700 dark:text-blue-300" }, "text": "$t:admin.settings.info.no_update_message" }
                            ]
                        }
                    ]
                }
            ]
        }
    ]
}
