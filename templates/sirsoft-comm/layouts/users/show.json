{
  "version": "1.0.0",
  "layout_name": "users/show",
  "extends": "_user_base",
  "permissions": [],
  "meta": {
    "seo": {
      "enabled": true,
      "data_sources": [
        "profile"
      ],
      "priority": 0.4,
      "changefreq": "monthly",
      "og": {
        "type": "profile"
      },
      "structured_data": {
        "@type": "ProfilePage"
      }
    }
  },
  "data_sources": [
    {
      "id": "profile",
      "type": "api",
      "endpoint": "/api/users/{{route.userId}}/profile",
      "method": "GET",
      "auto_fetch": true,
      "auth_required": true,
      "refetchOnMount": true,
      "loading_strategy": "progressive",
      "errorHandling": {
        "404": {
          "handler": "showErrorPage",
          "params": {
            "target": "content"
          }
        }
      }
    },
    {
      "id": "postStats",
      "type": "api",
      "endpoint": "/api/modules/sirsoft-board/users/{{route.userId}}/posts/stats",
      "method": "GET",
      "auto_fetch": true,
      "auth_required": false,
      "loading_strategy": "progressive"
    },
    {
      "id": "recentPosts",
      "type": "api",
      "endpoint": "/api/modules/sirsoft-board/users/{{route.userId}}/posts",
      "method": "GET",
      "auto_fetch": true,
      "auth_required": false,
      "loading_strategy": "progressive",
      "params": {
        "per_page": 5
      }
    }
  ],
  "slots": {
    "content": [
      {
        "type": "basic",
        "name": "Div",
        "props": {
          "className": "min-h-screen bg-slate-50 dark:bg-slate-900"
        },
        "children": [
          {
            "type": "layout",
            "name": "Container",
            "props": {
              "className": "py-8"
            },
            "responsive": {
              "portable": {
                "props": {
                  "className": "py-4"
                }
              }
            },
            "children": [
              {
                "type": "basic",
                "name": "Div",
                "if": "{{profile.loading}}",
                "props": {
                  "className": "flex justify-center items-center py-20"
                },
                "children": [
                  {
                    "type": "basic",
                    "name": "Div",
                    "props": {
                      "className": "animate-spin rounded-full h-8 w-8 border-b-2 border-slate-900 dark:border-white"
                    }
                  }
                ]
              },
              {
                "type": "basic",
                "name": "Div",
                "if": "{{profile.data && !profile.loading && !profile.error}}",
                "props": {
                  "className": "space-y-6"
                },
                "children": [
                  {
                    "type": "basic",
                    "name": "Div",
                    "props": {
                      "className": "flex items-center gap-2 mb-6"
                    },
                    "children": [
                      {
                        "type": "basic",
                        "name": "Icon",
                        "props": {
                          "name": "user",
                          "size": "xl",
                          "className": "text-slate-900 dark:text-white"
                        }
                      },
                      {
                        "type": "basic",
                        "name": "H1",
                        "props": {
                          "className": "text-2xl font-bold text-slate-900 dark:text-white"
                        },
                        "text": "$t:user.profile.page_title"
                      }
                    ]
                  },
                  {
                    "type": "basic",
                    "name": "Div",
                    "props": {
                      "className": "bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-6"
                    },
                    "responsive": {
                      "portable": {
                        "props": {
                          "className": "bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-4"
                        }
                      }
                    },
                    "children": [
                      {
                        "type": "basic",
                        "name": "Div",
                        "props": {
                          "className": "flex gap-6 items-start"
                        },
                        "responsive": {
                          "portable": {
                            "props": {
                              "className": "flex flex-col items-center gap-4"
                            }
                          }
                        },
                        "children": [
                          {
                            "type": "composite",
                            "name": "Avatar",
                            "props": {
                              "author": "{{profile.data}}",
                              "size": "xl"
                            },
                            "responsive": {
                              "portable": {
                                "props": {
                                  "size": "lg"
                                }
                              }
                            }
                          },
                          {
                            "type": "basic",
                            "name": "Div",
                            "if": "{{profile.data?.status !== 'withdrawn'}}",
                            "props": {
                              "className": "flex-1 space-y-3"
                            },
                            "responsive": {
                              "portable": {
                                "props": {
                                  "className": "w-full space-y-3 text-center"
                                }
                              }
                            },
                            "children": [
                              {
                                "type": "basic",
                                "name": "H2",
                                "props": {
                                  "className": "text-2xl font-bold text-slate-900 dark:text-white"
                                },
                                "responsive": {
                                  "portable": {
                                    "props": {
                                      "className": "text-xl font-bold text-slate-900 dark:text-white"
                                    }
                                  }
                                },
                                "text": "{{profile.data?.name ?? '-'}}"
                              },
                              {
                                "type": "basic",
                                "name": "Div",
                                "props": {
                                  "className": "flex items-center gap-2 text-sm text-slate-500 dark:text-slate-400"
                                },
                                "responsive": {
                                  "portable": {
                                    "props": {
                                      "className": "flex items-center justify-center gap-2 text-sm text-slate-500 dark:text-slate-400"
                                    }
                                  }
                                },
                                "children": [
                                  {
                                    "type": "basic",
                                    "name": "Icon",
                                    "props": {
                                      "name": "calendar",
                                      "size": "sm"
                                    }
                                  },
                                  {
                                    "type": "basic",
                                    "name": "Span",
                                    "text": "$t:user.profile.joined_at"
                                  },
                                  {
                                    "type": "basic",
                                    "name": "Span",
                                    "props": {
                                      "className": "font-medium text-slate-700 dark:text-slate-300"
                                    },
                                    "text": "{{profile.data?.created_at ?? '-'}}"
                                  }
                                ]
                              },
                              {
                                "if": "{{profile.data?.bio}}",
                                "type": "basic",
                                "name": "P",
                                "props": {
                                  "className": "text-slate-600 dark:text-slate-300 whitespace-pre-wrap mt-4"
                                },
                                "text": "{{profile.data?.bio}}"
                              }
                            ]
                          },
                          {
                            "type": "basic",
                            "name": "Div",
                            "if": "{{profile.data?.status === 'withdrawn'}}",
                            "props": {
                              "className": "flex-1 space-y-3"
                            },
                            "responsive": {
                              "portable": {
                                "props": {
                                  "className": "w-full space-y-3 text-center"
                                }
                              }
                            },
                            "children": [
                              {
                                "type": "basic",
                                "name": "H2",
                                "props": {
                                  "className": "text-2xl font-bold text-slate-400 dark:text-slate-500 line-through"
                                },
                                "responsive": {
                                  "portable": {
                                    "props": {
                                      "className": "text-xl font-bold text-slate-400 dark:text-slate-500 line-through"
                                    }
                                  }
                                },
                                "text": "$t:userinfo.withdrawn_user"
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "basic",
                    "name": "Div",
                    "props": {
                      "className": "grid grid-cols-2 gap-4"
                    },
                    "responsive": {
                      "portable": {
                        "props": {
                          "className": "grid grid-cols-2 gap-3"
                        }
                      }
                    },
                    "children": [
                      {
                        "type": "basic",
                        "name": "Div",
                        "props": {
                          "className": "bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-4 text-center"
                        },
                        "children": [
                          {
                            "type": "basic",
                            "name": "Div",
                            "props": {
                              "className": "text-3xl font-bold text-teal-600 dark:text-teal-400"
                            },
                            "text": "{{postStats.data.posts_count ?? 0 | number}}"
                          },
                          {
                            "type": "basic",
                            "name": "Div",
                            "props": {
                              "className": "text-sm text-slate-500 dark:text-slate-400 mt-1"
                            },
                            "text": "$t:user.profile.posts_count"
                          }
                        ]
                      },
                      {
                        "type": "basic",
                        "name": "Div",
                        "props": {
                          "className": "bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-4 text-center"
                        },
                        "children": [
                          {
                            "type": "basic",
                            "name": "Div",
                            "props": {
                              "className": "text-3xl font-bold text-green-600 dark:text-green-400"
                            },
                            "text": "{{postStats.data.comments_count ?? 0 | number}}"
                          },
                          {
                            "type": "basic",
                            "name": "Div",
                            "props": {
                              "className": "text-sm text-slate-500 dark:text-slate-400 mt-1"
                            },
                            "text": "$t:user.profile.comments_count"
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "if": "{{recentPosts.data?.data?.length > 0}}",
                    "type": "basic",
                    "name": "Div",
                    "props": {
                      "className": "bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700"
                    },
                    "children": [
                      {
                        "type": "basic",
                        "name": "Div",
                        "props": {
                          "className": "px-6 py-4 border-b border-slate-200 dark:border-slate-700 flex items-center justify-between"
                        },
                        "children": [
                          {
                            "type": "basic",
                            "name": "H3",
                            "props": {
                              "className": "text-lg font-semibold text-slate-900 dark:text-white"
                            },
                            "text": "$t:user.profile.recent_posts"
                          },
                          {
                            "type": "basic",
                            "name": "Button",
                            "props": {
                              "className": "text-sm text-teal-600 dark:text-teal-400 hover:underline cursor-pointer"
                            },
                            "actions": [
                              {
                                "type": "click",
                                "handler": "navigate",
                                "params": {
                                  "path": "/users/{{route.userId}}/posts"
                                }
                              }
                            ],
                            "children": [
                              {
                                "type": "basic",
                                "name": "Span",
                                "text": "$t:user.profile.view_all"
                              }
                            ]
                          }
                        ]
                      },
                      {
                        "type": "basic",
                        "name": "Div",
                        "props": {
                          "className": "divide-y divide-slate-200 dark:divide-slate-700"
                        },
                        "children": [
                          {
                            "type": "basic",
                            "name": "Button",
                            "iteration": {
                              "source": "{{recentPosts.data?.data ?? []}}",
                              "item_var": "post"
                            },
                            "props": {
                              "className": "block w-full text-left px-6 py-3 hover:bg-slate-50 dark:hover:bg-slate-700/50 transition-colors cursor-pointer"
                            },
                            "actions": [
                              {
                                "type": "click",
                                "handler": "navigate",
                                "params": {
                                  "path": "/board/{{post.board_slug}}/{{post.id}}"
                                }
                              }
                            ],
                            "children": [
                              {
                                "type": "basic",
                                "name": "Div",
                                "props": {
                                  "className": "flex items-center justify-between gap-4"
                                },
                                "children": [
                                  {
                                    "type": "basic",
                                    "name": "Div",
                                    "props": {
                                      "className": "flex-1 min-w-0 flex items-center gap-2 overflow-hidden"
                                    },
                                    "children": [
                                      {
                                        "type": "basic",
                                        "name": "Span",
                                        "props": {
                                          "className": "flex-shrink-0 text-xs px-1.5 py-0.5 bg-teal-100 dark:bg-teal-900/50 text-teal-700 dark:text-teal-300 rounded whitespace-nowrap"
                                        },
                                        "text": "{{post.board_name}}"
                                      },
                                      {
                                        "type": "basic",
                                        "name": "Span",
                                        "if": "{{post.category}}",
                                        "props": {
                                          "className": "flex-shrink-0 text-xs px-1.5 py-0.5 bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-400 rounded whitespace-nowrap"
                                        },
                                        "text": "{{post.category}}"
                                      },
                                      {
                                        "type": "basic",
                                        "name": "Icon",
                                        "if": "{{post.is_secret}}",
                                        "props": {
                                          "name": "lock",
                                          "size": "xs",
                                          "className": "flex-shrink-0 text-orange-500 dark:text-orange-400"
                                        }
                                      },
                                      {
                                        "type": "basic",
                                        "name": "Icon",
                                        "if": "{{post.status === 'blinded'}}",
                                        "props": {
                                          "name": "eye-slash",
                                          "size": "xs",
                                          "className": "flex-shrink-0 text-orange-500 dark:text-orange-400"
                                        }
                                      },
                                      {
                                        "type": "basic",
                                        "name": "Div",
                                        "props": {
                                          "className": "flex-1 min-w-0 flex items-center gap-1"
                                        },
                                        "children": [
                                          {
                                            "type": "basic",
                                            "name": "Span",
                                            "props": {
                                              "className": "truncate text-sm font-medium text-slate-900 dark:text-white"
                                            },
                                            "text": "{{post.title}}"
                                          },
                                          {
                                            "type": "basic",
                                            "name": "Span",
                                            "if": "{{post.comments_count > 0}}",
                                            "props": {
                                              "className": "flex-shrink-0 text-xs text-teal-600 dark:text-teal-400 font-medium"
                                            },
                                            "text": "[{{post.comments_count}}]"
                                          }
                                        ]
                                      }
                                    ]
                                  },
                                  {
                                    "type": "basic",
                                    "name": "Span",
                                    "props": {
                                      "className": "text-xs text-slate-500 dark:text-slate-400 flex-shrink-0 hidden md:inline",
                                      "title": "{{post.created_at ?? ''}}"
                                    },
                                    "text": "{{post.created_at_formatted ?? ''}}"
                                  }
                                ]
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "if": "{{!recentPosts.data?.data?.length}}",
                    "type": "basic",
                    "name": "Div",
                    "props": {
                      "className": "bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700"
                    },
                    "children": [
                      {
                        "type": "basic",
                        "name": "Div",
                        "props": {
                          "className": "px-6 py-4 border-b border-slate-200 dark:border-slate-700 flex items-center justify-between"
                        },
                        "children": [
                          {
                            "type": "basic",
                            "name": "H3",
                            "props": {
                              "className": "text-lg font-semibold text-slate-900 dark:text-white"
                            },
                            "text": "$t:user.profile.recent_posts"
                          },
                          {
                            "type": "basic",
                            "name": "Button",
                            "props": {
                              "className": "text-sm text-teal-600 dark:text-teal-400 hover:underline cursor-pointer"
                            },
                            "actions": [
                              {
                                "type": "click",
                                "handler": "navigate",
                                "params": {
                                  "path": "/users/{{route.userId}}/posts"
                                }
                              }
                            ],
                            "children": [
                              {
                                "type": "basic",
                                "name": "Span",
                                "text": "$t:user.profile.view_all"
                              }
                            ]
                          }
                        ]
                      },
                      {
                        "type": "basic",
                        "name": "Div",
                        "props": {
                          "className": "text-center py-12"
                        },
                        "children": [
                          {
                            "type": "basic",
                            "name": "Icon",
                            "props": {
                              "name": "file-circle-xmark",
                              "size": "3x",
                              "className": "text-slate-300 dark:text-slate-600 mb-4"
                            }
                          },
                          {
                            "type": "basic",
                            "name": "P",
                            "props": {
                              "className": "text-slate-500 dark:text-slate-400"
                            },
                            "text": "$t:user.profile.no_posts"
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
