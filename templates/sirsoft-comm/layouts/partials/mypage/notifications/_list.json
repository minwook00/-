{
  "meta": {
    "is_partial": true
  },
  "type": "basic",
  "name": "Div",
  "blur_until_loaded": {
    "enabled": true,
    "data_sources": "userNotifications"
  },
  "props": {
    "className": "mt-6"
  },
  "responsive": {
    "portable": {
      "props": {
        "className": "mt-4"
      }
    }
  },
  "children": [
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "bg-white dark:bg-slate-800 rounded-lg overflow-hidden"
      },
      "children": [
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "flex items-center justify-between p-4 border-b border-slate-200 dark:border-slate-700"
          },
          "responsive": {
            "portable": {
              "props": {
                "className": "flex flex-col gap-2 p-3 border-b border-slate-200 dark:border-slate-700"
              }
            }
          },
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex items-center gap-4"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-sm text-red-500 dark:text-red-400 font-medium"
                  },
                  "text": "$t:mypage.notifications.unread_count|count={{userNotifications.data?.unread_count ?? 0}}"
                },
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "flex items-center gap-1.5 cursor-pointer select-none"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Input",
                      "props": {
                        "type": "checkbox",
                        "checked": "{{_local.userNotificationsUnreadOnly ?? false}}",
                        "className": "w-3.5 h-3.5 rounded border-slate-300 dark:border-slate-600 text-teal-600 focus:ring-teal-500 cursor-pointer"
                      },
                      "actions": [
                        {
                          "type": "change",
                          "handler": "sequence",
                          "actions": [
                            {
                              "handler": "setState",
                              "params": {
                                "target": "local",
                                "userNotificationsUnreadOnly": "{{$event.target.checked}}",
                                "notificationsPage": 1
                              }
                            },
                            {
                              "handler": "refetchDataSource",
                              "params": {
                                "dataSourceId": "userNotifications"
                              }
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "text-xs text-slate-600 dark:text-slate-400"
                      },
                      "text": "$t:mypage.notifications.unread_only"
                    }
                  ]
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex items-center gap-3"
              },
              "responsive": {
                "portable": {
                  "props": {
                    "className": "flex items-center justify-end gap-3"
                  }
                }
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Button",
                  "if": "{{userNotifications.data.data && userNotifications.data.data.length > 0}}",
                  "props": {
                    "className": "text-sm text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white transition-colors",
                    "type": "button"
                  },
                  "text": "$t:mypage.notifications.mark_all_read",
                  "actions": [
                    {
                      "type": "click",
                      "handler": "apiCall",
                      "auth_required": true,
                      "target": "/api/user/notifications/read-all",
                      "params": {
                        "method": "POST"
                      },
                      "onSuccess": [
                        {
                          "handler": "refetchDataSource",
                          "params": {
                            "dataSourceId": "userNotifications"
                          }
                        },
                        {
                          "handler": "refetchDataSource",
                          "params": {
                            "dataSourceId": "notification_unread_count"
                          }
                        },
                        {
                          "handler": "setState",
                          "params": {
                            "target": "global",
                            "notificationCount": 0
                          }
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Button",
                  "if": "{{userNotifications.data.data && userNotifications.data.data.length > 0}}",
                  "props": {
                    "className": "text-sm text-red-500 dark:text-red-400 hover:text-red-600 dark:hover:text-red-300 transition-colors",
                    "type": "button"
                  },
                  "text": "$t:mypage.notifications.delete_all",
                  "actions": [
                    {
                      "type": "click",
                      "handler": "openModal",
                      "target": "notification_delete_all_confirm_modal"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "basic",
          "name": "Div",
          "if": "{{userNotifications.data.data && userNotifications.data.data.length > 0}}",
          "props": {
            "className": "divide-y divide-slate-200 dark:divide-slate-700"
          },
          "iteration": {
            "source": "{{userNotifications.data.data ?? []}}",
            "item_var": "notification"
          },
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "p-4 hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors cursor-pointer {{notification.read_at ? '' : 'bg-red-50/30 dark:bg-red-900/10'}}"
              },
              "responsive": {
                "portable": {
                  "props": {
                    "className": "p-3 hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors cursor-pointer {{notification.read_at ? '' : 'bg-red-50/30 dark:bg-red-900/10'}}"
                  }
                }
              },
              "actions": [
                {
                  "type": "click",
                  "handler": "sequence",
                  "actions": [
                    {
                      "handler": "apiCall",
                      "if": "{{!notification.read_at}}",
                      "auth_required": true,
                      "target": "/api/user/notifications/{{notification.id}}/read",
                      "params": {
                        "method": "PATCH"
                      },
                      "onSuccess": [
                        {
                          "handler": "refetchDataSource",
                          "params": {
                            "dataSourceId": "notification_unread_count"
                          }
                        },
                        {
                          "handler": "setState",
                          "params": {
                            "target": "global",
                            "notificationCount": "{{Math.max(0, (_global.notificationCount ?? 0) - 1)}}"
                          }
                        }
                      ]
                    },
                    {
                      "handler": "navigate",
                      "if": "{{notification.url}}",
                      "params": {
                        "path": "{{notification.url}}"
                      }
                    }
                  ]
                }
              ],
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex items-start gap-3"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "flex items-center gap-2 flex-shrink-0"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Div",
                          "if": "{{!notification.read_at}}",
                          "props": {
                            "className": "w-2 h-2 rounded-full bg-red-500"
                          }
                        },
                        {
                          "type": "basic",
                          "name": "Div",
                          "props": {
                            "className": "w-10 h-10 rounded-full flex items-center justify-center {{notification.type === 'order' ? 'bg-green-100 dark:bg-green-900/30' : notification.type === 'comment' ? 'bg-teal-100 dark:bg-teal-900/30' : notification.type === 'shipping' ? 'bg-orange-100 dark:bg-orange-900/30' : notification.type === 'promotion' ? 'bg-teal-100 dark:bg-teal-900/30' : 'bg-slate-100 dark:bg-slate-700'}}"
                          },
                          "responsive": {
                            "portable": {
                              "props": {
                                "className": "w-9 h-9 rounded-full flex items-center justify-center {{notification.type === 'order' ? 'bg-green-100 dark:bg-green-900/30' : notification.type === 'comment' ? 'bg-teal-100 dark:bg-teal-900/30' : notification.type === 'shipping' ? 'bg-orange-100 dark:bg-orange-900/30' : notification.type === 'promotion' ? 'bg-teal-100 dark:bg-teal-900/30' : 'bg-slate-100 dark:bg-slate-700'}}"
                              }
                            }
                          },
                          "children": [
                            {
                              "type": "basic",
                              "name": "Icon",
                              "props": {
                                "name": "{{notification.type === 'order' ? 'shopping-cart' : notification.type === 'comment' ? 'message-square' : notification.type === 'shipping' ? 'truck' : notification.type === 'promotion' ? 'gift' : 'bell'}}",
                                "className": "w-5 h-5 {{notification.type === 'order' ? 'text-green-600 dark:text-green-400' : notification.type === 'comment' ? 'text-teal-600 dark:text-teal-400' : notification.type === 'shipping' ? 'text-orange-600 dark:text-orange-400' : notification.type === 'promotion' ? 'text-teal-600 dark:text-teal-400' : 'text-slate-600 dark:text-slate-400'}}"
                              },
                              "responsive": {
                                "portable": {
                                  "props": {
                                    "name": "{{notification.type === 'order' ? 'shopping-cart' : notification.type === 'comment' ? 'message-square' : notification.type === 'shipping' ? 'truck' : notification.type === 'promotion' ? 'gift' : 'bell'}}",
                                    "className": "w-4 h-4 {{notification.type === 'order' ? 'text-green-600 dark:text-green-400' : notification.type === 'comment' ? 'text-teal-600 dark:text-teal-400' : notification.type === 'shipping' ? 'text-orange-600 dark:text-orange-400' : notification.type === 'promotion' ? 'text-teal-600 dark:text-teal-400' : 'text-slate-600 dark:text-slate-400'}}"
                                  }
                                }
                              }
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "flex-1 min-w-0"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Div",
                          "props": {
                            "className": "flex items-center justify-between gap-2 mb-1"
                          },
                          "children": [
                            {
                              "type": "basic",
                              "name": "Div",
                              "props": {
                                "className": "flex items-center gap-2 min-w-0"
                              },
                              "children": [
                                {
                                  "type": "basic",
                                  "name": "Span",
                                  "props": {
                                    "className": "text-sm text-slate-900 dark:text-white truncate {{notification.read_at ? '' : 'font-semibold'}}"
                                  },
                                  "text": "{{notification.subject ?? ''}}"
                                },
                                {
                                  "type": "basic",
                                  "name": "Span",
                                  "if": "{{notification.type_label}}",
                                  "props": {
                                    "className": "flex-shrink-0 px-2 py-0.5 text-xs rounded {{notification.type === 'order' ? 'bg-green-100 dark:bg-green-900/50 text-green-700 dark:text-green-300' : notification.type === 'comment' ? 'bg-teal-100 dark:bg-teal-900/50 text-teal-700 dark:text-teal-300' : notification.type === 'shipping' ? 'bg-orange-100 dark:bg-orange-900/50 text-orange-700 dark:text-orange-300' : notification.type === 'promotion' ? 'bg-teal-100 dark:bg-teal-900/50 text-teal-700 dark:text-teal-300' : 'bg-slate-100 dark:bg-slate-700 text-slate-700 dark:text-slate-300'}}"
                                  },
                                  "text": "{{notification.type_label}}"
                                }
                              ]
                            },
                            {
                              "type": "basic",
                              "name": "Button",
                              "props": {
                                "className": "flex-shrink-0 p-1.5 text-slate-400 dark:text-slate-500 hover:text-red-500 dark:hover:text-red-400 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-700 transition-colors",
                                "type": "button"
                              },
                              "children": [
                                {
                                  "type": "basic",
                                  "name": "Icon",
                                  "props": {
                                    "name": "trash-can",
                                    "className": "w-4 h-4"
                                  }
                                }
                              ],
                              "actions": [
                                {
                                  "type": "click",
                                  "handler": "stopPropagation"
                                },
                                {
                                  "type": "click",
                                  "handler": "apiCall",
                                  "auth_required": true,
                                  "target": "/api/user/notifications/{{notification.id}}",
                                  "params": {
                                    "method": "DELETE"
                                  },
                                  "onSuccess": [
                                    {
                                      "handler": "refetchDataSource",
                                      "params": {
                                        "dataSourceId": "userNotifications"
                                      }
                                    },
                                    {
                                      "handler": "refetchDataSource",
                                      "params": {
                                        "dataSourceId": "notification_unread_count"
                                      }
                                    },
                                    {
                                      "handler": "setState",
                                      "if": "{{!notification.read_at}}",
                                      "params": {
                                        "target": "global",
                                        "notificationCount": "{{Math.max(0, (_global.notificationCount ?? 0) - 1)}}"
                                      }
                                    }
                                  ]
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "type": "basic",
                          "name": "P",
                          "props": {
                            "className": "text-sm text-slate-600 dark:text-slate-400 mb-1"
                          },
                          "text": "{{notification.body ?? ''}}"
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "text-xs text-slate-400 dark:text-slate-500"
                          },
                          "text": "{{notification.created_at | datetime}}"
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "basic",
          "name": "Div",
          "if": "{{!userNotifications.data.data || userNotifications.data.data.length === 0}}",
          "props": {
            "className": "p-12 text-center"
          },
          "responsive": {
            "portable": {
              "props": {
                "className": "p-8 text-center"
              }
            }
          },
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "props": {
                "name": "bell-off",
                "className": "w-12 h-12 mx-auto text-slate-300 dark:text-slate-600 mb-3"
              }
            },
            {
              "type": "basic",
              "name": "P",
              "props": {
                "className": "text-slate-500 dark:text-slate-400"
              },
              "text": "$t:mypage.notifications.empty"
            }
          ]
        },
        {
          "type": "composite",
          "name": "Pagination",
          "if": "{{userNotifications.data.last_page > 1}}",
          "props": {
            "currentPage": "{{userNotifications.data.current_page}}",
            "totalPages": "{{userNotifications.data.last_page}}",
            "className": "p-4 border-t border-slate-200 dark:border-slate-700"
          },
          "responsive": {
            "portable": {
              "props": {
                "currentPage": "{{userNotifications.data.current_page}}",
                "totalPages": "{{userNotifications.data.last_page}}",
                "className": "p-3 border-t border-slate-200 dark:border-slate-700"
              }
            }
          },
          "actions": [
            {
              "event": "onPageChange",
              "handler": "sequence",
              "actions": [
                {
                  "handler": "setState",
                  "params": {
                    "target": "local",
                    "notificationsPage": "{{$args[0]}}"
                  }
                },
                {
                  "handler": "refetchDataSource",
                  "params": {
                    "dataSourceId": "userNotifications"
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
