{
  "meta": {
    "is_partial": true
  },
  "type": "basic",
  "name": "Div",
  "if": "{{!_local?.isPasswordVerified}}",
  "props": {
    "className": "max-w-lg mx-auto mt-16"
  },
  "children": [
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "p-8 border border-slate-200 dark:border-slate-700 rounded-xl bg-white dark:bg-slate-800 shadow-sm"
      },
      "children": [
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "text-center mb-8"
          },
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "inline-flex items-center justify-center w-12 h-12 mb-4 rounded-full bg-slate-100 dark:bg-slate-700"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Icon",
                  "props": {
                    "name": "lock",
                    "size": "lg",
                    "className": "text-slate-600 dark:text-slate-400"
                  }
                }
              ]
            },
            {
              "type": "basic",
              "name": "H2",
              "props": {
                "className": "text-lg font-semibold text-slate-900 dark:text-white mb-2"
              },
              "text": "$t:mypage.profile.verify_password_title"
            },
            {
              "type": "basic",
              "name": "P",
              "props": {
                "className": "text-sm text-slate-600 dark:text-slate-400"
              },
              "text": "$t:mypage.profile.verify_password_message"
            }
          ]
        },
        {
          "type": "basic",
          "name": "Form",
          "props": {
            "id": "verifyPasswordForm",
            "className": "space-y-5"
          },
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "children": [
                {
                  "type": "basic",
                  "name": "PasswordInput",
                  "props": {
                    "name": "password",
                    "value": "{{_local?.verifyPassword ?? ''}}",
                    "placeholder": "$t:mypage.profile.verify_password_placeholder",
                    "showToggle": true,
                    "className": "w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-500 dark:placeholder-slate-400 focus:ring-2 focus:ring-slate-900 dark:focus:ring-white focus:border-transparent transition-colors"
                  },
                  "actions": [
                    {
                      "type": "change",
                      "handler": "setState",
                      "params": {
                        "target": "local",
                        "verifyPassword": "{{$event.target.value}}"
                      }
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "P",
                  "if": "{{_local?.verifyPasswordError}}",
                  "props": {
                    "className": "mt-2 text-sm text-red-600 dark:text-red-400"
                  },
                  "text": "$t:mypage.profile.verify_password_error"
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex gap-3 pt-2"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Button",
                  "props": {
                    "type": "button",
                    "className": "flex-1 px-4 py-2.5 border border-slate-300 dark:border-slate-600 text-slate-700 dark:text-slate-300 rounded-lg font-medium hover:bg-slate-50 dark:hover:bg-slate-700 transition-colors"
                  },
                  "text": "$t:common.cancel",
                  "actions": [
                    {
                      "type": "click",
                      "handler": "navigate",
                      "params": {
                        "path": "/mypage/profile"
                      }
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Button",
                  "props": {
                    "type": "submit",
                    "form": "verifyPasswordForm",
                    "loading": "{{_local.isVerifyingPassword}}",
                    "disabled": "{{_local.isVerifyingPassword || !_local.verifyPassword}}",
                    "className": "flex-1 inline-flex items-center justify-center gap-2 px-4 py-2.5 bg-teal-600 dark:bg-teal-500 text-white rounded-lg font-medium hover:bg-teal-700 dark:hover:bg-teal-600 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
                  },
                  "children": [
                    {
                      "if": "{{_local.isVerifyingPassword}}",
                      "type": "basic",
                      "name": "Icon",
                      "props": {
                        "name": "spinner",
                        "size": "sm"
                      }
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "text": "$t:mypage.profile.verify_password_button"
                    }
                  ]
                }
              ]
            }
          ],
          "actions": [
            {
              "type": "submit",
              "handler": "sequence",
              "actions": [
                {
                  "handler": "setState",
                  "params": {
                    "target": "local",
                    "isVerifyingPassword": true,
                    "verifyPasswordError": false
                  }
                },
                {
                  "handler": "apiCall",
                  "auth_required": true,
                  "target": "/api/me/verify-password",
                  "params": {
                    "method": "POST",
                    "body": {
                      "password": "{{_local.verifyPassword}}"
                    }
                  },
                  "onSuccess": [
                    {
                      "handler": "setState",
                      "params": {
                        "target": "local",
                        "isVerifyingPassword": false,
                        "isPasswordVerified": true,
                        "verifyPassword": ""
                      }
                    }
                  ],
                  "onError": [
                    {
                      "handler": "setState",
                      "params": {
                        "target": "local",
                        "isVerifyingPassword": false,
                        "verifyPasswordError": true
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
