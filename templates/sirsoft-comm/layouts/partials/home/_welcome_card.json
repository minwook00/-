                {
                  "type": "basic",
                  "name": "Icon",
                  "props": {
                    "name": "arrow-right",
                    "className": "w-4 h-4"
                  }
                }
              ]
            },
            {
              "type": "basic",
              "name": "Button",
              "if": "{{!_global.currentUser?.uuid}}",
              "props": {
                "variant": "primary",
                "size": "md",
