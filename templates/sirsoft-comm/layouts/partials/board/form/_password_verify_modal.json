{
  "meta": {
    "is_partial": true
  },
  "id": "password_verify_modal",
  "type": "composite",
  "name": "Modal",
  "props": {
    "isOpen": "{{form_meta?.data?.requires_password && !_local?.passwordVerified && !form_meta?.data?.board?.user_abilities?.can_manage}}",
    "title": "$t:board.modals.edit_post_title",
    "icon": "pen",
    "iconClassName": "text-teal-500",
    "width": "400px",
    "closeOnBackdropClick": false
  },
  "actions": [
    {
      "event": "onClose",
      "type": "click",
      "handler": "navigate",
      "params": {
        "path": "/board/{{route.slug}}/{{route.id}}"
      }
    }
  ],
  "children": [
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "space-y-4"
      },
      "children": [
        {
          "type": "basic",
          "name": "P",
          "props": {
            "className": "text-sm text-slate-600 dark:text-slate-400"
          },
          "text": "$t:board.password_verify.description"
        },
        {
          "type": "basic",
          "name": "Div",
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex items-center gap-1.5 mb-1"
              },
              "children": [
                {
                  "type": "composite",
                  "name": "Icon",
                  "props": {
                    "name": "lock",
                    "size": "xs",
                    "className": "text-slate-500 dark:text-slate-400"
                  }
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-sm font-medium text-slate-700 dark:text-slate-300"
                  },
                  "text": "$t:board.guest_password"
                }
              ]
            },
            {
              "type": "basic",
              "name": "Input",
              "props": {
                "type": "password",
                "placeholder": "$t:board.password_verify.placeholder",
                "className": "w-full px-4 py-2 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-800 text-slate-900 dark:text-white focus:ring-2 focus:ring-teal-500",
                "value": "{{_local.verifyPassword ?? ''}}"
              },
              "actions": [
                {
                  "type": "change",
                  "handler": "setState",
                  "params": {
                    "target": "local",
                    "verifyPassword": "{{$event.target.value}}"
                  }
                }
              ]
            }
          ]
        },
        {
          "type": "basic",
          "name": "Div",
          "if": "{{_local.passwordError}}",
          "props": {
            "className": "text-sm text-red-500"
          },
          "text": "{{_local.passwordError}}"
        },
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "flex justify-end gap-3"
          },
          "children": [
            {
              "type": "basic",
              "name": "Button",
              "props": {
                "className": "px-4 py-2 border border-slate-300 dark:border-slate-600 text-slate-700 dark:text-slate-300 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-700 cursor-pointer"
              },
              "actions": [
                {
                  "type": "click",
                  "handler": "navigate",
                  "params": {
                    "path": "/board/{{route.slug}}/{{route.id}}"
                  }
                }
              ],
              "text": "$t:common.cancel"
            },
            {
              "type": "basic",
              "name": "Button",
              "props": {
                "disabled": "{{_local.isVerifying || !_local.verifyPassword}}",
                "className": "px-4 py-2 bg-teal-600 dark:bg-teal-500 text-white rounded-lg font-medium hover:bg-teal-700 dark:hover:bg-teal-600 disabled:opacity-50 disabled:cursor-not-allowed"
              },
              "actions": [
                {
                  "type": "click",
                  "handler": "sequence",
                  "actions": [
                    {
                      "handler": "setState",
                      "params": {
                        "target": "local",
                        "isVerifying": true,
                        "passwordError": ""
                      }
                    },
                    {
                      "handler": "apiCall",
                      "target": "/api/modules/sirsoft-board/boards/{{route.slug}}/posts/{{route.id}}/verify-password-for-modify",
                      "params": {
                        "method": "POST",
                        "body": {
                          "password": "{{_local.verifyPassword}}"
                        }
                      },
                      "onSuccess": [
                        {
                          "handler": "setState",
                          "params": {
                            "target": "local",
                            "passwordVerified": true,
                            "isVerifying": false,
                            "verificationToken": "{{result?.data?.verification_token}}",
                            "verifyPassword": ""
                          }
                        },
                        {
                          "handler": "refetchDataSource",
                          "params": {
                            "dataSourceId": "form_meta"
                          }
                        },
                        {
                          "handler": "refetchDataSource",
                          "params": {
                            "dataSourceId": "form_data"
                          }
                        }
                      ],
                      "onError": [
                        {
                          "handler": "setState",
                          "params": {
                            "target": "local",
                            "isVerifying": false,
                            "passwordError": "$t:board.password_verify.incorrect"
                          }
                        }
                      ]
                    }
                  ]
                }
              ],
              "children": [
                {
                  "type": "composite",
                  "name": "Icon",
                  "if": "{{_local.isVerifying}}",
                  "props": {
                    "name": "spinner",
                    "size": "sm",
                    "className": "animate-spin mr-2"
                  }
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "text": "$t:board.password_verify.confirm"
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
