{
  "meta": {
    "is_partial": true
  },
  "type": "basic",
  "name": "Form",
  "props": {
    "id": "form",
    "className": "{{!form_meta?.data || !form_data?.data ? 'space-y-6 opacity-50 pointer-events-none' : 'space-y-6'}}"
  },
  "children": [
    {
      "type": "basic",
      "name": "Div",
      "if": "{{_local.errors && (typeof _local.errors === 'string' || Object.keys(_local.errors).length > 0)}}",
      "props": {
        "className": "bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg p-4 mb-6"
      },
      "children": [
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "flex items-start gap-3"
          },
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "props": {
                "name": "triangle-exclamation",
                "className": "text-red-600 dark:text-red-400 mt-0.5",
                "size": "lg"
              }
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex-1"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "H3",
                  "props": {
                    "className": "text-sm font-semibold text-red-800 dark:text-red-200 mb-2"
                  },
                  "text": "$t:common.validation_errors"
                },
                {
                  "type": "basic",
                  "name": "Ul",
                  "props": {
                    "className": "list-disc list-inside space-y-1 text-sm text-red-700 dark:text-red-300"
                  },
                  "iteration": {
                    "source": "typeof _local.errors === 'string' ? [_local.errors] : Object.entries(_local.errors ?? {}).flatMap(([field, messages]) => Array.isArray(messages) ? messages : [messages])",
                    "item_var": "message"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Li",
                      "props": {
                        "className": "text-sm text-red-700 dark:text-red-300"
                      },
                      "text": "{{message}}"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "if": "{{route.id && form_data?.data?.author}}",
      "props": {
        "className": "flex items-center gap-3 p-4 bg-slate-50 dark:bg-slate-800/50 rounded-lg border border-slate-200 dark:border-slate-700"
      },
      "children": [
        {
          "type": "composite",
          "name": "Avatar",
          "props": {
            "author": "{{form_data?.data?.author}}",
            "size": "md"
          }
        },
        {
          "type": "basic",
          "name": "Div",
          "children": [
            {
              "type": "composite",
              "name": "UserInfo",
              "props": {
                "userId": "{{form_data?.data?.author?.uuid}}",
                "name": "{{form_data?.data?.author?.name}}",
                "isGuest": "{{!form_data?.data?.author?.uuid}}",
                "showDropdown": false,
                "clickable": false,
                "className": "text-sm font-medium"
              }
            },
            {
              "type": "basic",
              "name": "P",
              "props": {
                "className": "text-xs text-slate-500 dark:text-slate-400 mt-0.5"
              },
              "text": "$t:board.created_at: {{form_data?.data?.created_at}}"
            }
          ]
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "if": "{{form_meta?.data?.board?.user_abilities?.can_manage || form_meta?.data?.board?.secret_mode === 'enabled' || form_meta?.data?.board?.secret_mode === 'always'}}",
      "children": [
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "grid grid-cols-1 md:grid-cols-2 gap-4"
          },
          "children": [
            {
              "type": "basic",
              "name": "Label",
              "if": "{{form_meta?.data?.board?.user_abilities?.can_manage && !_local.form?.parent_id}}",
              "props": {
                "className": "block bg-white dark:bg-slate-800 rounded-lg p-3 border border-slate-200 dark:border-slate-700 cursor-pointer hover:bg-slate-50 dark:hover:bg-slate-750 transition-colors"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex items-start gap-3"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Input",
                      "props": {
                        "type": "checkbox",
                        "name": "is_notice",
                        "className": "mt-0.5 w-4 h-4 text-teal-600 bg-slate-100 border-slate-300 rounded focus:ring-teal-500 dark:focus:ring-teal-600 dark:ring-offset-slate-800 focus:ring-2 dark:bg-slate-700 dark:border-slate-600"
                      }
                    },
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "flex-1"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Div",
                          "props": {
                            "className": "flex items-center gap-2 mb-1"
                          },
                          "children": [
                            {
                              "type": "basic",
                              "name": "Icon",
                              "props": {
                                "name": "bell",
                                "size": "sm",
                                "className": "text-teal-600 dark:text-teal-400"
                              }
                            },
                            {
                              "type": "basic",
                              "name": "Span",
                              "props": {
                                "className": "text-sm font-semibold text-slate-900 dark:text-white"
                              },
                              "text": "$t:board.form.is_notice"
                            }
                          ]
                        },
                        {
                          "type": "basic",
                          "name": "P",
                          "props": {
                            "className": "text-xs text-slate-500 dark:text-slate-400"
                          },
                          "text": "$t:board.form.notice_description"
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "type": "basic",
              "name": "Label",
              "if": "{{form_meta?.data?.board?.secret_mode === 'enabled'}}",
              "props": {
                "className": "block bg-white dark:bg-slate-800 rounded-lg p-3 border border-slate-200 dark:border-slate-700 cursor-pointer hover:bg-slate-50 dark:hover:bg-slate-750 transition-colors"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex items-start gap-3"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Input",
                      "props": {
                        "type": "checkbox",
                        "name": "is_secret",
                        "className": "mt-0.5 w-4 h-4 text-amber-600 bg-slate-100 border-slate-300 rounded focus:ring-amber-500 dark:focus:ring-amber-600 dark:ring-offset-slate-800 focus:ring-2 dark:bg-slate-700 dark:border-slate-600"
                      }
                    },
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "flex-1"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Div",
                          "props": {
                            "className": "flex items-center gap-2 mb-1"
                          },
                          "children": [
                            {
                              "type": "basic",
                              "name": "Icon",
                              "props": {
                                "name": "lock",
                                "size": "sm",
                                "className": "text-amber-600 dark:text-amber-400"
                              }
                            },
                            {
                              "type": "basic",
                              "name": "Span",
                              "props": {
                                "className": "text-sm font-semibold text-slate-900 dark:text-white"
                              },
                              "text": "$t:board.form.secret_post"
                            }
                          ]
                        },
                        {
                          "type": "basic",
                          "name": "P",
                          "props": {
                            "className": "text-xs text-slate-500 dark:text-slate-400"
                          },
                          "text": "$t:board.form.secret_description"
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "if": "{{form_meta?.data?.board?.secret_mode === 'always'}}",
              "props": {
                "className": "bg-slate-100 dark:bg-slate-800 rounded-lg p-3 border border-slate-200 dark:border-slate-700 opacity-75"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Input",
                  "props": {
                    "type": "hidden",
                    "name": "is_secret",
                    "value": "true"
                  }
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex items-start gap-3"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Input",
                      "props": {
                        "type": "checkbox",
                        "checked": true,
                        "disabled": true,
                        "className": "mt-0.5 w-4 h-4 text-amber-600 bg-slate-100 border-slate-300 rounded dark:bg-slate-700 dark:border-slate-600 opacity-50 cursor-not-allowed"
                      }
                    },
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "flex-1"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Div",
                          "props": {
                            "className": "flex items-center gap-2 mb-1"
                          },
                          "children": [
                            {
                              "type": "basic",
                              "name": "Icon",
                              "props": {
                                "name": "lock",
                                "size": "sm",
                                "className": "text-amber-600 dark:text-amber-400"
                              }
                            },
                            {
                              "type": "basic",
                              "name": "Span",
                              "props": {
                                "className": "text-sm font-semibold text-slate-900 dark:text-white"
                              },
                              "text": "$t:board.form.secret_post"
                            }
                          ]
                        },
                        {
                          "type": "basic",
                          "name": "P",
                          "props": {
                            "className": "text-xs text-slate-500 dark:text-slate-400"
                          },
                          "text": "$t:board.form.secret_always_description"
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "if": "{{form_meta?.data?.board?.categories?.length > 0}}",
      "children": [
        {
          "type": "basic",
          "name": "Label",
          "props": {
            "className": "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1"
          },
          "text": "$t:board.form.category"
        },
        {
          "type": "basic",
          "name": "Select",
          "props": {
            "name": "category",
            "value": "{{_local.form?.category ?? ''}}",
            "className": "w-full px-4 py-2 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-800 text-slate-900 dark:text-white focus:ring-2 focus:ring-teal-500",
            "options": "{{[{value: '', label: $t('board.form.select_category')}, ...(form_meta?.data?.board?.categories ?? []).map(c => ({value: c, label: c}))]}}"
          },
          "actions": [
            {
              "event": "change",
              "handler": "setState",
              "params": {
                "target": "local",
                "form": {
                  "category": "{{$event.target.value}}"
                },
                "hasChanges": true
              }
            }
          ]
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "children": [
        {
          "type": "basic",
          "name": "Label",
          "props": {
            "className": "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1"
          },
          "children": [
            {
              "type": "basic",
              "name": "Span",
              "text": "$t:board.form.title"
            },
            {
              "type": "basic",
              "name": "Span",
              "props": {
                "className": "text-red-500 ml-1"
              },
              "text": "*"
            }
          ]
        },
        {
          "type": "basic",
          "name": "Input",
          "props": {
            "type": "text",
            "name": "title",
            "placeholder": "$t:board.form.title_placeholder",
            "className": "w-full px-4 py-2 border rounded-lg bg-white dark:bg-slate-800 text-slate-900 dark:text-white focus:ring-2 {{_local.errors?.title ? 'border-red-500 dark:border-red-500 focus:ring-red-500' : 'border-slate-300 dark:border-slate-600 focus:ring-teal-500'}}"
          }
        },
        {
          "type": "basic",
          "name": "P",
          "if": "{{_local.errors?.title}}",
          "props": {
            "className": "mt-1 text-sm text-red-600 dark:text-red-400"
          },
          "text": "{{_local.errors?.title?.[0] ?? _local.errors?.title}}"
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "{{_local.errors?.content ? '[&_textarea]:!border-red-500 [&_textarea]:dark:!border-red-500 [&_textarea]:focus:!ring-red-500' : ''}}"
      },
      "children": [
        {
          "id": "content_section",
          "type": "extension_point",
          "name": "html_editor",
          "props": {
            "name": "content",
            "content": "{{_local.form?.content ?? ''}}",
            "isHtml": "{{(_local.form?.content_mode ?? 'text') === 'html'}}",
            "rows": 15,
            "placeholder": "$t:board.form.content_placeholder",
            "label": "$t:board.form.content",
            "showHtmlModeToggle": true
          },
          "default": [
            {
              "type": "composite",
              "name": "HtmlEditor",
              "props": {
                "name": "content",
                "content": "{{_local.form?.content ?? ''}}",
                "isHtml": "{{(_local.form?.content_mode ?? 'text') === 'html'}}",
                "rows": 15,
                "placeholder": "$t:board.form.content_placeholder",
                "label": "$t:board.form.content",
                "showHtmlModeToggle": true
              },
              "actions": [
                {
                  "event": "onIsHtmlChange",
                  "type": "change",
                  "handler": "setState",
                  "params": {
                    "target": "local",
                    "form": {
                      "content_mode": "{{$args[0].target.checked ? 'html' : 'text'}}"
                    }
                  }
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "basic",
      "name": "P",
      "if": "{{_local.errors?.content}}",
      "props": {
        "className": "mt-1 text-sm text-red-600 dark:text-red-400"
      },
      "text": "{{_local.errors?.content?.[0] ?? _local.errors?.content}}"
    },
    {
      "type": "basic",
      "name": "Div",
      "if": "{{form_meta?.data?.board?.use_file_upload === true && form_meta?.data?.board?.user_abilities?.can_upload}}",
      "children": [
        {
          "type": "basic",
          "name": "Label",
          "props": {
            "className": "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1"
          },
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "props": {
                "name": "paperclip",
                "size": "sm",
                "className": "inline mr-1"
              }
            },
            {
              "type": "basic",
              "name": "Span",
              "text": "$t:board.form.attachments"
            }
          ]
        },
        {
          "type": "basic",
          "name": "P",
          "props": {
            "className": "text-xs text-slate-500 dark:text-slate-400 mb-2"
          },
          "text": "$t:board.form.attachments_desc|maxFiles={{form_meta?.data?.board?.max_file_count ?? 5}}|maxSize={{form_meta?.data?.board?.max_file_size ?? 10}}"
        },
        {
          "type": "composite",
          "name": "FileUploader",
          "props": {
            "collection": "post_attachments",
            "maxFiles": "{{form_meta?.data?.board?.max_file_count ?? 5}}",
            "maxSize": "{{form_meta?.data?.board?.max_file_size ?? 10}}",
            "accept": "{{form_meta?.data?.board?.allowed_extensions ? '.' + form_meta?.data?.board?.allowed_extensions?.join(',.') : '.jpg,.jpeg,.png,.gif,.pdf,.zip'}}",
            "initialFiles": "{{form_meta?.data?.attachments ?? []}}",
            "autoUpload": false,
            "uploadTriggerEvent": "upload:board_attachments",
            "compact": true,
            "confirmBeforeRemove": true,
            "confirmRemoveTitle": "$t:board.posts.form.confirm_remove_attachment_title",
            "confirmRemoveMessage": "$t:board.posts.form.confirm_remove_attachment_message",
            "uploadParams": {
              "temp_key": "{{_local.tempKey}}"
            },
            "apiEndpoints": {
              "upload": "/api/modules/sirsoft-board/boards/{{route.slug}}/attachments",
              "delete": "/api/modules/sirsoft-board/boards/{{route.slug}}/attachments/:id",
              "reorder": "/api/modules/sirsoft-board/boards/{{route.slug}}/attachments/reorder"
            }
          },
          "actions": [
            {
              "event": "onFilesChange",
              "type": "change",
              "handler": "setState",
              "if": "{{!_local.hasChanges}}",
              "params": {
                "target": "local",
                "hasChanges": true
              }
            },
            {
              "event": "onUploadError",
              "type": "change",
              "handler": "sequence",
              "actions": [
                {
                  "handler": "setState",
                  "params": {
                    "target": "local",
                    "uploadError": "{{$args[0]}}",
                    "isSaving": false
                  }
                },
                {
                  "handler": "toast",
                  "params": {
                    "type": "error",
                    "message": "{{$args[0]}}",
                    "icon": "triangle-exclamation"
                  }
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "flex justify-end gap-3 pt-4 border-t border-slate-200 dark:border-slate-700"
      },
      "children": [
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "type": "button",
            "className": "px-4 py-2 border border-slate-300 dark:border-slate-600 text-slate-700 dark:text-slate-300 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-700 cursor-pointer"
          },
          "actions": [
            {
              "type": "click",
              "handler": "navigate",
              "params": {
                "path": "{{route.id ? '/board/' + route.slug + '/' + route.id : '/board/' + route.slug}}"
              }
            }
          ],
          "text": "$t:common.cancel"
        },
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "type": "button",
            "disabled": "{{_local?.isSaving}}",
            "className": "flex items-center gap-2 px-4 py-2 bg-teal-600 dark:bg-teal-500 text-white rounded-lg font-medium hover:bg-teal-700 dark:hover:bg-teal-600 disabled:opacity-50 disabled:cursor-not-allowed"
          },
          "actions": [
            {
              "type": "click",
              "handler": "sequence",
              "actions": [
                {
                  "handler": "setState",
                  "params": {
                    "target": "local",
                    "isSaving": true,
                    "errors": null
                  }
                },
                {
                  "handler": "emitEvent",
                  "params": {
                    "event": "upload:board_attachments"
                  }
                },
                {
                  "handler": "apiCall",
                  "target": "{{route.id ? '/api/modules/sirsoft-board/boards/' + route.slug + '/posts/' + route.id : '/api/modules/sirsoft-board/boards/' + route.slug + '/posts'}}",
                  "auth_required": true,
                  "params": {
                    "method": "{{route.id ? 'PUT' : 'POST'}}",
                    "body": "{{Object.assign({}, _local.form, { temp_key: _local?.tempKey })}}"
                  },
                  "onSuccess": [
                    {
                      "handler": "setState",
                      "params": {
                        "target": "local",
                        "isSaving": false,
                        "hasChanges": false,
                        "errors": null
                      }
                    },
                    {
                      "handler": "toast",
                      "params": {
                        "type": "success",
                        "message": "{{route?.id ? '$t:board.post_updated' : '$t:board.post_created'}}"
                      }
                    },
                    {
                      "handler": "navigate",
                      "params": {
                        "path": "/board/{{route?.slug}}/{{result?.data?.id}}"
                      }
                    }
                  ],
                  "onError": [
                    {
                      "handler": "setState",
                      "params": {
                        "target": "local",
                        "isSaving": false,
                        "errors": "{{error?.errors ?? null}}"
                      }
                    },
                    {
                      "handler": "toast",
                      "params": {
                        "type": "error",
                        "message": "{{error?.message ?? '$t:common.error_occurred'}}"
                      }
                    }
                  ]
                }
              ]
            }
          ],
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "if": "{{_local?.isSaving}}",
              "props": {
                "name": "spinner",
                "size": "sm",
                "className": "animate-spin"
              }
            },
            {
              "type": "basic",
              "name": "Span",
              "text": "{{_local?.isSaving ? '$t:common.saving' : (route?.id ? '$t:common.save' : '$t:board.form.submit')}}"
            }
          ]
        }
      ]
    }
  ]
}
