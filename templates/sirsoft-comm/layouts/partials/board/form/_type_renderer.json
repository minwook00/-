{
  "meta": {
    "is_partial": true
  },
  "type": "basic",
  "name": "Div",
  "if": "{{!form_meta?.data?.requires_password || _local.passwordVerified || form_meta?.data?.board?.user_abilities?.can_manage}}",
  "children": [
    {
      "type": "basic",
      "name": "Div",
      "if": "{{form_meta?.data?.board?.type === 'basic' || !['gallery','card'].includes(form_meta?.data?.board?.type ?? 'basic')}}",
      "children": [
        {
          "partial": "partials/board/types/basic/form.json"
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "if": "{{form_meta?.data?.board?.type === 'gallery'}}",
      "children": [
        {
          "partial": "partials/board/types/basic/form.json"
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "if": "{{form_meta?.data?.board?.type === 'card'}}",
      "children": [
        {
          "partial": "partials/board/types/basic/form.json"
        }
      ]
    }
  ]
}
