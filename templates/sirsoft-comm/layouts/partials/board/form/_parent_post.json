{
  "meta": {
    "is_partial": true
  },
  "id": "parent_post_card",
  "type": "basic",
  "name": "Div",
  "if": "{{(form_data?.data?.parent_id || query?.parent_id) && form_meta?.data?.parent_post?.id}}",
  "props": {
    "className": "mb-6 p-4 bg-slate-50 dark:bg-slate-700/50 border-l-4 border-slate-400 dark:border-slate-500 rounded-r-lg"
  },
  "children": [
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "flex items-center gap-2 mb-3"
      },
      "children": [
        {
          "type": "basic",
          "name": "Icon",
          "props": {
            "name": "reply",
            "className": "w-4 h-4 text-teal-600 dark:text-teal-400"
          }
        },
        {
          "type": "basic",
          "name": "Span",
          "props": {
            "className": "text-sm font-semibold text-slate-900 dark:text-white"
          },
          "text": "$t:board.form.reply_to"
        },
        {
          "type": "basic",
          "name": "Badge",
          "if": "{{form_meta?.data?.parent_post?.is_notice}}",
          "props": {
            "variant": "danger"
          },
          "text": "$t:board.post.notice"
        },
        {
          "type": "basic",
          "name": "Badge",
          "if": "{{form_meta?.data?.parent_post?.is_secret}}",
          "props": {
            "variant": "warning"
          },
          "text": "$t:board.post.secret"
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "flex items-center gap-2 mb-2"
      },
      "children": [
        {
          "type": "basic",
          "name": "H4",
          "props": {
            "className": "text-base font-semibold text-slate-900 dark:text-white"
          },
          "text": "{{form_meta?.data?.parent_post?.title}}"
        },
        {
          "type": "basic",
          "name": "A",
          "props": {
            "href": "/board/{{route.slug}}/{{form_meta?.data?.parent_post?.id}}",
            "title": "$t:board.form.view_original",
            "className": "text-teal-600 dark:text-teal-400 hover:text-teal-700 dark:hover:text-teal-300 transition-colors"
          },
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "props": {
                "name": "arrow-up-right-from-square",
                "className": "w-3.5 h-3.5"
              }
            }
          ]
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "flex items-center gap-2 text-xs text-slate-500 dark:text-slate-400 mb-3"
      },
      "children": [
        {
          "type": "basic",
          "name": "Span",
          "text": "{{form_meta?.data?.parent_post?.author?.name ?? '$t:board.unknown_author'}}"
        },
        {
          "type": "basic",
          "name": "Span",
          "text": "·"
        },
        {
          "type": "basic",
          "name": "Span",
          "text": "{{form_meta?.data?.parent_post?.created_at}}"
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "if": "{{form_meta?.data?.parent_post?.content}}",
      "props": {
        "className": "bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded p-3"
      },
      "children": [
        {
          "type": "extension_point",
          "name": "html_content",
          "props": {
            "content": "{{form_meta?.data?.parent_post?.content ?? ''}}",
            "isHtml": "{{(form_meta?.data?.parent_post?.content_mode ?? 'text') === 'html'}}",
            "className": "{{_local.parentPostExpanded ? '' : 'line-clamp-3'}} text-sm text-slate-600 dark:text-slate-300 mb-2"
          },
          "default": [
            {
              "type": "composite",
              "name": "HtmlContent",
              "props": {
                "content": "{{form_meta?.data?.parent_post?.content ?? ''}}",
                "isHtml": "{{(form_meta?.data?.parent_post?.content_mode ?? 'text') === 'html'}}",
                "className": "{{_local.parentPostExpanded ? '' : 'line-clamp-3'}} text-sm text-slate-600 dark:text-slate-300 mb-2"
              }
            }
          ]
        },
        {
          "type": "basic",
          "name": "Button",
          "if": "{{(form_meta?.data?.parent_post?.content?.length ?? 0) > 150}}",
          "props": {
            "type": "button",
            "className": "text-xs text-teal-600 dark:text-teal-400 hover:text-teal-700 dark:hover:text-teal-300 font-medium transition-colors flex items-center gap-1"
          },
          "actions": [
            {
              "type": "click",
              "handler": "setState",
              "params": {
                "target": "local",
                "parentPostExpanded": "{{!_local.parentPostExpanded}}"
              }
            }
          ],
          "children": [
            {
              "type": "basic",
              "name": "Span",
              "text": "{{_local.parentPostExpanded ? '$t:board.form.hide_content' : '$t:board.form.show_full_content'}}"
            },
            {
              "type": "basic",
              "name": "Icon",
              "props": {
                "name": "{{_local.parentPostExpanded ? 'chevron-up' : 'chevron-down'}}",
                "className": "w-3 h-3"
              }
            }
          ]
        }
      ]
    }
  ]
}
