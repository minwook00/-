{
  "meta": {
    "is_partial": true
  },
  "type": "basic",
  "name": "Div",
  "children": [
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "flex justify-between items-start mb-6"
      },
      "children": [
        {
          "type": "basic",
          "name": "Div",
          "children": [
            {
              "type": "basic",
              "name": "H1",
              "props": {
                "className": "text-2xl font-bold text-slate-900 dark:text-white"
              },
              "text": "{{posts?.data?.board?.name ?? ''}}"
            },
            {
              "type": "basic",
              "name": "P",
              "if": "{{posts?.data?.board?.description}}",
              "props": {
                "className": "text-slate-600 dark:text-slate-400 mt-1"
              },
              "text": "{{posts?.data?.board?.description}}"
            }
          ]
        },
        {
          "partial": "../../index/_write_button.json"
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "flex flex-col sm:flex-row items-stretch sm:items-center justify-between gap-3 mb-4"
      },
      "children": [
        {
          "type": "basic",
          "name": "Select",
          "if": "{{posts?.data?.board?.categories && posts?.data?.board?.categories.length > 0}}",
          "props": {
            "value": "{{query.category || 'all'}}",
            "className": "w-full sm:w-auto sm:min-w-48 px-3 py-2 bg-white dark:bg-slate-800 border border-slate-300 dark:border-slate-600 rounded-lg text-slate-900 dark:text-white text-sm",
            "options": "{{[{value:'all', label:'$t:board.filter.category_all'},{value:'unclassified', label:'$t:board.filter.category_unclassified'}].concat((posts?.data?.board?.categories ?? []).map(function(c){return{value:c,label:c};}))}}"
          },
          "actions": [
            {
              "type": "change",
              "handler": "navigate",
              "params": {
                "path": "/board/{{route.slug}}",
                "mergeQuery": true,
                "query": {
                  "category": "{{$event.target.value === 'all' ? '' : $event.target.value}}",
                  "page": 1
                }
              }
            }
          ]
        },
        {
          "type": "basic",
          "name": "Button",
          "if": "{{posts?.data?.abilities?.can_view_deleted}}",
          "props": {
            "type": "button",
            "className": "{{query.del === '1' ? 'inline-flex items-center gap-1.5 px-3 py-2 border-2 border-teal-600 dark:border-teal-400 bg-teal-50 dark:bg-teal-900/30 text-teal-700 dark:text-teal-300 rounded-lg text-sm font-medium' : 'inline-flex items-center gap-1.5 px-3 py-2 border border-slate-300 dark:border-slate-600 text-slate-700 dark:text-slate-300 rounded-lg text-sm hover:bg-slate-50 dark:hover:bg-slate-700'}}"
          },
          "actions": [
            {
              "type": "click",
              "handler": "navigate",
              "params": {
                "path": "/board/{{route.slug}}",
                "mergeQuery": true,
                "query": {
                  "del": "{{query.del === '1' ? '' : '1'}}",
                  "page": 1
                }
              }
            }
          ],
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "props": {
                "name": "eye",
                "size": "sm"
              }
            },
            {
              "type": "basic",
              "name": "Span",
              "text": "$t:board.filter.include_deleted"
            }
          ]
        },
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "w-full sm:w-auto sm:ml-auto"
          },
          "children": [
            {
              "type": "composite",
              "name": "SearchBar",
              "props": {
                "name": "search",
                "placeholder": "$t:board.search_placeholder",
                "value": "{{query.search || ''}}",
                "showButton": false,
                "className": "w-full sm:w-64"
              },
              "actions": [
                {
                  "type": "submit",
                  "handler": "navigate",
                  "params": {
                    "path": "/board/{{route.slug}}",
                    "mergeQuery": true,
                    "query": {
                      "search": "{{$event.target.search.value}}",
                      "page": 1
                    }
                  }
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "layout",
      "name": "Grid",
      "props": {
        "cols": 1,
        "gap": 4,
        "className": "grid-cols-1"
      },
      "responsive": {
        "tablet": {
          "props": {
            "cols": 2,
            "gap": 4,
            "className": "grid-cols-2"
          }
        },
        "desktop": {
          "props": {
            "cols": 3,
            "gap": 4,
            "className": "grid-cols-3"
          }
        }
      },
      "children": [
        {
          "type": "basic",
          "name": "Button",
          "iteration": {
            "source": "{{posts?.data?.data ?? []}}",
            "item_var": "post"
          },
          "props": {
            "className": "block w-full text-left rounded-xl shadow-sm relative aspect-[4/3] group cursor-pointer border border-slate-200 dark:border-slate-700 hover:shadow-lg hover:border-teal-300 dark:hover:border-teal-700 transition-all duration-200"
          },
          "actions": [
            {
              "type": "click",
              "handler": "navigate",
              "params": {
                "path": "/board/{{route.slug}}/{{post.id}}"
              }
            }
          ],
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "absolute inset-0 rounded-xl overflow-hidden"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Img",
                  "if": "{{post?.thumbnail}}",
                  "props": {
                    "src": "{{post?.thumbnail}}",
                    "alt": "{{post?.title}}",
                    "className": "w-full h-full object-cover group-hover:scale-105 transition-transform duration-200"
                  }
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "if": "{{!post?.thumbnail}}",
                  "props": {
                    "className": "w-full h-full bg-slate-700 dark:bg-slate-800 flex items-center justify-center"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Icon",
                      "props": {
                        "name": "image",
                        "size": "2x",
                        "className": "text-slate-400 dark:text-slate-500"
                      }
                    }
                  ]
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "if": "{{post?.status === 'blinded' || post?.deleted_at}}",
              "props": {
                "className": "absolute inset-0 bg-slate-900/40 z-10"
              }
            },
            {
              "type": "basic",
              "name": "Div",
              "if": "{{post?.is_secret && !post?.abilities?.can_view}}",
              "props": {
                "className": "absolute inset-0 bg-slate-900/50 flex items-center justify-center z-10"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Icon",
                  "props": {
                    "name": "lock",
                    "size": "2x",
                    "className": "text-white"
                  }
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "if": "{{post?.category || post?.is_notice || post?.is_new}}",
              "props": {
                "className": "absolute inset-x-0 top-0 flex items-start justify-between p-2 z-20"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex items-center gap-1 flex-wrap"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Span",
                      "if": "{{post?.is_notice}}",
                      "props": {
                        "className": "inline-flex items-center gap-1 px-2 py-0.5 rounded text-sm font-bold bg-teal-600 text-white dark:bg-teal-500 flex-shrink-0"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Icon",
                          "props": {
                            "name": "bell",
                            "size": "xs",
                            "className": "text-white"
                          }
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "text": "$t:board.notice"
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "if": "{{post?.category}}",
                      "props": {
                        "className": "inline-flex items-center px-2 py-0.5 rounded text-sm font-medium bg-black/40 text-white backdrop-blur-sm flex-shrink-0"
                      },
                      "text": "{{post?.category}}"
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "if": "{{post?.is_new}}",
                  "props": {
                    "className": "px-1.5 py-0.5 text-xs font-bold bg-red-500 text-white rounded flex-shrink-0"
                  },
                  "text": "$t:board.new_badge_short"
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "absolute inset-x-0 bottom-0 z-30 px-3 pt-10 pb-3 rounded-b-xl bg-gradient-to-t from-black/90 via-black/60 to-transparent"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex items-center gap-1.5 min-w-0 mb-1.5"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Icon",
                      "if": "{{post?.status === 'blinded'}}",
                      "props": {
                        "name": "eye-slash",
                        "size": "sm",
                        "className": "text-orange-300 flex-shrink-0"
                      }
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "if": "{{post?.is_reply}}",
                      "props": {
                        "className": "inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-teal-500/80 text-white flex-shrink-0"
                      },
                      "text": "$t:board.reply_badge_short"
                    },
                    {
                      "type": "basic",
                      "name": "Icon",
                      "if": "{{post?.is_secret}}",
                      "props": {
                        "name": "lock",
                        "size": "sm",
                        "className": "text-slate-300 flex-shrink-0"
                      }
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "text-base font-semibold truncate transition-colors {{(post?.status === 'blinded' || post?.deleted_at) ? 'text-slate-400' : 'text-white'}}"
                      },
                      "text": "{{post?.title}}"
                    },
                    {
                      "type": "basic",
                      "name": "Icon",
                      "if": "{{post?.has_attachment}}",
                      "props": {
                        "name": "paperclip",
                        "size": "sm",
                        "className": "text-slate-300 flex-shrink-0"
                      }
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "if": "{{post?.deleted_at}}",
                      "props": {
                        "className": "inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-300 flex-shrink-0"
                      },
                      "text": "$t:board.post.deleted_badge"
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex items-center justify-between text-xs"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "flex items-center gap-1.5 min-w-0"
                      },
                      "children": [
                        {
                          "type": "composite",
                          "name": "Avatar",
                          "props": {
                            "author": "{{post?.author}}",
                            "size": "xs",
                            "className": "{{(post?.status === 'blinded' || post?.deleted_at) ? 'opacity-40' : ''}}"
                          }
                        },
                        {
                          "type": "composite",
                          "name": "UserInfo",
                          "props": {
                            "author": "{{post?.author}}",
                            "showDropdown": true,
                            "stopPropagation": true,
                            "className": "text-xs font-medium {{(post?.status === 'blinded' || post?.deleted_at) ? 'text-slate-400' : 'text-slate-200'}}"
                          }
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "text-slate-400 flex-shrink-0"
                          },
                          "text": "·"
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "flex-shrink-0 {{(post?.status === 'blinded' || post?.deleted_at) ? 'text-slate-400' : 'text-slate-300'}}",
                            "title": "{{post?.created_at ?? ''}}"
                          },
                          "text": "{{post?.created_at_formatted ?? ''}}"
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "flex items-center gap-2 flex-shrink-0"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "flex items-center gap-0.5 {{(post?.status === 'blinded' || post?.deleted_at) ? 'text-slate-400' : 'text-slate-300'}}"
                          },
                          "children": [
                            {
                              "type": "basic",
                              "name": "Icon",
                              "props": {
                                "name": "eye",
                                "size": "xs"
                              }
                            },
                            {
                              "type": "basic",
                              "name": "Span",
                              "text": "{{post?.view_count ?? 0}}"
                            }
                          ]
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "if": "{{post?.comment_count > 0}}",
                          "props": {
                            "className": "flex items-center gap-0.5 {{(post?.status === 'blinded' || post?.deleted_at) ? 'text-slate-400' : 'text-teal-300'}}"
                          },
                          "children": [
                            {
                              "type": "basic",
                              "name": "Icon",
                              "props": {
                                "name": "message",
                                "size": "xs"
                              }
                            },
                            {
                              "type": "basic",
                              "name": "Span",
                              "text": "{{post?.comment_count ?? 0}}"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "partial": "../../index/_empty_states.json"
    },
    {
      "type": "composite",
      "name": "Pagination",
      "props": {
        "currentPage": "{{posts?.data?.pagination?.current_page ?? 1}}",
        "totalPages": "{{posts?.data?.pagination?.last_page ?? 1}}",
        "className": "mt-6 justify-center"
      },
      "actions": [
        {
          "event": "onPageChange",
          "handler": "navigate",
          "params": {
            "path": "/board/{{route?.slug}}",
            "mergeQuery": true,
            "query": {
              "page": "{{$args[0]}}",
              "category": "{{query.category}}",
              "filters[0][field]": "{{query['filters[0][field]']}}",
              "filters[0][value]": "{{query['filters[0][value]']}}",
              "filters[0][operator]": "{{query['filters[0][operator]']}}"
            }
          }
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "flex justify-end mt-4"
      },
      "children": [
        {
          "partial": "../../index/_write_button.json"
        }
      ]
    }
  ]
}
