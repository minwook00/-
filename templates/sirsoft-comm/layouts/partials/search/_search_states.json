{
  "meta": {
    "is_partial": true
  },
  "type": "basic",
  "name": "Div",
  "children": [
    {
      "type": "basic",
      "name": "Div",
      "if": "{{query?.q && searchResults?.data}}",
      "props": {
        "className": "mb-4"
      },
      "children": [
        {
          "type": "basic",
          "name": "P",
          "props": {
            "className": "text-sm text-slate-600 dark:text-slate-400 flex items-baseline gap-1"
          },
          "children": [
            {
              "type": "basic",
              "name": "Span",
              "props": {
                "className": "text-teal-600 dark:text-teal-400 font-medium"
              },
              "text": "\"{{query?.q}}\""
            },
            {
              "type": "basic",
              "name": "Span",
              "text": "$t:search.results"
            },
            {
              "type": "basic",
              "name": "Span",
              "props": {
                "className": "font-medium"
              },
              "text": "{{(searchResults.data.total ?? 0) | number}}"
            },
            {
              "type": "basic",
              "name": "Span",
              "text": "$t:search.result_count_suffix"
            }
          ]
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "if": "{{!query?.q}}",
      "props": {
        "className": "py-16 text-center"
      },
      "children": [
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "mb-5 text-slate-300 dark:text-slate-600"
          },
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "props": {
                "name": "search",
                "size": "4x"
              }
            }
          ]
        },
        {
          "type": "basic",
          "name": "H3",
          "props": {
            "className": "text-lg font-medium text-slate-900 dark:text-white mb-2"
          },
          "text": "$t:search.initial.title"
        },
        {
          "type": "basic",
          "name": "P",
          "props": {
            "className": "text-sm text-slate-500 dark:text-slate-400 mb-6"
          },
          "text": "$t:search.initial.description"
        },
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "max-w-md mx-auto bg-slate-50 dark:bg-slate-800 rounded-lg p-4 text-left"
          },
          "children": [
            {
              "type": "basic",
              "name": "H4",
              "props": {
                "className": "text-sm font-medium text-slate-700 dark:text-slate-300 mb-3 flex items-center gap-2"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Icon",
                  "props": {
                    "name": "lightbulb",
                    "size": "sm"
                  }
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "text": "$t:search.initial.hint_title"
                }
              ]
            },
            {
              "type": "basic",
              "name": "Ul",
              "props": {
                "className": "space-y-2 text-sm text-slate-600 dark:text-slate-400"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Li",
                  "props": {
                    "className": "flex items-center gap-2"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Icon",
                      "props": {
                        "name": "check",
                        "size": "sm",
                        "className": "text-green-500 flex-shrink-0"
                      }
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "text": "$t:search.initial.hint_1"
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Li",
                  "props": {
                    "className": "flex items-center gap-2"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Icon",
                      "props": {
                        "name": "check",
                        "size": "sm",
                        "className": "text-green-500 flex-shrink-0"
                      }
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "text": "$t:search.initial.hint_2"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "if": "{{query?.q && searchResults?.data && (searchResults?.data?.total ?? 0) === 0 && (_global.searchActiveTab ?? 'all') === 'all'}}",
      "props": {
        "className": "py-16 text-center"
      },
      "children": [
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "mb-5 text-slate-300 dark:text-slate-600"
          },
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "props": {
                "name": "search",
                "size": "4x"
              }
            }
          ]
        },
        {
          "type": "basic",
          "name": "H3",
          "props": {
            "className": "text-lg font-medium text-slate-900 dark:text-white mb-2"
          },
          "text": "$t:search.empty.all"
        },
        {
          "type": "basic",
          "name": "P",
          "props": {
            "className": "text-sm text-slate-500 dark:text-slate-400"
          },
          "text": "$t:search.empty.suggestion"
        }
      ]
    }
  ]
}
