{
  "meta": {
    "is_partial": true,
    "description": "플러그인 설치 확인 모달"
  },
  "id": "plugin_install_modal",
  "type": "composite",
  "name": "Modal",
  "props": {
    "title": "$t:admin.plugins.modals.install_title",
    "size": "small"
  },
  "children": [
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "py-2"
      },
      "children": [
        {
          "type": "basic",
          "name": "P",
          "props": {
            "className": "text-gray-700 dark:text-gray-300"
          },
          "text": "$t:admin.plugins.modals.install_confirm|name={{_global.selectedPlugin.name}}"
        },
        {
          "type": "basic",
          "name": "P",
          "props": {
            "className": "mt-2 text-sm text-gray-500 dark:text-gray-400"
          },
          "text": "$t:admin.plugins.modals.install_description"
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "mt-4"
      },
      "children": [
        {
          "type": "basic",
          "name": "Label",
          "props": {
            "className": "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2"
          },
          "text": "$t:admin.plugins.modals.vendor_mode_label"
        },
        {
          "type": "basic",
          "name": "Select",
          "props": {
            "className": "w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white",
            "value": "{{_global.pluginInstallVendorMode ?? 'auto'}}",
            "options": [
              { "value": "auto", "label": "$t:admin.plugins.modals.vendor_mode_auto" },
              { "value": "composer", "label": "$t:admin.plugins.modals.vendor_mode_composer" },
              { "value": "bundled", "label": "$t:admin.plugins.modals.vendor_mode_bundled" }
            ]
          },
          "actions": [
            {
              "type": "change",
              "handler": "setState",
              "params": {
                "target": "global",
                "pluginInstallVendorMode": "{{$event.target.value}}"
              }
            }
          ]
        },
        {
          "type": "basic",
          "name": "P",
          "props": {
            "className": "mt-1 text-xs text-gray-500 dark:text-gray-400"
          },
          "text": "$t:admin.plugins.modals.vendor_mode_hint"
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "flex justify-end gap-3 mt-6"
      },
      "children": [
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "className": "px-4 py-2 bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 disabled:opacity-50 disabled:cursor-not-allowed",
            "disabled": "{{_global.isPluginInstalling}}"
          },
          "actions": [
            {
              "type": "click",
              "handler": "closeModal"
            }
          ],
          "children": [
            {
              "type": "basic",
              "name": "Span",
              "text": "$t:common.cancel"
            }
          ]
        },
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "className": "flex items-center gap-2 px-4 py-2 bg-gray-900 dark:bg-white text-white dark:text-gray-900 rounded-lg hover:bg-gray-800 dark:hover:bg-gray-100 disabled:opacity-50 disabled:cursor-not-allowed",
            "disabled": "{{_global.isPluginInstalling}}"
          },
          "actions": [
            {
              "type": "click",
              "handler": "sequence",
              "actions": [
                {
                  "handler": "setState",
                  "params": {
                    "target": "global",
                    "isPluginInstalling": true
                  }
                },
                {
                  "handler": "apiCall",
                  "auth_required": true,
                  "target": "/api/admin/plugins/install",
                  "params": {
                    "method": "POST",
                    "body": {
                      "plugin_name": "{{_global.selectedPlugin.identifier}}",
                      "vendor_mode": "{{_global.pluginInstallVendorMode ?? 'auto'}}"
                    }
                  },
                  "onSuccess": [
                    {
                      "handler": "setState",
                      "params": {
                        "target": "global",
                        "isPluginInstalling": false
                      }
                    },
                    {
                      "handler": "setState",
                      "params": {
                        "target": "global",
                        "selectedPlugin": null
                      }
                    },
                    {
                      "handler": "toast",
                      "params": {
                        "type": "success",
                        "message": "$t:admin.plugins.install_success"
                      }
                    },
                    {
                      "handler": "refetchDataSource",
                      "params": {
                        "dataSourceId": "plugins"
                      }
                    },
                    {
                      "handler": "refetchDataSource",
                      "params": {
                        "dataSourceId": "admin_menu"
                      }
                    },
                    {
                      "handler": "reloadExtensions"
                    },
                    {
                      "handler": "closeModal"
                    }
                  ],
                  "onError": [
                    {
                      "handler": "setState",
                      "params": {
                        "target": "global",
                        "isPluginInstalling": false
                      }
                    },
                    {
                      "handler": "toast",
                      "params": {
                        "type": "error",
                        "message": "{{error.message}}"
                      }
                    }
                  ]
                }
              ]
            }
          ],
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "if": "{{!_global.isPluginInstalling}}",
              "props": {
                "name": "download",
                "className": "w-4 h-4"
              }
            },
            {
              "type": "basic",
              "name": "Icon",
              "if": "{{_global.isPluginInstalling}}",
              "props": {
                "name": "spinner",
                "className": "w-4 h-4 animate-spin"
              }
            },
            {
              "type": "basic",
              "name": "Span",
              "text": "{{_global.isPluginInstalling ? '$t:admin.plugins.installing' : '$t:admin.plugins.actions.install'}}"
            }
          ]
        }
      ]
    }
  ]
}