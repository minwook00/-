{
  "meta": {
    "is_partial": true,
    "description": "환경설정 일반 탭 콘텐츠"
  },
  "id": "tab_content_general",
  "type": "basic",
  "name": "Div",
  "if": "{{(_global.activeSettingsTab || query.tab || 'general') === 'general'}}",
  "props": {
    "className": "mt-6 space-y-6"
  },
  "children": [
    {
      "id": "card_site_info",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-6"
      },
      "children": [
        {
          "type": "basic",
          "name": "H3",
          "props": {
            "className": "text-lg font-semibold text-gray-900 dark:text-white mb-1"
          },
          "text": "$t:admin.settings.general.site_info"
        },
        {
          "type": "basic",
          "name": "P",
          "props": {
            "className": "text-sm text-gray-500 dark:text-gray-400 mb-6"
          },
          "text": "$t:admin.settings.general.site_info_desc"
        },
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "grid grid-cols-1 md:grid-cols-2 gap-4"
          },
          "children": [
            {
              "id": "field_site_name",
              "type": "basic",
              "name": "Div",
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Span",
                      "text": "$t:admin.settings.general.site_name"
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "text-red-500 ml-1"
                      },
                      "text": "*"
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Input",
                  "props": {
                    "type": "text",
                    "name": "general.site_name",
                    "placeholder": "그누보드7",
                    "disabled": "{{_computed.isReadOnly}}",
                    "className": "{{_local.errors?.['general.site_name'] ? 'w-full px-3 py-2 border border-red-500 dark:border-red-500 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white text-sm focus:ring-2 focus:ring-red-500 focus:border-red-500 disabled:bg-gray-100 dark:disabled:bg-gray-800 disabled:text-gray-400 dark:disabled:text-gray-500 disabled:cursor-not-allowed' : 'w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 disabled:bg-gray-100 dark:disabled:bg-gray-800 disabled:text-gray-400 dark:disabled:text-gray-500 disabled:cursor-not-allowed'}}"
                  }
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "if": "{{_local.errors?.['general.site_name']}}",
                  "props": {
                    "className": "text-red-500 text-xs mt-1 block"
                  },
                  "text": "{{_local.errors?.['general.site_name']?.[0] ?? ''}}"
                }
              ]
            },
            {
              "id": "field_site_url",
              "type": "basic",
              "name": "Div",
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Span",
                      "text": "$t:admin.settings.general.site_url"
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "text-red-500 ml-1"
                      },
                      "text": "*"
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Input",
                  "props": {
                    "type": "url",
                    "name": "general.site_url",
                    "placeholder": "https://example.com",
                    "disabled": "{{_computed.isReadOnly}}",
                    "className": "{{_local.errors?.['general.site_url'] ? 'w-full px-3 py-2 border border-red-500 dark:border-red-500 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white text-sm focus:ring-2 focus:ring-red-500 focus:border-red-500 disabled:bg-gray-100 dark:disabled:bg-gray-800 disabled:text-gray-400 dark:disabled:text-gray-500 disabled:cursor-not-allowed' : 'w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 disabled:bg-gray-100 dark:disabled:bg-gray-800 disabled:text-gray-400 dark:disabled:text-gray-500 disabled:cursor-not-allowed'}}"
                  }
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "if": "{{_local.errors?.['general.site_url']}}",
                  "props": {
                    "className": "text-red-500 text-xs mt-1 block"
                  },
                  "text": "{{_local.errors?.['general.site_url']?.[0] ?? ''}}"
                }
              ]
            },
            {
              "id": "field_site_description",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "md:col-span-2"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1"
                  },
                  "text": "$t:admin.settings.general.site_description"
                },
                {
                  "type": "basic",
                  "name": "Textarea",
                  "props": {
                    "name": "general.site_description",
                    "rows": 2,
                    "placeholder": "$t:admin.settings.general.site_description_placeholder",
                    "disabled": "{{_computed.isReadOnly}}",
                    "className": "w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 disabled:bg-gray-100 dark:disabled:bg-gray-800 disabled:text-gray-400 dark:disabled:text-gray-500 disabled:cursor-not-allowed resize-none"
                  }
                }
              ]
            },
            {
              "id": "field_admin_email",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "md:col-span-2"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Span",
                      "text": "$t:admin.settings.general.admin_email"
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "text-red-500 ml-1"
                      },
                      "text": "*"
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Input",
                  "props": {
                    "type": "email",
                    "name": "general.admin_email",
                    "placeholder": "admin@example.com",
                    "disabled": "{{_computed.isReadOnly}}",
                    "className": "{{_local.errors?.['general.admin_email'] ? 'w-full px-3 py-2 border border-red-500 dark:border-red-500 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white text-sm focus:ring-2 focus:ring-red-500 focus:border-red-500 disabled:bg-gray-100 dark:disabled:bg-gray-800 disabled:text-gray-400 dark:disabled:text-gray-500 disabled:cursor-not-allowed' : 'w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 disabled:bg-gray-100 dark:disabled:bg-gray-800 disabled:text-gray-400 dark:disabled:text-gray-500 disabled:cursor-not-allowed'}}"
                  }
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "if": "{{_local.errors?.['general.admin_email']}}",
                  "props": {
                    "className": "text-red-500 text-xs mt-1 block"
                  },
                  "text": "{{_local.errors?.['general.admin_email']?.[0] ?? ''}}"
                }
              ]
            },
            {
              "id": "field_site_logo",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "md:col-span-2"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1"
                  },
                  "text": "$t:admin.settings.general.site_logo"
                },
                {
                  "type": "basic",
                  "name": "P",
                  "props": {
                    "className": "text-xs text-gray-500 dark:text-gray-400 mb-2"
                  },
                  "text": "$t:admin.settings.general.site_logo_desc"
                },
                {
                  "id": "site_logo_uploader",
                  "type": "composite",
                  "name": "FileUploader",
                  "props": {
                    "collection": "site_logo",
                    "disabled": "{{_computed.isReadOnly}}",
                    "maxFiles": 5,
                    "maxSize": "{{_global.settings?.upload?.max_file_size ?? _global.uploadSettings?.max_file_size ?? 10}}",
                    "accept": "{{_global.settings?.upload?.allowed_extensions_formatted ?? _global.uploadSettings?.allowed_extensions_formatted ?? '.jpg,.jpeg,.png,.gif,.svg,.webp'}}",
                    "imageCompression": {
                      "maxSizeMB": 1,
                      "maxWidthOrHeight": "{{_global.settings?.upload?.image_max_width ?? _global.uploadSettings?.image_max_width ?? 800}}"
                    },
                    "initialFiles": "{{settings?.data?.general?.site_logo ?? []}}",
                    "autoUpload": false,
                    "uploadTriggerEvent": "upload:site_logo",
                    "confirmBeforeRemove": true
                  },
                  "actions": [
                    {
                      "event": "onFilesChange",
                      "type": "change",
                      "if": "{{$args[0] && $args[0].length > 0}}",
                      "handler": "setState",
                      "params": {
                        "target": "local",
                        "hasChanges": true
                      }
                    },
                    {
                      "event": "onUploadComplete",
                      "type": "change",
                      "handler": "setState",
                      "params": {
                        "target": "local",
                        "hasChanges": true,
                        "form.general.site_logo": "{{[...(_local.form?.general?.site_logo ?? []), ...$args[0]]}}"
                      }
                    },
                    {
                      "event": "onUploadComplete",
                      "type": "custom",
                      "handler": "toast",
                      "params": {
                        "type": "success",
                        "message": "$t:attachment.upload_success"
                      }
                    },
                    {
                      "event": "onUploadError",
                      "type": "custom",
                      "handler": "toast",
                      "params": {
                        "type": "error",
                        "message": "{{$args[0]}}"
                      }
                    },
                    {
                      "event": "onRemove",
                      "type": "change",
                      "handler": "setState",
                      "params": {
                        "target": "local",
                        "hasChanges": true,
                        "form.general.site_logo": "{{(_local.form?.general?.site_logo ?? []).filter(item => item.id !== $args[0])}}"
                      }
                    },
                    {
                      "event": "onRemove",
                      "type": "custom",
                      "handler": "toast",
                      "params": {
                        "type": "info",
                        "message": "$t:attachment.deleted"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "card_localization",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-6"
      },
      "children": [
        {
          "type": "basic",
          "name": "H3",
          "props": {
            "className": "text-lg font-semibold text-gray-900 dark:text-white mb-1"
          },
          "text": "$t:admin.settings.general.localization"
        },
        {
          "type": "basic",
          "name": "P",
          "props": {
            "className": "text-sm text-gray-500 dark:text-gray-400 mb-6"
          },
          "text": "$t:admin.settings.general.localization_desc"
        },
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "grid grid-cols-1 md:grid-cols-2 gap-4"
          },
          "children": [
            {
              "id": "field_language",
              "type": "basic",
              "name": "Div",
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Span",
                      "text": "$t:admin.settings.general.default_language"
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "text-red-500 ml-1"
                      },
                      "text": "*"
                    }
                  ]
                },
                {
                  "type": "composite",
                  "name": "Select",
                  "props": {
                    "name": "general.language",
                    "className": "w-full",
                    "disabled": "{{_computed.isReadOnly}}",
                    "placeholder": "$t:admin.settings.general.select_language",
                    "options": [
                      { "label": "한국어", "value": "ko" },
                      { "label": "English", "value": "en" }
                    ],
                    "error": "{{_local.errors?.['general.language']?.[0] ?? ''}}"
                  }
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "if": "{{_local.errors?.['general.language']}}",
                  "props": {
                    "className": "text-red-500 text-xs mt-1 block"
                  },
                  "text": "{{_local.errors?.['general.language']?.[0] ?? ''}}"
                }
              ]
            },
            {
              "id": "field_timezone",
              "type": "basic",
              "name": "Div",
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Span",
                      "text": "$t:admin.settings.general.timezone"
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "text-red-500 ml-1"
                      },
                      "text": "*"
                    }
                  ]
                },
                {
                  "type": "composite",
                  "name": "Select",
                  "props": {
                    "name": "general.timezone",
                    "className": "w-full",
                    "disabled": "{{_computed.isReadOnly}}",
                    "placeholder": "$t:admin.settings.general.select_timezone",
                    "options": "{{_global.appConfig?.supportedTimezones ?? []}}",
                    "searchable": true,
                    "searchPlaceholder": "{{$t('common.search')}}",
                    "error": "{{_local.errors?.['general.timezone']?.[0] ?? ''}}"
                  }
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "if": "{{_local.errors?.['general.timezone']}}",
                  "props": {
                    "className": "text-red-500 text-xs mt-1 block"
                  },
                  "text": "{{_local.errors?.['general.timezone']?.[0] ?? ''}}"
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
