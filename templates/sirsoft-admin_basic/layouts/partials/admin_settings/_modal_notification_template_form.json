{
  "meta": {
    "is_partial": true,
    "description": "알림 템플릿 편집 모달 — 단일 채널 template 편집"
  },
  "id": "modal_notification_template_form",
  "type": "composite",
  "name": "Modal",
  "props": {
    "title": "$t:admin.settings.notification_definitions.edit_modal.title",
    "size": "xl",
    "closeOnOverlayClick": false
  },
  "children": [
    {
      "id": "template_form_container",
      "type": "basic",
      "name": "Div",
      "blur_until_loaded": "{{$parent._local.isSaving}}",
      "props": {
        "className": "flex flex-col max-h-[calc(90vh-140px)] -my-4"
      },
      "children": [
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "flex-1 overflow-y-auto space-y-5 pr-1"
          },
          "children": [
            {
              "id": "template_validation_error",
              "type": "basic",
              "name": "Div",
              "if": "{{$parent._local.templateErrors}}",
              "props": {
                "className": "bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg p-4"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex gap-3"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Icon",
                      "props": {
                        "name": "triangle-exclamation",
                        "size": "sm",
                        "className": "text-red-600 dark:text-red-400 flex-shrink-0 mt-0.5"
                      }
                    },
                    {
                      "type": "basic",
                      "name": "Div",
                      "children": [
                        {
                          "type": "basic",
                          "name": "H3",
                          "props": {
                            "className": "text-sm font-medium text-red-800 dark:text-red-200"
                          },
                          "text": "$t:admin.settings.notification_definitions.edit_modal.validation_error"
                        },
                        {
                          "type": "basic",
                          "name": "Ul",
                          "if": "{{typeof $parent._local.templateErrors === 'object' && Object.keys($parent._local.templateErrors).length > 0}}",
                          "props": {
                            "className": "mt-2 list-disc list-inside space-y-1"
                          },
                          "iteration": {
                            "source": "Object.entries($parent._local.templateErrors ?? {}).flatMap(([field, messages]) => Array.isArray(messages) ? messages : [messages])",
                            "item_var": "errMsg"
                          },
                          "children": [
                            {
                              "type": "basic",
                              "name": "Li",
                              "props": {
                                "className": "text-sm text-red-700 dark:text-red-300"
                              },
                              "text": "{{errMsg}}"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "id": "template_type_channel",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex flex-wrap items-center gap-2"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-sm font-medium text-gray-500 dark:text-gray-400"
                  },
                  "text": "$t:admin.settings.notification_definitions.edit_modal.type_label"
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-sm font-semibold text-gray-900 dark:text-white"
                  },
                  "text": "$t:admin.settings.notification_definitions.types.{{$parent._local.editingDefinition?.type ?? ''}}"
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-xs font-mono px-1.5 py-0.5 bg-gray-100 dark:bg-gray-700 text-gray-500 dark:text-gray-400 rounded"
                  },
                  "text": "{{$parent._local.editingDefinition?.type ?? ''}}"
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-sm text-gray-400 dark:text-gray-500"
                  },
                  "text": "·"
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-sm text-gray-500 dark:text-gray-400"
                  },
                  "text": "$t:admin.settings.notification_definitions.edit_modal.channel_label"
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-sm font-medium text-indigo-600 dark:text-indigo-400"
                  },
                  "text": "{{(availableChannels?.data?.channels ?? []).find(c => c.id === $parent._local.editingTemplate?.channel)?.name?.[$locale] ?? $parent._local.editingTemplate?.channel ?? ''}}"
                }
              ]
            },
            {
              "id": "template_recipients_section",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "bg-purple-50 dark:bg-purple-900/20 border border-purple-200 dark:border-purple-700 rounded-lg p-4 space-y-3"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "H4",
                  "props": {
                    "className": "text-sm font-medium text-purple-800 dark:text-purple-200"
                  },
                  "text": "$t:admin.settings.notification_definitions.recipients.title"
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "space-y-3"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Div",
                      "iteration": {
                        "source": "{{$parent._local.editingRecipients ?? []}}",
                        "item_var": "rcpt",
                        "index_var": "rcptIdx"
                      },
                      "props": {
                        "className": "bg-white dark:bg-gray-800 border border-purple-200 dark:border-purple-600 rounded-lg p-3 space-y-2"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Div",
                          "props": {
                            "className": "flex items-center justify-between"
                          },
                          "children": [
                            {
                              "type": "basic",
                              "name": "Span",
                              "props": {
                                "className": "text-xs font-medium text-purple-700 dark:text-purple-300"
                              },
                              "text": "$t:admin.settings.notification_definitions.recipients.rule_label|index={{rcptIdx + 1}}"
                            },
                            {
                              "type": "basic",
                              "name": "Button",
                              "props": {
                                "type": "button",
                                "className": "p-1 text-gray-400 hover:text-red-500 dark:hover:text-red-400 transition-colors"
                              },
                              "children": [
                                {
                                  "type": "basic",
                                  "name": "Icon",
                                  "props": { "name": "fa-solid fa-xmark", "size": "sm" }
                                }
                              ],
                              "actions": [
                                {
                                  "type": "click",
                                  "handler": "setState",
                                  "params": {
                                    "target": "$parent._local",
                                    "editingRecipients": "{{($parent._local.editingRecipients ?? []).filter((_, i) => i !== rcptIdx)}}"
                                  }
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "type": "basic",
                          "name": "Div",
                          "props": {
                            "className": "space-y-2"
                          },
                          "children": [
                            {
                              "type": "basic",
                              "name": "Div",
                              "props": { "className": "space-y-1" },
                              "children": [
                                {
                                  "type": "basic",
                                  "name": "Label",
                                  "props": { "className": "block text-xs font-medium text-gray-600 dark:text-gray-400" },
                                  "text": "$t:admin.settings.notification_definitions.recipients.type_label"
                                },
                                {
                                  "type": "composite",
                                  "name": "Select",
                                  "props": {
                                    "value": "{{rcpt.type ?? ''}}",
                                    "className": "w-full text-sm",
                                    "options": [
                                      { "value": "trigger_user", "label": "$t:admin.settings.notification_definitions.recipients.types.trigger_user" },
                                      { "value": "related_user", "label": "$t:admin.settings.notification_definitions.recipients.types.related_user" },
                                      { "value": "role", "label": "$t:admin.settings.notification_definitions.recipients.types.role" },
                                      { "value": "specific_users", "label": "$t:admin.settings.notification_definitions.recipients.types.specific_users" }
                                    ]
                                  },
                                  "actions": [
                                    {
                                      "type": "change",
                                      "handler": "setState",
                                      "params": {
                                        "target": "$parent._local",
                                        "editingRecipients": "{{($parent._local.editingRecipients ?? []).map((r, i) => i === rcptIdx ? {...r, type: $event.target.value} : r)}}"
                                      }
                                    }
                                  ]
                                }
                              ]
                            },
                            {
                              "type": "basic",
                              "name": "Div",
                              "if": "{{rcpt.type === 'related_user'}}",
                              "props": { "className": "space-y-1" },
                              "children": [
                                {
                                  "type": "basic",
                                  "name": "Label",
                                  "props": { "className": "block text-xs font-medium text-gray-600 dark:text-gray-400" },
                                  "text": "$t:admin.settings.notification_definitions.recipients.relation_label"
                                },
                                {
                                  "type": "basic",
                                  "name": "Span",
                                  "props": {
                                    "className": "block w-full px-3 py-1.5 text-sm bg-gray-100 dark:bg-gray-700 text-gray-500 dark:text-gray-400 border border-gray-200 dark:border-gray-600 rounded-md"
                                  },
                                  "text": "{{rcpt.relation ?? ''}}"
                                }
                              ]
                            },
                            {
                              "type": "basic",
                              "name": "Div",
                              "if": "{{rcpt.type === 'role'}}",
                              "props": { "className": "space-y-1" },
                              "children": [
                                {
                                  "type": "basic",
                                  "name": "Label",
                                  "props": { "className": "block text-xs font-medium text-gray-600 dark:text-gray-400" },
                                  "text": "$t:admin.settings.notification_definitions.recipients.role_label"
                                },
                                {
                                  "type": "composite",
                                  "name": "SearchableDropdown",
                                  "props": {
                                    "value": "{{rcpt.value ?? ''}}",
                                    "options": "{{$parent._local.recipientRoleSearchResults ?? []}}",
                                    "searchPlaceholder": "$t:admin.settings.notification_definitions.recipients.role_search_placeholder",
                                    "noResultsText": "$t:admin.settings.notification_definitions.recipients.users_no_options",
                                    "initialText": "$t:admin.settings.notification_definitions.recipients.role_search_placeholder",
                                    "triggerLabel": "$t:admin.settings.notification_definitions.recipients.role_label",
                                    "className": "w-full"
                                  },
                                  "actions": [
                                    {
                                      "event": "onSearch",
                                      "handler": "apiCall",
                                      "debounce": 300,
                                      "auth_required": true,
                                      "target": "/api/admin/roles",
                                      "params": {
                                        "method": "GET",
                                        "query": {
                                          "search": "{{$args[0]}}",
                                          "per_page": 50
                                        }
                                      },
                                      "onSuccess": [
                                        {
                                          "handler": "setState",
                                          "params": {
                                            "target": "$parent._local",
                                            "recipientRoleSearchResults": "{{(response.data?.data ?? []).map(r => ({ value: r.identifier, label: r.name, description: r.identifier }))}}"
                                          }
                                        }
                                      ],
                                      "onError": [
                                        {
                                          "handler": "setState",
                                          "params": {
                                            "target": "$parent._local",
                                            "recipientRoleSearchResults": []
                                          }
                                        }
                                      ]
                                    },
                                    {
                                      "event": "onChange",
                                      "handler": "setState",
                                      "params": {
                                        "target": "$parent._local",
                                        "editingRecipients": "{{($parent._local.editingRecipients ?? []).map((r, i) => i === rcptIdx ? {...r, value: $args[0]} : r)}}"
                                      }
                                    }
                                  ]
                                }
                              ]
                            },
                            {
                              "type": "basic",
                              "name": "Div",
                              "if": "{{rcpt.type === 'specific_users'}}",
                              "props": { "className": "space-y-1" },
                              "children": [
                                {
                                  "type": "basic",
                                  "name": "Label",
                                  "props": { "className": "block text-xs font-medium text-gray-600 dark:text-gray-400" },
                                  "text": "$t:admin.settings.notification_definitions.recipients.users_label"
                                },
                                {
                                  "id": "rcpt_users_{{rcptIdx}}",
                                  "type": "composite",
                                  "name": "SearchableDropdown",
                                  "props": {
                                    "multiple": true,
                                    "value": "{{rcpt.value ?? []}}",
                                    "options": "{{$parent._local.recipientUserSearchResults ?? []}}",
                                    "searchPlaceholder": "$t:admin.settings.notification_definitions.recipients.users_placeholder",
                                    "noResultsText": "$t:admin.settings.notification_definitions.recipients.users_no_options",
                                    "initialText": "$t:admin.settings.notification_definitions.recipients.users_placeholder",
                                    "triggerLabel": "$t:admin.settings.notification_definitions.recipients.users_label",
                                    "className": "w-full"
                                  },
                                  "actions": [
                                    {
                                      "event": "onSearch",
                                      "handler": "apiCall",
                                      "debounce": 300,
                                      "auth_required": true,
                                      "target": "/api/admin/users/search",
                                      "params": {
                                        "method": "GET",
                                        "query": {
                                          "keyword": "{{$args[0]}}"
                                        }
                                      },
                                      "onSuccess": [
                                        {
                                          "handler": "setState",
                                          "params": {
                                            "target": "$parent._local",
                                            "recipientUserSearchResults": "{{(response.data ?? []).map(u => ({ value: u.uuid, label: u.name, description: u.email }))}}"
                                          }
                                        }
                                      ],
                                      "onError": [
                                        {
                                          "handler": "setState",
                                          "params": {
                                            "target": "$parent._local",
                                            "recipientUserSearchResults": []
                                          }
                                        }
                                      ]
                                    },
                                    {
                                      "event": "onChange",
                                      "handler": "setState",
                                      "params": {
                                        "target": "$parent._local",
                                        "editingRecipients": "{{($parent._local.editingRecipients ?? []).map((r, i) => i === rcptIdx ? {...r, value: $args[0]} : r)}}"
                                      }
                                    }
                                  ]
                                }
                              ]
                            },
                            {
                              "type": "basic",
                              "name": "Div",
                              "if": "{{rcpt.type === 'role' || rcpt.type === 'specific_users'}}",
                              "props": { "className": "flex items-center gap-2" },
                              "children": [
                                {
                                  "type": "composite",
                                  "name": "Toggle",
                                  "props": {
                                    "checked": "{{rcpt.exclude_trigger_user ?? false}}"
                                  },
                                  "actions": [
                                    {
                                      "type": "change",
                                      "handler": "setState",
                                      "params": {
                                        "target": "$parent._local",
                                        "editingRecipients": "{{($parent._local.editingRecipients ?? []).map((r, i) => i === rcptIdx ? {...r, exclude_trigger_user: !(r.exclude_trigger_user ?? false)} : r)}}"
                                      }
                                    }
                                  ]
                                },
                                {
                                  "type": "basic",
                                  "name": "Span",
                                  "props": { "className": "text-xs text-gray-600 dark:text-gray-400" },
                                  "text": "$t:admin.settings.notification_definitions.recipients.exclude_trigger_user"
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Button",
                  "props": {
                    "type": "button",
                    "className": "text-sm text-purple-600 dark:text-purple-400 hover:text-purple-800 dark:hover:text-purple-200 font-medium"
                  },
                  "text": "$t:admin.settings.notification_definitions.recipients.add_rule",
                  "actions": [
                    {
                      "type": "click",
                      "handler": "setState",
                      "params": {
                        "target": "$parent._local",
                        "editingRecipients": "{{[...($parent._local.editingRecipients ?? []), {type: 'trigger_user'}]}}"
                      }
                    }
                  ]
                }
              ]
            },
            {
              "id": "template_lang_tabs",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex border-b border-gray-200 dark:border-gray-700"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Button",
                  "iteration": {
                    "source": "{{$locales}}",
                    "item_var": "loc"
                  },
                  "props": {
                    "type": "button",
                    "className": "{{($parent._local.editLang ?? $locale) === loc ? 'border-b-2 border-indigo-500 text-indigo-600 dark:text-indigo-400' : 'text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300'}} px-4 py-2 text-sm font-medium focus:outline-none"
                  },
                  "text": "{{_global.appConfig?.localeNames?.[loc] ?? loc}}",
                  "actions": [
                    {
                      "type": "click",
                      "handler": "setState",
                      "params": {
                        "target": "$parent._local",
                        "editLang": "{{loc}}"
                      }
                    }
                  ]
                }
              ]
            },
            {
              "id": "template_subject_input",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "space-y-1"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "block text-sm font-medium text-gray-700 dark:text-gray-300"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Span",
                      "text": "$t:admin.settings.notification_definitions.edit_modal.subject"
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": { "className": "text-red-500 dark:text-red-400 ml-1" },
                      "text": "*"
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Input",
                  "props": {
                    "type": "text",
                    "value": "{{$parent._local.editingTemplate?.subject?.[$parent._local.editLang ?? $locale] ?? ''}}",
                    "className": "w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500"
                  },
                  "actions": [
                    {
                      "type": "change",
                      "handler": "setState",
                      "params": {
                        "target": "$parent._local",
                        "editingTemplate": "{{Object.assign({}, $parent._local.editingTemplate, {subject: Object.assign({}, $parent._local.editingTemplate?.subject, {[$parent._local.editLang ?? $locale]: $event.target.value})})}}"
                      }
                    }
                  ]
                }
              ]
            },
            {
              "id": "template_body_input",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "space-y-1"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "block text-sm font-medium text-gray-700 dark:text-gray-300"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Span",
                      "text": "$t:admin.settings.notification_definitions.edit_modal.body"
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": { "className": "text-red-500 dark:text-red-400 ml-1" },
                      "text": "*"
                    }
                  ]
                },
                {
                  "type": "composite",
                  "name": "HtmlEditor",
                  "props": {
                    "content": "{{$parent._local.editingTemplate?.body?.[$parent._local.editLang ?? $locale] ?? ''}}",
                    "isHtml": true,
                    "showHtmlModeToggle": false,
                    "className": "min-h-[200px]"
                  },
                  "actions": [
                    {
                      "type": "change",
                      "handler": "setState",
                      "params": {
                        "target": "$parent._local",
                        "editingTemplate": "{{Object.assign({}, $parent._local.editingTemplate, {body: Object.assign({}, $parent._local.editingTemplate?.body, {[$parent._local.editLang ?? $locale]: $event.target.value})})}}"
                      }
                    }
                  ]
                }
              ]
            },
            {
              "id": "template_click_url_input",
              "type": "basic",
              "name": "Div",
              "if": "{{$parent._local.editingTemplate?.channel === 'database'}}",
              "props": {
                "className": "space-y-1"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "block text-sm font-medium text-gray-700 dark:text-gray-300"
                  },
                  "text": "$t:admin.settings.notification_definitions.edit_modal.click_url"
                },
                {
                  "type": "basic",
                  "name": "Input",
                  "props": {
                    "type": "text",
                    "value": "{{$parent._local.editingTemplate?.click_url ?? ''}}",
                    "placeholder": "/mypage/orders/{order_number}",
                    "className": "w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-800 text-gray-900 dark:text-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                  },
                  "actions": [
                    {
                      "type": "change",
                      "handler": "setState",
                      "params": {
                        "target": "$parent._local",
                        "editingTemplate": "{{Object.assign({}, $parent._local.editingTemplate, {click_url: $event.target.value || null})}}"
                      }
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "P",
                  "props": {
                    "className": "text-xs text-gray-500 dark:text-gray-400 mt-1"
                  },
                  "text": "$t:admin.settings.notification_definitions.edit_modal.click_url_hint"
                }
              ]
            },
            {
              "id": "template_variables_info",
              "type": "basic",
              "name": "Div",
              "if": "{{($parent._local.editingDefinition?.variables ?? []).length > 0}}",
              "props": {
                "className": "bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-md p-4"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "H4",
                  "props": {
                    "className": "text-sm font-medium text-gray-700 dark:text-gray-300 mb-2"
                  },
                  "text": "$t:admin.settings.notification_definitions.edit_modal.variables_title"
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex flex-wrap gap-2"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Span",
                      "iteration": {
                        "source": "{{$parent._local.editingDefinition?.variables ?? []}}",
                        "item_var": "v"
                      },
                      "props": {
                        "className": "inline-flex items-center gap-1 text-xs px-2 py-1 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-600 rounded text-gray-700 dark:text-gray-300"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": { "className": "font-mono" },
                          "text": "{"
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": { "className": "font-mono" },
                          "text": "{{v.key}}"
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": { "className": "font-mono" },
                          "text": "}"
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "text": " — {{v.description ?? ''}}"
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "id": "template_modal_footer",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "flex justify-between items-center pt-4 pb-4 border-t border-gray-200 dark:border-gray-700 mt-4 flex-shrink-0"
          },
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "children": [
                {
                  "type": "basic",
                  "name": "Button",
                  "props": {
                    "type": "button",
                    "className": "text-sm px-4 py-2 rounded-md border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors",
                    "disabled": "{{$parent._local.isSaving ?? false}}"
                  },
                  "text": "$t:admin.settings.notification_definitions.edit_modal.btn_preview",
                  "actions": [
                    {
                      "type": "click",
                      "handler": "apiCall",
                      "auth_required": true,
                      "target": "/api/admin/notification-templates/preview",
                      "params": {
                        "method": "POST",
                        "body": {
                          "definition_id": "{{$parent._local.editingDefinition?.id}}",
                          "subject": "{{$parent._local.editingTemplate?.subject}}",
                          "body": "{{$parent._local.editingTemplate?.body}}",
                          "locale": "{{$parent._local.editLang ?? $locale}}"
                        }
                      },
                      "onSuccess": [
                        {
                          "handler": "setState",
                          "params": {
                            "target": "$parent._local",
                            "previewData": "{{response.data}}"
                          }
                        },
                        {
                          "handler": "openModal",
                          "target": "modal_notification_template_preview"
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex gap-2"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Button",
                  "props": {
                    "type": "button",
                    "className": "text-sm px-4 py-2 rounded-md border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed",
                    "disabled": "{{$parent._local.isSaving ?? false}}"
                  },
                  "text": "$t:common.cancel",
                  "actions": [
                    {
                      "type": "click",
                      "handler": "closeModal",
                      "target": "modal_notification_template_form"
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Button",
                  "props": {
                    "type": "button",
                    "className": "flex items-center gap-2 text-sm px-4 py-2 rounded-md bg-indigo-600 text-white hover:bg-indigo-700 dark:bg-indigo-500 dark:hover:bg-indigo-600 transition-colors disabled:opacity-50 disabled:cursor-not-allowed",
                    "disabled": "{{$parent._local.isSaving ?? false}}"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Icon",
                      "if": "{{$parent._local.isSaving}}",
                      "props": { "name": "spinner", "className": "animate-spin", "size": "sm" }
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "text": "{{$parent._local.isSaving ? '$t:common.saving' : '$t:common.save'}}"
                    }
                  ],
                  "actions": [
                    {
                      "type": "click",
                      "handler": "sequence",
                      "params": {
                        "actions": [
                          {
                            "handler": "setState",
                            "params": {
                              "target": "$parent._local",
                              "isSaving": true,
                              "templateErrors": null
                            }
                          },
                          {
                            "handler": "apiCall",
                            "auth_required": true,
                            "target": "{{'/api/admin/notification-templates/' + $parent._local.editingTemplate?.id}}",
                            "params": {
                              "method": "PUT",
                              "body": {
                                "subject": "{{$parent._local.editingTemplate?.subject}}",
                                "body": "{{$parent._local.editingTemplate?.body}}",
                                "click_url": "{{$parent._local.editingTemplate?.click_url ?? null}}",
                                "recipients": "{{$parent._local.editingRecipients ?? []}}"
                              }
                            },
                            "onSuccess": [
                              {
                                "handler": "setState",
                                "params": {
                                  "target": "$parent._local",
                                  "isSaving": false,
                                  "templateErrors": null,
                                  "editingTemplate": null,
                                  "editingDefinition": null,
                                  "editingRecipients": null
                                }
                              },
                              {
                                "handler": "refetchDataSource",
                                "params": {
                                  "dataSourceId": "notificationDefinitions"
                                }
                              },
                              {
                                "handler": "toast",
                                "params": {
                                  "message": "$t:admin.settings.notification_definitions.save_success",
                                  "type": "success"
                                }
                              },
                              {
                                "handler": "closeModal",
                                "target": "modal_notification_template_form"
                              }
                            ],
                          "onError": [
                            {
                              "handler": "setState",
                              "params": {
                                "target": "$parent._local",
                                "isSaving": false,
                                "templateErrors": "{{error.errors}}"
                              }
                            },
                            {
                              "handler": "toast",
                              "params": {
                                "message": "$t:admin.settings.notification_definitions.save_error",
                                "type": "error"
                              }
                            }
                          ]
                        }
                        ]
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
