{
  "meta": {
    "is_partial": true,
    "description": "앱 키 재생성 비밀번호 확인 모달"
  },
  "id": "settings_password_confirm_modal",
  "type": "composite",
  "name": "Modal",
  "props": {
    "title": "$t:admin.settings.modals.password_confirm_title",
    "size": "small"
  },
  "children": [
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "py-2"
      },
      "children": [
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "flex items-start gap-3 p-3 bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-lg mb-4"
          },
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "props": {
                "name": "triangle-exclamation",
                "className": "w-5 h-5 text-amber-600 dark:text-amber-400 flex-shrink-0 mt-0.5"
              }
            },
            {
              "type": "basic",
              "name": "P",
              "props": {
                "className": "text-sm text-amber-800 dark:text-amber-200"
              },
              "text": "$t:admin.settings.modals.app_key_warning"
            }
          ]
        },
        {
          "type": "basic",
          "name": "Label",
          "props": {
            "className": "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2"
          },
          "text": "$t:admin.settings.modals.enter_password"
        },
        {
          "type": "basic",
          "name": "Input",
          "props": {
            "type": "password",
            "placeholder": "$t:admin.settings.modals.password_placeholder",
            "className": "w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
          },
          "actions": [
            {
              "type": "change",
              "handler": "setState",
              "params": {
                "target": "global",
                "appKeyPassword": "{{$event.target.value}}"
              }
            }
          ]
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "flex justify-end gap-3 mt-6"
      },
      "children": [
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "className": "px-4 py-2 bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 disabled:opacity-50 disabled:cursor-not-allowed",
            "disabled": "{{_global.isRegeneratingKey}}"
          },
          "actions": [
            {
              "type": "click",
              "handler": "sequence",
              "actions": [
                {
                  "handler": "setState",
                  "params": {
                    "target": "global",
                    "appKeyPassword": ""
                  }
                },
                {
                  "handler": "closeModal"
                }
              ]
            }
          ],
          "children": [
            {
              "type": "basic",
              "name": "Span",
              "text": "$t:common.cancel"
            }
          ]
        },
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "className": "flex items-center gap-2 px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 disabled:opacity-50 disabled:cursor-not-allowed",
            "disabled": "{{_global.isRegeneratingKey || !_global.appKeyPassword}}"
          },
          "actions": [
            {
              "type": "click",
              "handler": "sequence",
              "actions": [
                {
                  "handler": "setState",
                  "params": {
                    "target": "global",
                    "isRegeneratingKey": true
                  }
                },
                {
                  "handler": "apiCall",
                  "auth_required": true,
                  "target": "/api/admin/settings/regenerate-app-key",
                  "params": {
                    "method": "POST",
                    "body": {
                      "password": "{{_global.appKeyPassword}}"
                    }
                  },
                  "onSuccess": [
                    {
                      "handler": "setState",
                      "params": {
                        "target": "global",
                        "isRegeneratingKey": false,
                        "appKeyPassword": ""
                      }
                    },
                    {
                      "handler": "toast",
                      "params": {
                        "type": "success",
                        "message": "$t:admin.settings.app_key_regenerated"
                      }
                    },
                    {
                      "handler": "refetchDataSource",
                      "params": {
                        "dataSourceId": "appKey"
                      }
                    },
                    {
                      "handler": "closeModal"
                    }
                  ],
                  "onError": [
                    {
                      "handler": "setState",
                      "params": {
                        "target": "global",
                        "isRegeneratingKey": false
                      }
                    },
                    {
                      "handler": "toast",
                      "params": {
                        "type": "error",
                        "message": "{{error.message}}"
                      }
                    }
                  ]
                }
              ]
            }
          ],
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "if": "{{_global.isRegeneratingKey}}",
              "props": {
                "name": "spinner",
                "className": "w-4 h-4 animate-spin"
              }
            },
            {
              "type": "basic",
              "name": "Span",
              "text": "{{_global.isRegeneratingKey ? '$t:admin.settings.modals.regenerating' : '$t:admin.settings.modals.regenerate'}}"
            }
          ]
        }
      ]
    }
  ]
}
