                      "if": "{{_local.errors?.['mail.from_address']}}",
                      "props": {
                        "className": "text-red-500 text-xs mt-1 block"
                      },
                      "text": "{{_local.errors?.['mail.from_address']?.[0] ?? ''}}"
                    }
                  ]
                },
                {
                  "id": "field_from_name",
                  "type": "basic",
                  "name": "Div",
                  "children": [
                    {
                      "type": "basic",
                      "name": "Label",
                      "props": {
                        "className": "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Span",
                          "text": "$t:admin.settings.mail.from_name"
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "text-red-500 ml-1"
                          },
                          "text": "*"
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Input",
                      "props": {
                        "type": "text",
                        "name": "mail.from_name",
                        "placeholder": "그누보드7",
                        "disabled": "{{_computed.isReadOnly}}",
                        "className": "{{_local.errors?.['mail.from_name'] ? 'w-full px-3 py-2 border border-red-500 dark:border-red-500 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white text-sm focus:ring-2 focus:ring-red-500 focus:border-red-500 disabled:bg-gray-100 dark:disabled:bg-gray-800 disabled:text-gray-400 dark:disabled:text-gray-500 disabled:cursor-not-allowed' : 'w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 disabled:bg-gray-100 dark:disabled:bg-gray-800 disabled:text-gray-400 dark:disabled:text-gray-500 disabled:cursor-not-allowed'}}"
                      }
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "if": "{{_local.errors?.['mail.from_name']}}",
                      "props": {
                        "className": "text-red-500 text-xs mt-1 block"
                      },
                      "text": "{{_local.errors?.['mail.from_name']?.[0] ?? ''}}"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "card_test_mail",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-6"
      },
      "children": [
        {
          "type": "basic",
          "name": "H3",
          "props": {
            "className": "text-lg font-semibold text-gray-900 dark:text-white mb-1"
          },
          "text": "$t:admin.settings.mail.test_mail"
        },
        {
          "type": "basic",
          "name": "P",
          "props": {
            "className": "text-sm text-gray-500 dark:text-gray-400 mb-6"
          },
          "text": "$t:admin.settings.mail.test_mail_desc"
        },
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "flex flex-col sm:flex-row gap-4"
          },
          "children": [
            {
              "type": "basic",
              "name": "Input",
              "props": {
                "type": "email",
                "name": "mail.test_email",
                "placeholder": "$t:admin.settings.mail.test_email_placeholder",
                "disabled": "{{_computed.isReadOnly}}",
                "className": "flex-1 px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 disabled:bg-gray-100 dark:disabled:bg-gray-800 disabled:text-gray-400 dark:disabled:text-gray-500 disabled:cursor-not-allowed"
              }
            },
            {
              "id": "test_mail_button",
              "type": "basic",
              "name": "Button",
              "props": {
                "disabled": "{{_computed.isReadOnly || _local.isSendingTest}}",
                "className": "flex items-center justify-center gap-2 px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 font-medium transition-colors disabled:opacity-50 disabled:cursor-not-allowed whitespace-nowrap"
              },
              "actions": [
                {
                  "type": "click",
                  "handler": "sequence",
                  "actions": [
                    {
                      "handler": "setState",
                      "params": {
                        "target": "local",
                        "isSendingTest": true,
                        "testMailResult": null,
                        "testMailResultMessage": null
                      }
                    },
                    {
                      "handler": "apiCall",
                      "auth_required": true,
                      "target": "/api/admin/settings/test-mail",
                      "params": {
                        "method": "POST",
                        "body": {
                          "to_email": "{{_local.form?.mail?.test_email || ''}}",
                          "mailer": "{{_local.form?.mail?.mailer || 'smtp'}}",
                          "from_address": "{{_local.form?.mail?.from_address || ''}}",
                          "from_name": "{{_local.form?.mail?.from_name || ''}}",
                          "host": "{{!_local.form?.mail?.mailer || _local.form?.mail?.mailer === 'smtp' ? (_local.form?.mail?.host ?? '') : undefined}}",
                          "port": "{{!_local.form?.mail?.mailer || _local.form?.mail?.mailer === 'smtp' ? (_local.form?.mail?.port ?? 587) : undefined}}",
                          "username": "{{!_local.form?.mail?.mailer || _local.form?.mail?.mailer === 'smtp' ? (_local.form?.mail?.username ?? '') : undefined}}",
                          "password": "{{!_local.form?.mail?.mailer || _local.form?.mail?.mailer === 'smtp' ? (_local.form?.mail?.password ?? '') : undefined}}",
                          "encryption": "{{!_local.form?.mail?.mailer || _local.form?.mail?.mailer === 'smtp' ? (_local.form?.mail?.encryption ?? 'tls') : undefined}}",
                          "mailgun_domain": "{{_local.form?.mail?.mailer === 'mailgun' ? (_local.form?.mail?.mailgun_domain ?? '') : undefined}}",
                          "mailgun_secret": "{{_local.form?.mail?.mailer === 'mailgun' ? (_local.form?.mail?.mailgun_secret ?? '') : undefined}}",
                          "mailgun_endpoint": "{{_local.form?.mail?.mailer === 'mailgun' ? (_local.form?.mail?.mailgun_endpoint ?? '') : undefined}}",
                          "ses_key": "{{_local.form?.mail?.mailer === 'ses' ? (_local.form?.mail?.ses_key ?? '') : undefined}}",
                          "ses_secret": "{{_local.form?.mail?.mailer === 'ses' ? (_local.form?.mail?.ses_secret ?? '') : undefined}}",
                          "ses_region": "{{_local.form?.mail?.mailer === 'ses' ? (_local.form?.mail?.ses_region ?? '') : undefined}}"
                        }
                      },
                      "onSuccess": [
                        {
                          "handler": "setState",
                          "params": {
                            "target": "local",
                            "isSendingTest": false,
                            "testMailResult": "success",
                            "testMailResultMessage": "$t:admin.settings.mail.test_mail_success",
                            "testMailSubject": "{{response.data?.subject ?? ''}}",
                            "testMailBody": "{{response.data?.body ?? ''}}",
                            "testMailError": null
                          }
                        },
                        {
                          "handler": "toast",
                          "params": {
                            "type": "success",
                            "message": "$t:admin.settings.mail.test_mail_success"
                          }
                        }
                      ],
                      "onError": [
                        {
                          "handler": "setState",
                          "params": {
                            "target": "local",
                            "isSendingTest": false,
                            "testMailResult": "error",
                            "testMailResultMessage": "{{error.message || '$t:admin.settings.mail.test_mail_failed'}}",
                            "testMailSubject": null,
                            "testMailBody": null,
                            "testMailError": "{{typeof error.errors === 'object' ? Object.values(error.errors).flat().join(', ') : (error.errors ?? '')}}"
                          }
                        },
                        {
                          "handler": "toast",
                          "params": {
                            "type": "error",
                            "message": "{{error.message || '$t:admin.settings.mail.test_mail_failed'}}"
                          }
                        }
                      ]
                    }
                  ]
                }
              ],
              "children": [
                {
                  "type": "basic",
                  "name": "Icon",
                  "if": "{{_local.isSendingTest}}",
                  "props": {
                    "name": "spinner",
                    "className": "w-4 h-4 animate-spin"
                  }
                },
                {
                  "type": "basic",
                  "name": "Icon",
                  "if": "{{!_local.isSendingTest}}",
                  "props": {
                    "name": "paper-plane",
                    "className": "w-4 h-4"
                  }
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "text": "$t:admin.settings.mail.send_test"
                }
              ]
            }
          ]
        },
        {
          "id": "test_mail_result",
          "type": "basic",
          "name": "Div",
          "if": "{{_local.testMailResult}}",
          "props": {
            "className": "{{_local.testMailResult === 'success' ? 'mt-4 p-4 rounded-lg bg-green-50 dark:bg-green-900/20 text-green-700 dark:text-green-400 text-sm' : 'mt-4 p-4 rounded-lg bg-red-50 dark:bg-red-900/20 text-red-700 dark:text-red-400 text-sm'}}"
          },
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex items-center gap-2"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Icon",
                  "if": "{{_local.testMailResult === 'success'}}",
                  "props": {
                    "name": "check-circle",
                    "className": "text-green-500 dark:text-green-400 flex-shrink-0"
                  }
                },
                {
                  "type": "basic",
                  "name": "Icon",
                  "if": "{{_local.testMailResult === 'error'}}",
                  "props": {
                    "name": "exclamation-circle",
                    "className": "text-red-500 dark:text-red-400 flex-shrink-0"
                  }
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "font-medium"
                  },
                  "text": "{{_local.testMailResultMessage ?? ''}}"
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "if": "{{_local.testMailResult === 'success' && _local.testMailSubject}}",
              "props": {
                "className": "mt-2 pl-7 space-y-1 text-green-600 dark:text-green-300"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "children": [
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "font-medium"
                      },
                      "text": "$t:admin.settings.mail.test_mail_subject_label"
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "text": "{{_local.testMailSubject ?? ''}}"
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "children": [
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "font-medium"
                      },
                      "text": "$t:admin.settings.mail.test_mail_body_label"
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "text": "{{_local.testMailBody ?? ''}}"
                    }
                  ]
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "if": "{{_local.testMailResult === 'error' && _local.testMailError}}",
              "props": {
                "className": "mt-2 pl-7 text-xs text-red-600 dark:text-red-300 break-all"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Span",
                  "text": "{{_local.testMailError ?? ''}}"
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
