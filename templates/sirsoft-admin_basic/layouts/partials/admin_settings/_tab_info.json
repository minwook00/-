{
  "meta": {
    "is_partial": true,
    "description": "환경설정 정보 탭 콘텐츠"
  },
  "id": "tab_content_info",
  "type": "basic",
  "name": "Div",
  "if": "{{(_global.activeSettingsTab || query.tab) === 'info'}}",
  "props": {
    "className": "mt-6 space-y-6"
  },
  "children": [
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "grid grid-cols-1 md:grid-cols-2 gap-6"
      },
      "children": [
        {
          "id": "card_system_info",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-6"
          },
          "children": [
            {
              "type": "basic",
              "name": "H3",
              "props": {
                "className": "text-lg font-semibold text-gray-900 dark:text-white mb-1"
              },
              "text": "$t:admin.settings.info.system_info"
            },
            {
              "type": "basic",
              "name": "P",
              "props": {
                "className": "text-sm text-gray-500 dark:text-gray-400 mb-4"
              },
              "text": "$t:admin.settings.info.system_info_desc"
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "space-y-3"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex justify-between items-center py-2 border-b border-gray-100 dark:border-gray-700"
                  },
                  "children": [
                    { "type": "basic", "name": "Span", "props": { "className": "text-sm text-gray-600 dark:text-gray-400" }, "text": "$t:admin.settings.info.os" },
                    { "type": "basic", "name": "Span", "props": { "className": "text-sm font-medium text-gray-900 dark:text-white" }, "text": "{{systemInfo?.data?.os_info ?? '-'}}" }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex justify-between items-center py-2 border-b border-gray-100 dark:border-gray-700"
                  },
                  "children": [
                    { "type": "basic", "name": "Span", "props": { "className": "text-sm text-gray-600 dark:text-gray-400" }, "text": "$t:admin.settings.info.web_server" },
                    { "type": "basic", "name": "Span", "props": { "className": "text-sm font-medium text-gray-900 dark:text-white" }, "text": "{{systemInfo?.data?.web_server ?? '-'}}" }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex justify-between items-center py-2 border-b border-gray-100 dark:border-gray-700"
                  },
                  "children": [
                    { "type": "basic", "name": "Span", "props": { "className": "text-sm text-gray-600 dark:text-gray-400" }, "text": "$t:admin.settings.info.php_version" },
                    { "type": "basic", "name": "Span", "props": { "className": "text-sm font-medium text-gray-900 dark:text-white" }, "text": "{{systemInfo?.data?.php_version ?? '-'}}" }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex justify-between items-center py-2 border-b border-gray-100 dark:border-gray-700"
                  },
                  "children": [
                    { "type": "basic", "name": "Span", "props": { "className": "text-sm text-gray-600 dark:text-gray-400" }, "text": "$t:admin.settings.info.mysql_version" },
                    { "type": "basic", "name": "Span", "props": { "className": "text-sm font-medium text-gray-900 dark:text-white" }, "text": "{{systemInfo?.data?.mysql_version ?? '-'}}" }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex justify-between items-center py-2 border-b border-gray-100 dark:border-gray-700"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": { "className": "text-sm text-gray-600 dark:text-gray-400" },
                      "text": "$t:admin.settings.info.g7_version"
                    },
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": { "className": "flex items-center gap-2" },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": { "className": "text-sm font-medium text-gray-900 dark:text-white" },
                          "text": "{{systemInfo?.data?.g7_version ?? '-'}}"
                        },
                        {
                          "type": "composite",
                          "name": "StatusBadge",
                          "if": "{{_local.coreUpdateInfo?.update_available}}",
                          "props": {
                            "status": "success",
                            "label": "{{_local.coreUpdateInfo?.latest_version ?? ''}}"
                          }
                        },
                        {
                          "type": "basic",
                          "name": "Button",
                          "props": {
                            "type": "button",
                            "className": "px-3 py-1 text-xs font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-md hover:bg-gray-50 dark:hover:bg-gray-600 transition-colors disabled:opacity-50",
                            "disabled": "{{_local.checkingCoreUpdate}}"
                          },
                          "actions": [
                            {
                              "type": "click",
                              "handler": "sequence",
                              "actions": [
                                {
                                  "handler": "setState",
                                  "params": {
                                    "target": "local",
                                    "checkingCoreUpdate": true
                                  }
                                },
                                {
                                  "handler": "apiCall",
                                  "auth_required": true,
                                  "target": "/api/admin/core-update/check",
                                  "params": {
                                    "method": "POST"
                                  },
                                  "onSuccess": [
                                    {
                                      "handler": "setState",
                                      "params": {
                                        "target": "local",
                                        "checkingCoreUpdate": false,
                                        "coreUpdateInfo": "{{result.data}}"
                                      }
                                    },
                                    {
                                      "handler": "openModal",
                                      "target": "core_update_result_modal"
                                    }
                                  ],
                                  "onError": [
                                    {
                                      "handler": "setState",
                                      "params": {
                                        "target": "local",
                                        "checkingCoreUpdate": false,
                                        "coreUpdateError": "{{error.errors?.reason ?? ''}}"
                                      }
                                    },
                                    {
                                      "handler": "toast",
                                      "params": {
                                        "type": "error",
                                        "message": "{{error.errors?.reason ?? $t('admin.settings.info.update_check_failed')}}"
                                      }
                                    }
                                  ]
                                }
                              ]
                            }
                          ],
                          "children": [
                            {
                              "type": "basic",
                              "name": "Icon",
                              "if": "{{_local.checkingCoreUpdate}}",
                              "props": {
                                "name": "spinner",
                                "className": "w-3 h-3 animate-spin"
                              }
                            },
                            {
                              "type": "basic",
                              "name": "Span",
                              "if": "{{!_local.checkingCoreUpdate}}",
                              "text": "$t:admin.settings.info.check_update"
                            }
                          ]
                        },
                        {
                          "type": "basic",
                          "name": "Button",
                          "props": {
                            "type": "button",
                            "className": "px-3 py-1 text-xs font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-md hover:bg-gray-50 dark:hover:bg-gray-600 transition-colors disabled:opacity-50",
                            "disabled": "{{_local.loadingChangelog}}"
                          },
                          "actions": [
                            {
                              "type": "click",
                              "handler": "sequence",
                              "actions": [
                                {
                                  "handler": "setState",
                                  "params": {
                                    "target": "local",
                                    "loadingChangelog": true
                                  }
                                },
                                {
                                  "handler": "apiCall",
                                  "auth_required": true,
                                  "target": "/api/admin/core-update/changelog",
                                  "params": {
                                    "method": "GET"
                                  },
                                  "onSuccess": [
                                    {
                                      "handler": "setState",
                                      "params": {
                                        "target": "local",
                                        "loadingChangelog": false,
                                        "coreChangelog": "{{result.data.changelog ?? []}}"
                                      }
                                    },
                                    {
                                      "handler": "openModal",
                                      "target": "core_changelog_modal"
                                    }
                                  ],
                                  "onError": [
                                    {
                                      "handler": "setState",
                                      "params": {
                                        "target": "local",
                                        "loadingChangelog": false
                                      }
                                    },
                                    {
                                      "handler": "toast",
                                      "params": {
                                        "type": "error",
                                        "message": "$t:admin.settings.info.changelog_load_failed"
                                      }
                                    }
                                  ]
                                }
                              ]
                            }
                          ],
                          "children": [
                            {
                              "type": "basic",
                              "name": "Icon",
                              "if": "{{_local.loadingChangelog}}",
                              "props": {
                                "name": "spinner",
                                "className": "w-3 h-3 animate-spin"
                              }
                            },
                            {
                              "type": "basic",
                              "name": "Span",
                              "if": "{{!_local.loadingChangelog}}",
                              "text": "$t:admin.settings.info.view_changelog"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex justify-between items-center py-2"
                  },
                  "children": [
                    { "type": "basic", "name": "Span", "props": { "className": "text-sm text-gray-600 dark:text-gray-400" }, "text": "$t:admin.settings.info.laravel_version" },
                    { "type": "basic", "name": "Span", "props": { "className": "text-sm font-medium text-gray-900 dark:text-white" }, "text": "{{systemInfo?.data?.laravel_version ?? '-'}}" }
                  ]
                }
              ]
            }
          ]
        },
        {
          "id": "card_system_specs",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-6"
          },
          "children": [
            {
              "type": "basic",
              "name": "H3",
              "props": {
                "className": "text-lg font-semibold text-gray-900 dark:text-white mb-1"
              },
              "text": "$t:admin.settings.info.system_specs"
            },
            {
              "type": "basic",
              "name": "P",
              "props": {
                "className": "text-sm text-gray-500 dark:text-gray-400 mb-4"
              },
              "text": "$t:admin.settings.info.system_specs_desc"
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "space-y-3"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex justify-between items-center py-2 border-b border-gray-100 dark:border-gray-700"
                  },
                  "children": [
                    { "type": "basic", "name": "Span", "props": { "className": "text-sm text-gray-600 dark:text-gray-400" }, "text": "$t:admin.settings.info.cpu" },
                    { "type": "basic", "name": "Span", "props": { "className": "text-sm font-medium text-gray-900 dark:text-white" }, "text": "{{systemInfo?.data?.cpu_info ?? '-'}}" }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex justify-between items-center py-2 border-b border-gray-100 dark:border-gray-700"
                  },
                  "children": [
                    { "type": "basic", "name": "Span", "props": { "className": "text-sm text-gray-600 dark:text-gray-400" }, "text": "$t:admin.settings.info.memory" },
                    { "type": "basic", "name": "Span", "props": { "className": "text-sm font-medium text-gray-900 dark:text-white" }, "text": "{{systemInfo?.data?.memory_usage ?? '-'}}" }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex justify-between items-center py-2 border-b border-gray-100 dark:border-gray-700"
                  },
                  "children": [
                    { "type": "basic", "name": "Span", "props": { "className": "text-sm text-gray-600 dark:text-gray-400" }, "text": "$t:admin.settings.info.disk" },
                    { "type": "basic", "name": "Span", "props": { "className": "text-sm font-medium text-gray-900 dark:text-white" }, "text": "{{systemInfo?.data?.disk_usage?.used ?? '-'}} / {{systemInfo?.data?.disk_usage?.total ?? '-'}} ({{systemInfo?.data?.disk_usage?.percentage ?? 0}}%)" }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex justify-between items-center py-2 border-b border-gray-100 dark:border-gray-700"
                  },
                  "children": [
                    { "type": "basic", "name": "Span", "props": { "className": "text-sm text-gray-600 dark:text-gray-400" }, "text": "$t:admin.settings.info.php_memory" },
                    { "type": "basic", "name": "Span", "props": { "className": "text-sm font-medium text-gray-900 dark:text-white" }, "text": "{{systemInfo?.data?.php_memory_limit ?? '-'}}" }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex justify-between items-center py-2 border-b border-gray-100 dark:border-gray-700"
                  },
                  "children": [
                    { "type": "basic", "name": "Span", "props": { "className": "text-sm text-gray-600 dark:text-gray-400" }, "text": "$t:admin.settings.info.max_execution_time" },
                    { "type": "basic", "name": "Span", "props": { "className": "text-sm font-medium text-gray-900 dark:text-white" }, "text": "{{systemInfo?.data?.max_execution_time ?? '-'}}" }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex justify-between items-center py-2"
                  },
                  "children": [
                    { "type": "basic", "name": "Span", "props": { "className": "text-sm text-gray-600 dark:text-gray-400" }, "text": "$t:admin.settings.info.upload_size" },
                    { "type": "basic", "name": "Span", "props": { "className": "text-sm font-medium text-gray-900 dark:text-white" }, "text": "{{systemInfo?.data?.upload_max_filesize ?? '-'}}" }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "card_install_paths",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-6"
      },
      "children": [
        {
          "type": "basic",
          "name": "H3",
          "props": {
            "className": "text-lg font-semibold text-gray-900 dark:text-white mb-1"
          },
          "text": "$t:admin.settings.info.install_paths"
        },
        {
          "type": "basic",
          "name": "P",
          "props": {
            "className": "text-sm text-gray-500 dark:text-gray-400 mb-4"
          },
          "text": "$t:admin.settings.info.install_paths_desc"
        },
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "grid grid-cols-1 md:grid-cols-2 gap-4"
          },
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex justify-between items-center py-2"
              },
              "children": [
                { "type": "basic", "name": "Span", "props": { "className": "text-sm text-gray-600 dark:text-gray-400" }, "text": "$t:admin.settings.info.install_path" },
                { "type": "basic", "name": "Span", "props": { "className": "text-sm font-mono text-gray-900 dark:text-white break-all" }, "text": "{{systemInfo?.data?.install_path ?? '-'}}" }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex justify-between items-center py-2"
              },
              "children": [
                { "type": "basic", "name": "Span", "props": { "className": "text-sm text-gray-600 dark:text-gray-400" }, "text": "$t:admin.settings.info.config_file" },
                { "type": "basic", "name": "Span", "props": { "className": "text-sm font-mono text-gray-900 dark:text-white break-all" }, "text": "{{systemInfo?.data?.config_path ?? '-'}}" }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex justify-between items-center py-2"
              },
              "children": [
                { "type": "basic", "name": "Span", "props": { "className": "text-sm text-gray-600 dark:text-gray-400" }, "text": "$t:admin.settings.info.log_path" },
                { "type": "basic", "name": "Span", "props": { "className": "text-sm font-mono text-gray-900 dark:text-white break-all" }, "text": "{{systemInfo?.data?.log_path ?? '-'}}" }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex justify-between items-center py-2"
              },
              "children": [
                { "type": "basic", "name": "Span", "props": { "className": "text-sm text-gray-600 dark:text-gray-400" }, "text": "$t:admin.settings.info.upload_path" },
                { "type": "basic", "name": "Span", "props": { "className": "text-sm font-mono text-gray-900 dark:text-white break-all" }, "text": "{{systemInfo?.data?.upload_path ?? '-'}}" }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "card_database_config",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-6"
      },
      "children": [
        {
          "type": "basic",
          "name": "H3",
          "props": {
            "className": "text-lg font-semibold text-gray-900 dark:text-white mb-1"
          },
          "text": "$t:admin.settings.info.database_config"
        },
        {
          "type": "basic",
          "name": "P",
          "props": {
            "className": "text-sm text-gray-500 dark:text-gray-400 mb-6"
          },
          "text": "$t:admin.settings.info.database_config_desc"
        },
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "space-y-6"
          },
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex items-center gap-2 mb-4"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-sm font-medium text-gray-700 dark:text-gray-300"
                  },
                  "text": "$t:admin.settings.info.config_type"
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "{{systemInfo?.data?.database_config?.has_read_write_split ? 'inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200' : 'inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-200'}}"
                  },
                  "text": "{{systemInfo?.data?.database_config?.has_read_write_split ? $t('admin.settings.info.read_write_split') : $t('admin.settings.info.write_only')}}"
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "grid grid-cols-1 lg:grid-cols-2 gap-6"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "bg-gray-50 dark:bg-gray-900 rounded-lg p-4"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "P",
                      "props": {
                        "className": "text-sm font-medium text-gray-700 dark:text-gray-300 mb-3"
                      },
                      "text": "$t:admin.settings.info.write_db"
                    },
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "space-y-2"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Div",
                          "props": {
                            "className": "flex justify-between items-center py-1.5"
                          },
                          "children": [
                            { "type": "basic", "name": "Span", "props": { "className": "text-sm text-gray-600 dark:text-gray-400" }, "text": "$t:admin.settings.info.db_host" },
                            { "type": "basic", "name": "Span", "props": { "className": "text-sm font-mono text-gray-900 dark:text-white" }, "text": "{{systemInfo?.data?.database_config?.write?.host ?? '-'}}" }
                          ]
                        },
                        {
                          "type": "basic",
                          "name": "Div",
                          "props": {
                            "className": "flex justify-between items-center py-1.5"
                          },
                          "children": [
                            { "type": "basic", "name": "Span", "props": { "className": "text-sm text-gray-600 dark:text-gray-400" }, "text": "$t:admin.settings.info.db_port" },
                            { "type": "basic", "name": "Span", "props": { "className": "text-sm font-mono text-gray-900 dark:text-white" }, "text": "{{systemInfo?.data?.database_config?.write?.port ?? '-'}}" }
                          ]
                        },
                        {
                          "type": "basic",
                          "name": "Div",
                          "props": {
                            "className": "flex justify-between items-center py-1.5"
                          },
                          "children": [
                            { "type": "basic", "name": "Span", "props": { "className": "text-sm text-gray-600 dark:text-gray-400" }, "text": "$t:admin.settings.info.db_name" },
                            { "type": "basic", "name": "Span", "props": { "className": "text-sm font-mono text-gray-900 dark:text-white" }, "text": "{{systemInfo?.data?.database_config?.write?.database ?? '-'}}" }
                          ]
                        },
                        {
                          "type": "basic",
                          "name": "Div",
                          "props": {
                            "className": "flex justify-between items-center py-1.5"
                          },
                          "children": [
                            { "type": "basic", "name": "Span", "props": { "className": "text-sm text-gray-600 dark:text-gray-400" }, "text": "$t:admin.settings.info.db_user" },
                            { "type": "basic", "name": "Span", "props": { "className": "text-sm font-mono text-gray-900 dark:text-white" }, "text": "{{systemInfo?.data?.database_config?.write?.username ?? '-'}}" }
                          ]
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "if": "{{systemInfo?.data?.database_config?.has_read_write_split}}",
                  "props": {
                    "className": "bg-gray-50 dark:bg-gray-900 rounded-lg p-4"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "P",
                      "props": {
                        "className": "text-sm font-medium text-gray-700 dark:text-gray-300 mb-3"
                      },
                      "text": "$t:admin.settings.info.read_db"
                    },
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "space-y-4"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Div",
                          "iteration": {
                            "source": "systemInfo?.data?.database_config?.read ?? []",
                            "item_var": "replica",
                            "index_var": "replicaIndex"
                          },
                          "props": {
                            "className": "{{(systemInfo?.data?.database_config?.read?.length ?? 0) > 1 ? 'border-b border-gray-200 dark:border-gray-700 pb-3 last:border-0 last:pb-0' : ''}}"
                          },
                          "children": [
                            {
                              "type": "basic",
                              "name": "P",
                              "if": "{{(systemInfo?.data?.database_config?.read?.length ?? 0) > 1}}",
                              "props": {
                                "className": "text-xs font-medium text-gray-500 dark:text-gray-400 mb-2"
                              },
                              "text": "Replica #{{replicaIndex + 1}}"
                            },
                            {
                              "type": "basic",
                              "name": "Div",
                              "props": {
                                "className": "space-y-2"
                              },
                              "children": [
                                {
                                  "type": "basic",
                                  "name": "Div",
                                  "props": {
                                    "className": "flex justify-between items-center py-1.5"
                                  },
                                  "children": [
                                    { "type": "basic", "name": "Span", "props": { "className": "text-sm text-gray-600 dark:text-gray-400" }, "text": "$t:admin.settings.info.db_host" },
                                    { "type": "basic", "name": "Span", "props": { "className": "text-sm font-mono text-gray-900 dark:text-white" }, "text": "{{replica?.host ?? '-'}}" }
                                  ]
                                },
                                {
                                  "type": "basic",
                                  "name": "Div",
                                  "props": {
                                    "className": "flex justify-between items-center py-1.5"
                                  },
                                  "children": [
                                    { "type": "basic", "name": "Span", "props": { "className": "text-sm text-gray-600 dark:text-gray-400" }, "text": "$t:admin.settings.info.db_port" },
                                    { "type": "basic", "name": "Span", "props": { "className": "text-sm font-mono text-gray-900 dark:text-white" }, "text": "{{replica?.port ?? '-'}}" }
                                  ]
                                },
                                {
                                  "type": "basic",
                                  "name": "Div",
                                  "props": {
                                    "className": "flex justify-between items-center py-1.5"
                                  },
                                  "children": [
                                    { "type": "basic", "name": "Span", "props": { "className": "text-sm text-gray-600 dark:text-gray-400" }, "text": "$t:admin.settings.info.db_name" },
                                    { "type": "basic", "name": "Span", "props": { "className": "text-sm font-mono text-gray-900 dark:text-white" }, "text": "{{replica?.database ?? '-'}}" }
                                  ]
                                },
                                {
                                  "type": "basic",
                                  "name": "Div",
                                  "props": {
                                    "className": "flex justify-between items-center py-1.5"
                                  },
                                  "children": [
                                    { "type": "basic", "name": "Span", "props": { "className": "text-sm text-gray-600 dark:text-gray-400" }, "text": "$t:admin.settings.info.db_user" },
                                    { "type": "basic", "name": "Span", "props": { "className": "text-sm font-mono text-gray-900 dark:text-white" }, "text": "{{replica?.username ?? '-'}}" }
                                  ]
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "if": "{{!systemInfo?.data?.database_config?.has_read_write_split}}",
                  "props": {
                    "className": "bg-gray-50 dark:bg-gray-900 rounded-lg p-4 flex items-center justify-center"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "P",
                      "props": {
                        "className": "text-sm text-gray-500 dark:text-gray-400"
                      },
                      "text": "$t:admin.settings.info.no_read_db"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "card_php_extensions",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-6"
      },
      "children": [
        {
          "type": "basic",
          "name": "H3",
          "props": {
            "className": "text-lg font-semibold text-gray-900 dark:text-white mb-1"
          },
          "text": "$t:admin.settings.info.php_extensions"
        },
        {
          "type": "basic",
          "name": "P",
          "props": {
            "className": "text-sm text-gray-500 dark:text-gray-400 mb-6"
          },
          "text": "$t:admin.settings.info.php_extensions_desc"
        },
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "space-y-6"
          },
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "children": [
                {
                  "type": "basic",
                  "name": "P",
                  "props": {
                    "className": "text-sm font-medium text-gray-700 dark:text-gray-300 mb-3"
                  },
                  "text": "$t:admin.settings.info.required_modules"
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Div",
                      "iteration": {
                        "source": "Object.entries(systemInfo?.data?.php_extensions?.required ?? {})",
                        "item_var": "ext"
                      },
                      "props": {
                        "className": "flex items-center gap-1.5"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Icon",
                          "props": {
                            "name": "{{ext[1] ? 'check' : 'x'}}",
                            "className": "{{ext[1] ? 'w-4 h-4 text-green-500 flex-shrink-0' : 'w-4 h-4 text-red-500 flex-shrink-0'}}"
                          }
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "text-sm text-gray-700 dark:text-gray-300"
                          },
                          "text": "{{ext[0]}}"
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "children": [
                {
                  "type": "basic",
                  "name": "P",
                  "props": {
                    "className": "text-sm font-medium text-gray-700 dark:text-gray-300 mb-3"
                  },
                  "text": "$t:admin.settings.info.optional_modules"
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Div",
                      "iteration": {
                        "source": "Object.entries(systemInfo?.data?.php_extensions?.optional ?? {})",
                        "item_var": "ext"
                      },
                      "props": {
                        "className": "flex items-center gap-1.5"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Icon",
                          "props": {
                            "name": "{{ext[1] ? 'check' : 'x'}}",
                            "className": "{{ext[1] ? 'w-4 h-4 text-green-500 flex-shrink-0' : 'w-4 h-4 text-red-500 flex-shrink-0'}}"
                          }
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "text-sm text-gray-700 dark:text-gray-300"
                          },
                          "text": "{{ext[0]}}"
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
