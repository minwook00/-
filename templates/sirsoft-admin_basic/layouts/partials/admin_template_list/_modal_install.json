{
  "meta": {
    "is_partial": true,
    "description": "템플릿 설치 확인 모달"
  },
  "id": "template_install_modal",
  "type": "composite",
  "name": "Modal",
  "props": {
    "title": "$t:admin.templates.modals.install_title",
    "size": "small"
  },
  "children": [
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "py-2"
      },
      "children": [
        {
          "type": "basic",
          "name": "P",
          "props": {
            "className": "text-gray-700 dark:text-gray-300"
          },
          "text": "$t:admin.templates.modals.install_confirm|name={{_global.selectedTemplate.name}}"
        },
        {
          "type": "basic",
          "name": "P",
          "props": {
            "className": "mt-2 text-sm text-gray-500 dark:text-gray-400"
          },
          "text": "$t:admin.templates.modals.install_description"
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "flex justify-end gap-3 mt-6"
      },
      "children": [
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "className": "px-4 py-2 bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 disabled:opacity-50 disabled:cursor-not-allowed",
            "disabled": "{{_global.isTemplateInstalling}}"
          },
          "actions": [
            {
              "type": "click",
              "handler": "closeModal"
            }
          ],
          "children": [
            {
              "type": "basic",
              "name": "Span",
              "text": "$t:common.cancel"
            }
          ]
        },
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "className": "flex items-center gap-2 px-4 py-2 bg-gray-900 dark:bg-white text-white dark:text-gray-900 rounded-lg hover:bg-gray-800 dark:hover:bg-gray-100 disabled:opacity-50 disabled:cursor-not-allowed",
            "disabled": "{{_global.isTemplateInstalling}}"
          },
          "actions": [
            {
              "type": "click",
              "handler": "sequence",
              "actions": [
                {
                  "handler": "setState",
                  "params": {
                    "target": "global",
                    "isTemplateInstalling": true
                  }
                },
                {
                  "handler": "apiCall",
                  "auth_required": true,
                  "target": "/api/admin/templates/install",
                  "params": {
                    "method": "POST",
                    "body": {
                      "template_name": "{{_global.selectedTemplate.identifier}}"
                    }
                  },
                  "onSuccess": [
                    {
                      "handler": "setState",
                      "params": {
                        "target": "global",
                        "isTemplateInstalling": false
                      }
                    },
                    {
                      "handler": "setState",
                      "params": {
                        "target": "global",
                        "selectedTemplate": null
                      }
                    },
                    {
                      "handler": "toast",
                      "params": {
                        "type": "success",
                        "message": "$t:admin.templates.install_success"
                      }
                    },
                    {
                      "handler": "refetchDataSource",
                      "params": {
                        "dataSourceId": "templates"
                      }
                    },
                    {
                      "handler": "reloadExtensions"
                    },
                    {
                      "handler": "closeModal"
                    }
                  ],
                  "onError": [
                    {
                      "handler": "setState",
                      "params": {
                        "target": "global",
                        "isTemplateInstalling": false
                      }
                    },
                    {
                      "handler": "toast",
                      "params": {
                        "type": "error",
                        "message": "{{error.message}}"
                      }
                    }
                  ]
                }
              ]
            }
          ],
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "if": "{{!_global.isTemplateInstalling}}",
              "props": {
                "name": "download",
                "className": "w-4 h-4"
              }
            },
            {
              "type": "basic",
              "name": "Icon",
              "if": "{{_global.isTemplateInstalling}}",
              "props": {
                "name": "spinner",
                "className": "w-4 h-4 animate-spin"
              }
            },
            {
              "type": "basic",
              "name": "Span",
              "text": "{{_global.isTemplateInstalling ? '$t:admin.templates.installing' : '$t:admin.templates.actions.install'}}"
            }
          ]
        }
      ]
    }
  ]
}
