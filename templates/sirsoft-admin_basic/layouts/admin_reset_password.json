{
  "version": "1.0.0",
  "layout_name": "admin_reset_password",
  "meta": {
    "title": "$t:auth.reset_password.title",
    "description": "관리자 비밀번호 재설정 페이지",
    "auth_required": false
  },
  "data_sources": [
    {
      "id": "tokenValidation",
      "type": "api",
      "endpoint": "/api/auth/validate-reset-token",
      "method": "POST",
      "auto_fetch": true,
      "auth_required": false,
      "params": {
        "token": "{{query.token ?? ''}}",
        "email": "{{query.email ?? ''}}"
      },
      "loading_strategy": "blocking",
      "initLocal": {
        "tokenValid": "{{data.valid ?? false}}"
      },
      "errorHandling": {
        "422": {
          "handler": "setState",
          "params": {
            "target": "local",
            "tokenError": true
          }
        },
        "default": {
          "handler": "setState",
          "params": {
            "target": "local",
            "tokenError": true
          }
        }
      }
    }
  ],
  "init_actions": [
    {
      "handler": "initTheme",
      "target": "{{query.theme}}"
    },
    {
      "handler": "setState",
      "params": {
        "target": "local",
        "isSubmitting": false,
        "success": false,
        "resetError": null,
        "resetErrors": null
      }
    }
  ],
  "components": [
    {
      "id": "reset_page_wrapper",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "min-h-screen flex items-center justify-center bg-gray-50 dark:bg-gray-900 px-4 sm:px-6 lg:px-8"
      },
      "children": [
        {
          "id": "reset_card_container",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "max-w-md w-full space-y-8"
          },
          "children": [
            {
              "id": "reset_card",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "bg-white dark:bg-gray-800 rounded-lg shadow-md p-8"
              },
              "children": [
                {
                  "comment": "헤더",
                  "id": "reset_header",
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "text-center mb-8"
                  },
                  "children": [
                    {
                      "id": "reset_icon_wrapper",
                      "type": "basic",
                      "name": "Div",
                      "if": "{{!_local.tokenError}}",
                      "props": {
                        "className": "w-16 h-16 mx-auto mb-4 bg-blue-100 dark:bg-blue-900/30 rounded-full flex items-center justify-center"
                      },
                      "children": [
                        {
                          "id": "reset_lock_icon",
                          "type": "basic",
                          "name": "Icon",
                          "props": {
                            "name": "lock",
                            "size": "xl",
                            "color": "text-blue-600 dark:text-blue-400"
                          }
                        }
                      ]
                    },
                    {
                      "id": "reset_warning_icon_wrapper",
                      "type": "basic",
                      "name": "Div",
                      "if": "{{_local.tokenError}}",
                      "props": {
                        "className": "w-16 h-16 mx-auto mb-4 bg-red-100 dark:bg-red-900/30 rounded-full flex items-center justify-center"
                      },
                      "children": [
                        {
                          "id": "reset_warning_icon",
                          "type": "basic",
                          "name": "Icon",
                          "props": {
                            "name": "triangle-exclamation",
                            "size": "xl",
                            "color": "text-red-600 dark:text-red-400"
                          }
                        }
                      ]
                    },
                    {
                      "id": "reset_title",
                      "type": "basic",
                      "name": "H1",
                      "if": "{{!_local.tokenError}}",
                      "props": {
                        "className": "text-2xl font-bold text-gray-900 dark:text-white mb-2"
                      },
                      "text": "$t:auth.reset_password.title"
                    },
                    {
                      "id": "reset_title_invalid",
                      "type": "basic",
                      "name": "H1",
                      "if": "{{_local.tokenError}}",
                      "props": {
                        "className": "text-2xl font-bold text-gray-900 dark:text-white mb-2"
                      },
                      "text": "$t:auth.reset_password.invalid_token_title"
                    },
                    {
                      "id": "reset_subtitle",
                      "type": "basic",
                      "name": "P",
                      "if": "{{!_local.tokenError && !_local.success}}",
                      "props": {
                        "className": "text-sm text-gray-600 dark:text-gray-400"
                      },
                      "text": "$t:auth.reset_password.subtitle"
                    }
                  ]
                },
                {
                  "comment": "토큰 에러",
                  "id": "reset_token_error",
                  "type": "basic",
                  "name": "Div",
                  "if": "{{_local.tokenError}}",
                  "props": {
                    "className": "text-center"
                  },
                  "children": [
                    {
                      "id": "reset_token_error_text",
                      "type": "basic",
                      "name": "P",
                      "props": {
                        "className": "text-gray-600 dark:text-gray-400 mb-6"
                      },
                      "text": "$t:auth.reset_password.invalid_token"
                    },
                    {
                      "id": "reset_token_error_button",
                      "type": "basic",
                      "name": "Button",
                      "props": {
                        "type": "button",
                        "className": "w-full px-4 py-3 rounded-lg font-medium bg-blue-600 hover:bg-blue-700 dark:bg-blue-500 dark:hover:bg-blue-600 text-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 dark:focus:ring-offset-gray-900 transition-colors duration-200 cursor-pointer"
                      },
                      "actions": [
                        {
                          "type": "click",
                          "handler": "navigate",
                          "params": {
                            "path": "/admin/forgot-password"
                          }
                        }
                      ],
                      "text": "$t:auth.reset_password.go_to_forgot_password"
                    }
                  ]
                },
                {
                  "comment": "성공 메시지",
                  "id": "reset_success",
                  "type": "basic",
                  "name": "Div",
                  "if": "{{_local.success && !_local.tokenError}}",
                  "props": {
                    "className": "text-center"
                  },
                  "children": [
                    {
                      "id": "reset_success_icon_wrapper",
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "mb-4 p-4 bg-green-50 dark:bg-green-900/30 border border-green-200 dark:border-green-800 rounded-lg"
                      },
                      "children": [
                        {
                          "id": "reset_success_text",
                          "type": "basic",
                          "name": "P",
                          "props": {
                            "className": "text-green-700 dark:text-green-300 text-sm"
                          },
                          "text": "$t:auth.reset_password.success"
                        }
                      ]
                    },
                    {
                      "id": "reset_success_login_button",
                      "type": "basic",
                      "name": "Button",
                      "props": {
                        "type": "button",
                        "className": "w-full px-4 py-3 rounded-lg font-medium bg-blue-600 hover:bg-blue-700 dark:bg-blue-500 dark:hover:bg-blue-600 text-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 dark:focus:ring-offset-gray-900 transition-colors duration-200 cursor-pointer"
                      },
                      "actions": [
                        {
                          "type": "click",
                          "handler": "navigate",
                          "params": {
                            "path": "/admin/login"
                          }
                        }
                      ],
                      "text": "$t:auth.reset_password.go_to_login"
                    }
                  ]
                },
                {
                  "comment": "비밀번호 재설정 폼",
                  "id": "reset_form",
                  "type": "basic",
                  "name": "Form",
                  "if": "{{!_local.success && !_local.tokenError}}",
                  "props": {
                    "className": "space-y-6"
                  },
                  "actions": [
                    {
                      "type": "submit",
                      "handler": "sequence",
                      "actions": [
                        {
                          "handler": "setState",
                          "params": {
                            "target": "local",
                            "isSubmitting": true,
                            "resetError": null,
                            "resetErrors": null
                          }
                        },
                        {
                          "handler": "apiCall",
                          "target": "/api/auth/reset-password",
                          "params": {
                            "method": "POST",
                            "body": {
                              "token": "{{query.token ?? ''}}",
                              "email": "{{query.email ?? ''}}",
                              "password": "{{form.password}}",
                              "password_confirmation": "{{form.password_confirmation}}"
                            }
                          },
                          "onSuccess": {
                            "handler": "setState",
                            "params": {
                              "target": "local",
                              "isSubmitting": false,
                              "success": true
                            }
                          },
                          "onError": [
                            {
                              "handler": "setState",
                              "params": {
                                "target": "local",
                                "isSubmitting": false,
                                "resetError": "{{error.message ?? ''}}",
                                "resetErrors": "{{error.errors ?? null}}"
                              }
                            }
                          ]
                        }
                      ]
                    }
                  ],
                  "children": [
                    {
                      "comment": "일반 에러 메시지 (필드 에러가 아닌 경우)",
                      "id": "reset_error_message",
                      "type": "basic",
                      "name": "Div",
                      "if": "{{_local.resetError && !_local.resetErrors}}",
                      "props": {
                        "className": "p-4 bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-800 rounded-lg"
                      },
                      "children": [
                        {
                          "id": "reset_error_text",
                          "type": "basic",
                          "name": "P",
                          "props": {
                            "className": "text-red-700 dark:text-red-300 text-sm text-center"
                          },
                          "text": "{{_local.resetError}}"
                        }
                      ]
                    },
                    {
                      "comment": "새 비밀번호",
                      "id": "reset_password_field",
                      "type": "basic",
                      "name": "Div",
                      "children": [
                        {
                          "id": "reset_password_label",
                          "type": "basic",
                          "name": "Label",
                          "props": {
                            "htmlFor": "password",
                            "className": "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2"
                          },
                          "text": "$t:auth.reset_password.password"
                        },
                        {
                          "id": "reset_password_input",
                          "type": "basic",
                          "name": "Input",
                          "props": {
                            "id": "password",
                            "type": "password",
                            "name": "password",
                            "className": "{{_local.resetErrors?.password ? 'w-full px-4 py-3 border border-red-500 dark:border-red-500 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white placeholder-gray-400 dark:placeholder-gray-500 focus:outline-none focus:ring-2 focus:border-red-500 focus:ring-red-500 disabled:opacity-50 disabled:cursor-not-allowed transition-colors duration-200' : 'w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white placeholder-gray-400 dark:placeholder-gray-500 focus:outline-none focus:ring-2 focus:border-blue-500 focus:ring-blue-500 disabled:opacity-50 disabled:cursor-not-allowed transition-colors duration-200'}}",
                            "required": true,
                            "disabled": "{{_local.isSubmitting ?? false}}"
                          }
                        },
                        {
                          "id": "reset_password_error",
                          "type": "basic",
                          "name": "P",
                          "if": "{{_local.resetErrors?.password}}",
                          "props": {
                            "className": "mt-2 text-sm text-red-600 dark:text-red-400"
                          },
                          "text": "{{Array.isArray(_local.resetErrors?.password) ? _local.resetErrors.password[0] : _local.resetErrors?.password}}"
                        }
                      ]
                    },
                    {
                      "comment": "비밀번호 확인",
                      "id": "reset_password_confirm_field",
                      "type": "basic",
                      "name": "Div",
                      "children": [
                        {
                          "id": "reset_password_confirm_label",
                          "type": "basic",
                          "name": "Label",
                          "props": {
                            "htmlFor": "password_confirmation",
                            "className": "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2"
                          },
                          "text": "$t:auth.reset_password.password_confirmation"
                        },
                        {
                          "id": "reset_password_confirm_input",
                          "type": "basic",
                          "name": "Input",
                          "props": {
                            "id": "password_confirmation",
                            "type": "password",
                            "name": "password_confirmation",
                            "className": "{{_local.resetErrors?.password_confirmation ? 'w-full px-4 py-3 border border-red-500 dark:border-red-500 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white placeholder-gray-400 dark:placeholder-gray-500 focus:outline-none focus:ring-2 focus:border-red-500 focus:ring-red-500 disabled:opacity-50 disabled:cursor-not-allowed transition-colors duration-200' : 'w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white placeholder-gray-400 dark:placeholder-gray-500 focus:outline-none focus:ring-2 focus:border-blue-500 focus:ring-blue-500 disabled:opacity-50 disabled:cursor-not-allowed transition-colors duration-200'}}",
                            "required": true,
                            "disabled": "{{_local.isSubmitting ?? false}}"
                          }
                        },
                        {
                          "id": "reset_password_confirm_error",
                          "type": "basic",
                          "name": "P",
                          "if": "{{_local.resetErrors?.password_confirmation}}",
                          "props": {
                            "className": "mt-2 text-sm text-red-600 dark:text-red-400"
                          },
                          "text": "{{Array.isArray(_local.resetErrors?.password_confirmation) ? _local.resetErrors.password_confirmation[0] : _local.resetErrors?.password_confirmation}}"
                        }
                      ]
                    },
                    {
                      "comment": "제출 버튼",
                      "id": "reset_submit_button",
                      "type": "basic",
                      "name": "Button",
                      "props": {
                        "type": "submit",
                        "className": "w-full px-4 py-3 rounded-lg font-medium bg-blue-600 hover:bg-blue-700 dark:bg-blue-500 dark:hover:bg-blue-600 text-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 dark:focus:ring-offset-gray-900 disabled:opacity-50 disabled:cursor-not-allowed transition-colors duration-200 flex items-center justify-center gap-2",
                        "disabled": "{{_local.isSubmitting ?? false}}"
                      },
                      "children": [
                        {
                          "id": "reset_submit_spinner",
                          "type": "basic",
                          "name": "Div",
                          "if": "{{_local.isSubmitting}}",
                          "props": {
                            "className": "w-5 h-5 border-2 border-white/30 border-t-white rounded-full animate-spin"
                          }
                        },
                        {
                          "id": "reset_submit_text",
                          "type": "basic",
                          "name": "Span",
                          "if": "{{!_local.isSubmitting}}",
                          "text": "$t:auth.reset_password.submit"
                        },
                        {
                          "id": "reset_submit_processing",
                          "type": "basic",
                          "name": "Span",
                          "if": "{{_local.isSubmitting}}",
                          "text": "$t:auth.reset_password.processing"
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "comment": "언어 셀렉터",
              "id": "reset_language_selector_container",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "mt-6"
              },
              "children": [
                {
                  "id": "reset_language_selector",
                  "type": "basic",
                  "name": "Select",
                  "props": {
                    "className": "block w-full px-4 py-2.5 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm",
                    "value": "{{$locale}}",
                    "options": "{{$locales}}"
                  },
                  "actions": [
                    {
                      "type": "change",
                      "handler": "setLocale",
                      "target": "{{event.target.value}}"
                    }
                  ]
                }
              ]
            },
            {
              "comment": "테마 Segmented Control",
              "id": "reset_theme_selector_container",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "mt-4 flex justify-center"
              },
              "children": [
                {
                  "id": "reset_theme_segmented_control",
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "inline-flex bg-gray-100 dark:bg-gray-800 rounded-lg p-1 gap-1"
                  },
                  "children": [
                    {
                      "id": "reset_theme_light_button",
                      "type": "basic",
                      "name": "Button",
                      "props": {
                        "type": "button",
                        "className": "{{_global.theme === 'light' ? 'p-2 rounded-md bg-white dark:bg-gray-700 shadow-sm text-blue-600 dark:text-blue-400 transition-all duration-200' : 'p-2 rounded-md text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300 transition-all duration-200'}}",
                        "title": "$t:admin.theme.light"
                      },
                      "actions": [
                        {
                          "type": "click",
                          "handler": "setTheme",
                          "target": "light"
                        }
                      ],
                      "children": [
                        {
                          "id": "reset_theme_light_icon",
                          "type": "basic",
                          "name": "Icon",
                          "props": {
                            "name": "sun",
                            "size": "sm"
                          }
                        }
                      ]
                    },
                    {
                      "id": "reset_theme_dark_button",
                      "type": "basic",
                      "name": "Button",
                      "props": {
                        "type": "button",
                        "className": "{{_global.theme === 'dark' ? 'p-2 rounded-md bg-white dark:bg-gray-700 shadow-sm text-blue-600 dark:text-blue-400 transition-all duration-200' : 'p-2 rounded-md text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300 transition-all duration-200'}}",
                        "title": "$t:admin.theme.dark"
                      },
                      "actions": [
                        {
                          "type": "click",
                          "handler": "setTheme",
                          "target": "dark"
                        }
                      ],
                      "children": [
                        {
                          "id": "reset_theme_dark_icon",
                          "type": "basic",
                          "name": "Icon",
                          "props": {
                            "name": "moon",
                            "size": "sm"
                          }
                        }
                      ]
                    },
                    {
                      "id": "reset_theme_auto_button",
                      "type": "basic",
                      "name": "Button",
                      "props": {
                        "type": "button",
                        "className": "{{_global.theme === 'auto' || !_global.theme ? 'p-2 rounded-md bg-white dark:bg-gray-700 shadow-sm text-blue-600 dark:text-blue-400 transition-all duration-200' : 'p-2 rounded-md text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300 transition-all duration-200'}}",
                        "title": "$t:admin.theme.auto"
                      },
                      "actions": [
                        {
                          "type": "click",
                          "handler": "setTheme",
                          "target": "auto"
                        }
                      ],
                      "children": [
                        {
                          "id": "reset_theme_auto_icon",
                          "type": "basic",
                          "name": "Icon",
                          "props": {
                            "name": "desktop",
                            "size": "sm"
                          }
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
