{
  "extension_point": "address_search_slot",
  "scripts": [
    {
      "src": "//t1.daumcdn.net/mapjsapi/bundle/postcode/prod/postcode.v2.js",
      "id": "daum_postcode_script"
    }
  ],
  "components": [
    {
      "id": "daum_postcode_container",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "inline-flex"
      },
      "lifecycle": {
        "onMount": [
          {
            "comment": "주소 검색 플러그인 마운트 시 지정된 필드를 readOnly로 설정",
            "handler": "sirsoft-daum_postcode.setFieldReadOnly",
            "params": {
              "fields": "{{extensionPointProps.readOnlyFields ?? ['zipcode', 'address']}}",
              "readOnly": true
            }
          }
        ]
      },
      "children": [
        {
          "id": "btn_search_address",
          "type": "basic",
          "name": "Button",
          "props": {
            "type": "button",
            "className": "px-3 py-2 bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-600 text-sm font-medium transition-colors"
          },
          "text": "$t:sirsoft-daum_postcode.search_address",
          "actions": [
            {
              "type": "click",
              "comment": "G7 표준 형식으로 변환하여 callbackAction 실행 (하이브리드 방식)",
              "handler": "sirsoft-daum_postcode.openPostcode",
              "params": {
                "displayMode": "{{_global.plugins['sirsoft-daum_postcode']?.display_mode ?? 'layer'}}",
                "width": "{{_global.plugins['sirsoft-daum_postcode']?.popup_width ?? 500}}",
                "height": "{{_global.plugins['sirsoft-daum_postcode']?.popup_height ?? 600}}",
                "theme": {
                  "searchBgColor": "{{_global.plugins['sirsoft-daum_postcode']?.theme_color ?? '#1D4ED8'}}",
                  "queryTextColor": "#FFFFFF"
                },
                "callbackAction": "{{extensionPointCallbacks.onAddressSelect}}",
                "targetFields": "{{extensionPointProps.targetFields}}"
              }
            }
          ]
        }
      ]
    }
  ],
  "priority": 100
}
